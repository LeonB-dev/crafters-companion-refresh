{% doc %}
  Renders CTV header navigation with menu.

  @example
  {% render 'ctv-navigation' %}
{% enddoc %}
{%- liquid
  assign snippet_name = 'snippet-ctv-navigation'

  assign live_show_url = shop.metafields.ctv.live_show.value

  if live_show_url == "false"
    assign live_show_url = blank
  endif
%}

<div class="{{ snippet_name }}" data-ctv-nav-container>
  <div class="container">
    <nav class="nav">
      <div class="logo">
        {%- capture ctv_logo -%}
          {%- render 'icon', _name: 'icon-crafters-tv-logo' -%}
        {%- endcapture -%}
        {%- if template contains 'page-ctv-landing' -%}
          {{- ctv_logo -}}
        {%- else -%}
          <a href="{{- settings.ctv_header_link -}}">
            {{- ctv_logo -}}
          </a>
        {%- endif -%}
      </div>
      {% if live_show_url != blank %}
        <a href="{{ live_show_url }}" title="{{ 'ctv.watch_live' | t }}" class="watch-live">
          {{ 'ctv.watch_live' | t }}
        </a>
      {% endif %}
      <ul data-ctv-nav>
        {%- for link in linklists[settings.ctv_navigation].links -%}
          <li
            {% if link.url == page.url or link.url == collection.url or link.url == blog.url %}
              class="current"
            {% endif %}
            data-name-{{- link.title | handleize }}
          >
            <a href="{{ link.url }}" title="{{ link.title | escape }}">
              {{- link.title | escape -}}
            </a>
          </li>
        {%- endfor -%}
      </ul>
      <button type="button" class="c-btn ctv-nav-open" data-ctv-nav-open>
        Menu
        {%- render 'icon', _name: 'icon-chevron-down' -%}
      </button>
    </nav>
  </div>
</div>

{% javascript %}
(()=>{"use strict";const e={visible:"is-visible",active:"is-active"},t={};function n(){t.headerHeight=t.header.getBoundingClientRect(),t.headerTop=t.headerHeight.height}function i(){t.navToggleElement.removeEventListener("click",o)}function a(){window.matchMedia(`(max-width: ${window.theme.breakpoints.lg}px)`).matches&&t.navToggleElement&&t.navToggleElement.addEventListener("click",o)}function o(){t.navContainerElement.classList.toggle(e.visible),t.navToggleElement.classList.toggle(e.active)}function d(){window.matchMedia(`(min-height: ${window.theme.breakpoints.md}px)`).matches?t.navElement.style.top=`${t.headerTop}px`:t.navElement.style.top="auto"}window.onload=function(){t.navElement=document.querySelector("[data-ctv-nav-container]"),t.navContainerElement=document.querySelector("[data-ctv-nav]"),t.navToggleElement=document.querySelector("[data-ctv-nav-open]"),t.header=document.querySelector(".site-header"),n(),a(),d(),window.addEventListener("breakpoint-down:lg",a),window.addEventListener("breakpoint-up:lg",i),window.addEventListener("resize",(e=>{window.innerHeight<"768"?(n(),t.navElement.style.top="auto"):(n(),d())}))}})();
