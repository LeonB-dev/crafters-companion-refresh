{% doc %}
  Creates swiper carousel container for media items.

  @param {array} _media_blocks - Array of media block objects to display in the carousel
  @param {number} _offset - Number of items to offset from the start
  @param {number} _col_limit - Maximum number of items to display
  @param {string} _fallback_link - Fallback URL passed to each carousel item

  @example
  {% render 'carousel', _media_blocks: section.blocks, _offset: 0, _col_limit: 6, _fallback_link: collection.url %}
{% enddoc %}
{% assign video_blocks = _media_blocks | where: 'type', 'video' %}

<div
  class="swiper-container swiper-container-free-mode"
  data-slider="inspiration{%- if _offset > 0 -%}-2{%- else -%}-1{%- endif %}"
  data-autoplay="false"
  data-vertical="true"
  data-loop="true"
  data-slides-visible="4.5/3.1/2">
  <div class="swiper-wrapper">
    {% if _offset > 0 %}
      {% assign offset_loop = true %}
    {% endif %}
    {% if offset_loop %}
      {% for media in _media_blocks offset: _offset %}
        {% assign offset_index = forloop.index | plus: _offset %}
        <div class="swiper-slide">
          {% render 'carousel-item' _media: media, _index: offset_index, _fallback_link: _fallback_link %}
        </div>
      {% endfor %}
    {% else %}
      {% for media in _media_blocks limit: _col_limit %}
        <div class="swiper-slide">
          {% render 'carousel-item' _media: media, _index: forloop.index, _fallback_link: _fallback_link  %}
        </div>
      {% endfor %}
    {% endif %}
  </div>
</div>