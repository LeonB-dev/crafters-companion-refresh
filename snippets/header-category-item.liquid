{% doc %}
  Renders header category display item.

  @param {string} _heading - The category heading text
  @param {string} _heading_color - CSS color for the heading text
  @param {string} _background_color - CSS background color for the item
  @param {image} _image - The category image
  @param {string} _loading - The image loading attribute value
  @param {string} _url - The link URL for the category
  @param {string} _button_text - The call-to-action button label
  @param {string} _button_text_color - CSS color for the button text
  @param {string} _button_background_color - CSS background color for the button
  @param {string} _lozenge - Optional lozenge badge text

  @example
  {% render 'header-category-item', _heading: 'New Arrivals', _url: '/collections/new', _button_text: 'Shop Now' %}
{% enddoc %}
<div class="snippet-collection-item" style="background-color: {{ _background_color }}">
  {%- if _lozenge != blank -%}
    <span class="c-lozenge carnation">{{- _lozenge -}}</span>
  {%- endif -%}
  
  <div class="snippet-collection-item__heading" style="color: {{ _heading_color }};">{{ _heading }}</div>

  <div class="image">
    {%- if _image != blank -%}
      <img src="{{ _image | image_url: width: 400 }}" alt="{{ _heading }}" height="332" width="295" loading="{{- _loading -}}">
    {%- else -%}
      {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
    {%- endif -%}
  </div>
  <a href="{{ _url }}" class="button stretched-link" title="{{- _heading -}}" 
      style="color: {{ _button_text_color }}; background-color: {{ _button_background_color }};">
    {{ _button_text }}
  </a>
  
</div>
