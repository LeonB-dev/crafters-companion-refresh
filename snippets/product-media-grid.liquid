{% liquid
  assign medias = product.media | where: 'media_type', 'image'
  assign product_videos = product.media | where: 'media_type', 'video'
  assign product_external_videos = product.media | where: 'media_type', 'external_video'
  assign product_media_array = medias | concat: product_videos | concat: product_external_videos

  assign parent_brand = product.metafields.custom.parent_brand.value

  if parent_brand != blank
    assign brand_metaobject = parent_brand
  else
    assign product_vendor = product.vendor | handleize
    assign collection = collections[product_vendor]
    assign brand_metaobject = collection.metafields.custom.brand.value
  endif

  assign brand_logo = brand_metaobject.sticker_logo
  assign brand_name = brand_metaobject.name
  assign brand_logo_alt = brand_logo.alt | default: brand_name
%}

<style>
  {% if product.media.size == 4 %}
    @media (min-width:1024px){
      .product-media-grid .grid > div:last-of-type{
        grid-column: 1/ span 2;
      }
    }
  {% endif %}
</style>

<div class="product-media-grid">
  {% if brand_logo != blank %}
    <a href="{{ collection.url }}" class="brand-logo" aria-label="{{ collection.title }}">
      {{ brand_logo | image_url: height: 40 | image_tag: alt: brand_logo_alt, loading: 'lazy' }}
    </a>
  {% endif %}
  <div class="grid">
    {%- if product.media.size > 0 -%}
      {%- for media in product.media limit: 5 -%}
        {%- if media.media_type == 'image' -%}
          <div class="image" style="background-image: url('{{ media.preview_image | image_url: width: 1000 }}')" onmousemove="zoom(event)" data-thumbnail-id="{{ media.id }}" data-media-id="{{ media.id }}" data-product-image>
            <img src="{{ media.preview_image | image_url: width: 600 }}" alt="{{ media.alt | default: product.title | strip_html -}}" loading="eager" height="366" width="366">
          </div>
        {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
          <div class="video-image {{ media.media_type }}">
            <div data-media-id="{{ media.id }}">
              <img src="{{ media.preview_image | image_url: width: 600 }}" alt="{{ media.alt | default: product.title -}}" loading="lazy" height="366" width="366">
            </div>
            <button class="c-btn modal-open" aria-controls="{{- media.id -}}" data-pmg-modal-open>
              {%- render 'icon', _name: 'icon-play' -%}
              Watch video
            </button>
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
    {%- endif -%}
  </div>
  {% if product.media.size > 5 -%}
    <button class="c-btn main tertiary media-open" data-pmg-slider-open>{{- 'template.product.see_more_images' | t -}}</button>
  {%- endif -%}
</div>

<script>
  function zoom(e) {
    var zoomer = e.currentTarget;
    e.offsetX ? (offsetX = e.offsetX) : (offsetX = e.touches[0].pageX);
    e.offsetY ? (offsetY = e.offsetY) : (offsetX = e.touches[0].pageX);
    x = (offsetX / zoomer.offsetWidth) * 100;
    y = (offsetY / zoomer.offsetHeight) * 100;
    zoomer.style.backgroundPosition = x + '% ' + y + '%';
  }
</script>
