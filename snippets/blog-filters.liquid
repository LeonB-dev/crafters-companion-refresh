{% doc %}
  Renders filterable blog navigation with category filters.

  @example
  {% render 'blog-filters' %}
{% enddoc %}
{% liquid
  assign active_tag = request.path | split: '/' | last

  for tag in blog.all_tags
    assign tag_split = tag | split: '_' | first
    assign tag_split_handleize = tag_split | handleize

    case tag_split_handleize
      when 'craft-area'
        assign show_craft_area = true
      when 'craft-expert'
        assign show_craft_expert = true
      when 'skill-difficulty'
        assign show_skill_difficulty = true
      when 'occasion'
        assign show_occasion = true
      when 'technique'
        assign show_technique = true
      when 'seasonal'
        assign show_seasonal = true
      when 'collection'
        assign show_collection = true
      when 'show'
        assign show_shows = true
      when 'date'
        assign show_date = true
    endcase
  endfor

  assign disabled_class = 'is-disabled'
%}

<div class="snippet-blog-filters" id="blog-filters" data-bf>
  <button class="close-filters c-btn" data-bf-close>
    {%- render 'icon', _name: 'icon-close' -%}
  </button>
  <nav>
    <ul class="tier-1">
      {%- comment -%}Craft Experts{%- endcomment -%}
      {%- if show_craft_expert == true -%}
        <li>
          <button class="c-btn" aria-controls="craft-experts" aria-expanded="false" data-bf-toggle>
            {%- render 'icon', _name: 'icon-craft-experts' -%}
            <span>
              {{- 'template.blog.craft_expert_title' | t -}}
              {%- render 'icon', _name: 'icon-chevron-down' -%}
            </span>
          </button>
          <ul class="tier-2" id="craft-experts" data-bf-option>
            {%- for tag in blog.all_tags -%}
              {% liquid
                assign tag_split = tag | split: '_' | first
                assign tag_split_handleize = tag_split | handleize
                assign current_tag = tag | handleize

              %}
              {%- if tag_split_handleize contains 'craft-expert' -%}
                <li
                  {% if current_tags contains tag -%}
                    class="is-active"
                    {% unless current_tags contains tag -%}
                      class="disabled"
                    {%- endunless -%}
                  {%- endif -%}
                  data-bf-category
                >
                  {%- if current_tags contains tag -%}
                    {{ tag | split: '_' | last | link_to_remove_tag: tag }}
                  {%- else -%}
                    {{ tag | split: '_' | last | link_to_add_tag: tag }}
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </li>
      {%- endif -%}
      {%- comment -%}Craft Area{%- endcomment -%}
      {%- if show_craft_area == true -%}
