{% doc %}
  Content section with image, text, and optional decorative shapes.

  @param {section} _section - The section object containing settings and blocks
  @param {boolean} _enable_dots - Whether to enable decorative dot patterns
  @param {boolean} _enable_shapes - Whether to enable decorative shapes
  @param {boolean} _ctvp - Whether to enable CTV player functionality
  @param {string} background_colour - Background colour override

  @example
  {% render 'text-and-image', _section: section, _enable_dots: true, _enable_shapes: true, _ctvp: false, background_colour: '#fff' %}
{% enddoc %}
{% liquid
  assign header_title = _section.settings.header_title
  assign header_image = _section.settings.header_image

  assign main_heading = _section.settings.main_heading
  assign main_text = _section.settings.main_text
  assign main_link_url = _section.settings.main_link_url
  assign main_link_text = _section.settings.main_link_text
  assign main_image = _section.settings.main_image

  assign contain_image = _section.settings.contain_image

  assign link_colour = _section.settings.link_colour
  assign content_position = _section.settings.content_position
  assign layout_direction = _section.settings.layout_direction

  assign heading_size = _section.settings.heading_size

  if _enable_dots == true
    assign dot_colour_top = _section.settings.dot_colour_top
    assign dot_colour_bottom = _section.settings.dot_colour_bottom
  endif

  if _enable_shapes == true
    assign shape_background = _section.settings.shape_background
    assign shape_position = _section.settings.shape_position
    assign shape_class = 'bg-shape ' | append: shape_position
  endif

  if _ctvp == true
    assign main_quote = _section.settings.main_quote
    assign craft_speciality = _section.settings.craft_speciality
    assign craft_technique = _section.settings.craft_technique
  endif

  assign enable_list = false
  assign list_heading = _section.settings.list_heading
  assign list_text = _section.settings.list_text

  if list_text != blank
    assign enable_list = true
    assign list_items = list_text | split: '</p>'
  endif
%}

<style>
  div[data-section-id="{{ _section.id }}"] .container{
    {%- if layout_direction == 'image-left' -%}
      --layout-direction: "image content";
      --grid-columns: var(--image-width) 1fr;
    {%- else -%}
      --layout-direction: "content image";
      --grid-columns: 1fr var(--image-width);
    {%- endif -%}
    {%- if shape_position == 'vertical-start' -%}
      --shape-position: top;
    {% elsif shape_position == 'vertical-end' -%}
      --shape-position: bottom;
    {%- else -%}
      --shape-position: center;
    {%- endif -%}

    {%- if enable_list == true -%}
      --text-alignment: start;
      --text-margin: 0;
    {%- else -%}
      --text-alignment: center;
      --text-margin: auto;
    {%- endif -%}
    {% if contain_image == true %}
      --image-fit: contain;
    {% else %}
      --image-fit: cover;
    {% endif %}
  }

  {%- if enable_dots == true -%}
    div[data-section-id="{{ _section.id }}"] .image::before{
      background-image: radial-gradient(var(--colour-{{- dot_colour_bottom -}}) 36%, var(--colour-{{- background_colour -}}) 30%);
    }

    div[data-section-id="{{ _section.id }}"] .image::after{
      background-image: radial-gradient(var(--colour-{{- dot_colour_top -}}) 36%, var(--colour-{{- background_colour -}}) 30%);
    }
  {%- endif -%}
</style>

<div class="snippet-text-and-image">
  <div class="container {{ content_position }}">
    <div class="image {% if enable_dots %}u-dots {% endif %}">
      {%- if main_image != blank -%}
        {{- main_image | image_url: width: 800 | image_tag: widths: '400, 600, 800', alt: image.alt, loading: 'lazy' -}}
      {%- endif -%}
      {%- if shape_background != blank -%}
        {{- shape_background | image_url: width: 800 | image_tag: widths: '400, 600, 800', alt: shape_background.alt, loading: 'lazy', class: shape_class -}}
      {%- endif -%}
    </div>
    <div class="content">
      {%- if header_title != blank and header_image != blank -%}
        {%-
          render 'section-header',
          _heading: header_title,
          _image: header_image,
          _offset: false
        -%}
      {%- endif -%}
      <h2 class="u-heading-{{- heading_size }}">{{- main_heading -}}</h2>
      {%- if _ctvp == true -%}
        <p class="u-text-xl">{{- main_quote -}}</p>
        {{- main_text -}}
        <ol class="presenter-details">
          <li>
            {%- render 'icon', _name: 'icon-brush-pen' -%}
            <dl>
              <dt><small>Craft speciality</small></dt>
              <dd class="u-text-xl">{{- craft_speciality -}}</dd>
            </dl>
          </li>
          <li>
            {%- render 'icon', _name: 'icon-draw-technique' -%}
            <dl>
              <dt><small>Craft technique</small></dt>
              <dd class="u-text-xl">{{- craft_technique -}}</dd>
            </dl>
          </li>
        </ol>
      {%- else -%}
        {{- main_text -}}
      {%- endif -%}
      {%- if enable_list == true -%}
        <ul class="c-check-list purple">
          {%- for list_item in list_items -%}
            <li>{{- list_item -}}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {%- if main_link_url != blank and main_link_text != blank -%}
        <a href="{{- main_link_url -}}" class="c-btn main {{ link_colour }}">{{- main_link_text -}}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
.snippet-text-and-image {
  --image-width: 48%;
}
@media (min-width: 1280px) {
  .snippet-text-and-image {
    --image-width: 56%;
  }
}
.snippet-text-and-image .container {
  display: grid;
  gap: 3rem;
  grid-template-areas: "image" "content";
}
@media (min-width: 768px) and (max-width: 1023.98px) {
  .snippet-text-and-image .container {
    max-width: var(--content-tablet-width);
  }
}
@media (min-width: 1024px) {
  .snippet-text-and-image .container {
    grid-template-columns: var(--grid-columns);
    grid-template-areas: var(--layout-direction);
    align-items: center;
    gap: 3rem;
  }
  .snippet-text-and-image .container.vertical-start {
    align-items: start;
  }
  .snippet-text-and-image .container.vertical-end {
    align-items: end;
  }
}
@media (min-width: 1280px) {
  .snippet-text-and-image .container {
    gap: 6rem;
    padding: 0 var(--content-offset);
  }
}
.snippet-text-and-image .container > .image {
  grid-area: image;
  position: relative;
}
.snippet-text-and-image .container > .image.u-dots::before {
  bottom: 0;
  left: 0;
  transform: translate(-16px, 16px);
}
@media (min-width: 1024px) {
  .snippet-text-and-image .container > .image.u-dots::before {
    transform: translate(-36px, 12px);
  }
}
.snippet-text-and-image .container > .image.u-dots::after {
  top: 0;
  right: 0;
  transform: translate(-16px, -22px);
}
@media (min-width: 1024px) {
  .snippet-text-and-image .container > .image.u-dots::after {
    top: 0;
    transform: translate(-100%, -24px);
  }
}
.snippet-text-and-image .container > .image img:not(.bg-shape) {
  height: auto;
  width: 100%;
  border-radius: var(--border-radius-lg);
  overflow: hidden;
  object-fit: var(--image-fit);
  aspect-ratio: 5/4;
  position: relative;
  z-index: 5;
}
.snippet-text-and-image .container > .image img.bg-shape {
  --shape-offset: 1rem;
  --shape-width: calc(var(--shape-offset) * 2);
  height: calc(100% + var(--shape-width));
  width: calc(100% + var(--shape-width));
  max-width: none;
  position: absolute;
  inset: calc(var(--shape-offset) * -1);
  object-fit: contain;
  object-position: var(--shape-position);
  z-index: 1;
}
@media (min-width: 768px) {
  .snippet-text-and-image .container > .image img.bg-shape {
    --shape-offset: 2rem;
  }
}
.snippet-text-and-image .content {
  grid-area: content;
}
@media (max-width: 1023.98px) {
  .snippet-text-and-image .content {
    text-align: var(--text-alignment);
  }
  .snippet-text-and-image .content h2, .snippet-text-and-image .content p {
    margin-left: var(--text-margin);
    margin-right: var(--text-margin);
  }
}
@media (min-width: 768px) and (max-width: 1023.98px) {
  .snippet-text-and-image .content .c-check-list {
    grid-template-columns: 1fr 1fr;
  }
}
.snippet-text-and-image .content > * {
  max-width: 32rem;
}
{% endstylesheet %}