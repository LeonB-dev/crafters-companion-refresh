{% doc %}
  Outputs JosefinSans font-face declaration.

  @example
  {% render 'fonts' %}
{% enddoc %}
<style>
  /* Body Font */
  @font-face {
    font-family: 'JosefinSans';
    src: url({{ 'JosefinSans-VariableFont_wght.ttf' | asset_url }}) format('truetype');
    font-style: normal;
    font-style: 400;
    font-display: swap;
  }
</style>