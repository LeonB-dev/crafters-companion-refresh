{% doc %}
  Renders collection item as styled card with background image.

  @param {string} _style - The card style variant (e.g. 'alt')
  @param {image} _image - The background image
  @param {string} _heading - The heading text
  @param {boolean} _show_label - Whether to show the heading label
  @param {string} [_lozenge_text] - Override text for the lozenge label
  @param {string} [_lozenge_color] - Background colour for the lozenge
  @param {string} [_heading_color] - Text colour for the heading
  @param {string} _url - The link URL
  @param {boolean} _show_overlay_button - Whether to show the overlay button
  @param {string} [_button_text] - Text for the overlay button
  @param {string} [_button_text_color] - Text colour for the overlay button
  @param {string} [_button_background_color] - Background colour for the overlay button
  @param {boolean} [_show_text_button] - Whether to show the text button below the card
  @param {string} [_text_button_text] - Text for the text button
  @param {boolean} [_text_button_underline] - Whether to underline the text button
  @param {string} [_text_button_font_family] - Font family for the text button
  @param {string} [_text_button_font_size] - Font size for the text button
  @param {string} [_text_button_font_weight] - Font weight for the text button
  @param {string} [_text_button_align] - Text alignment for the text button
  @param {string} [_text_button_color] - Text colour for the text button
  @param {string} [_loading] - Image loading strategy

  @example
  {% render 'collection-item', _style: 'alt', _image: block.settings.image, _heading: block.settings.heading, _url: block.settings.url, _show_label: true, _show_overlay_button: true, _button_text: 'Shop now' %}
{% enddoc %}
<div class="snippet-collection-item-wrapper">
  <div
    class="snippet-collection-item snippet-collection-item-style--{{ _style }}"
    style="
      background-image:url({{ _image | image_url: width: 600 }});
      background-position: center;
      background-size: cover;
      "
  >
    {%- if _heading != blank and _show_label != false -%}
      {%- assign lozenge_display_text = _lozenge_text | default: _heading -%}
      {%- assign lozenge_bg = _lozenge_color | default: '#603C8E' -%}
      <div class="snippet-collection-item__heading" style="color: {{ _heading_color }}; background: {{ lozenge_bg }};">
        {{- lozenge_display_text -}}
      </div>
    {%- endif -%}

    <!---<div class="image">
      {%- if _image != blank -%}
        <img
          src="{{ _image | image_url: width: 600 }}"
          alt="{{ _heading }}"
          height="332"
          width="295"
          loading="{{- _loading -}}"
        >
      {%- else -%}
        {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
      {%- endif -%}
    </div>-->

    {%- if _show_overlay_button != false -%}
      <a
        href="{{ _url }}"
        class="button stretched-link"
        title="{{- _heading -}}"
        style="color: {{ _button_text_color }}; background-color: {{ _button_background_color }};"
      >
        {{ _button_text }}
      </a>
    {%- endif -%}
  </div>

  {%- if _show_text_button != false and _text_button_text != blank -%}
    {%- liquid
      assign tb_decoration = 'underline'
      if _text_button_underline == false
        assign tb_decoration = 'none'
      endif
      assign tb_font = _text_button_font_family | default: 'inherit'
    -%}
    <a
      href="{{ _url }}"
      class="snippet-collection-item__text-button"
      title="{{- _heading -}}"
      style="font-size: {{ _text_button_font_size | default: 'var(--font-size-s)' }}; font-weight: {{ _text_button_font_weight | default: '400' }}; text-align: {{ _text_button_align | default: 'center' }}; color: {{ _text_button_color | default: 'var(--colour-text-base)' }}; text-decoration: {{ tb_decoration }}; font-family: {{ tb_font }};"
    >
      {{- _text_button_text -}}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
.snippet-collection-item {
  position: relative;
  border-radius: 20px;
  padding: 2rem 2.5rem .5rem 2.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
}
@media (min-width: 1024px) {
  .snippet-collection-item {
    width: 100%;
    align-self: stretch;
  }
}
.snippet-collection-item a.button {
  font-size: var(--font-size-l);
  display: block;
  margin: 1rem 0 0 0;
  width: 100%;
  max-width: 240px;
  border: none;
  padding: 17px;
  border-radius: 50px;
  text-decoration: none;
  text-align: center;
  font-size: 1.125rem;
}
.snippet-collection-item .snippet-collection-item__heading {
  margin: 0 0 1rem 0;
  text-align: center;
  overflow-x: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  width: 100%;
  font-size: var(--font-size-xxl);
  font-weight: 700;
  line-height: 1.2;
}
@media (max-width: 1023.98px) {
  .snippet-collection-item .snippet-collection-item__heading {
    font-size: 1.75rem;
  }
}
@media screen and (max-width: 1024px) {
  .snippet-collection-item {
    padding: 1.5rem;
  }
}

/* Alt style */
.snippet-collection-item-style--alt {
  overflow: hidden;
  height: 100%;
  display: flex;
  flex-direction: column;
  aspect-ratio: 1/1;
}
.snippet-collection-item-style--alt .image {
  height: 100%;
  width: 100%;
}
.snippet-collection-item-style--alt .image img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
}
.snippet-collection-item-style--alt .button[class] {
  position: relative;
  margin-top: auto;
}
.snippet-collection-item-style--alt .snippet-collection-item__heading {
  color: #ffffff;
  position: absolute;
  z-index: 1;
  left: 0;
  top: 1.0rem;
  margin: 0;
  font-size: 14px;
  font-weight: inherit;
  padding: 6px 10px;
  border-top-right-radius: 9999px;
  border-bottom-right-radius: 9999px;
  width: auto;
}

/* Wrapper — sits in the promotions-grid cell, fills height and stacks text button below */
.snippet-collection-item-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  height: 100%;
}

/* The wrapper must stretch to fill the grid cell so the card keeps its aspect ratio */
.snippet-collection-item-wrapper .snippet-collection-item {
  flex: 1 1 auto;
  width: 100%;
}

/* Text button below image */
.snippet-collection-item__text-button {
  display: block;
  flex-shrink: 0;
  margin-top: 0.6rem;
  padding: 0;
  background: none;
  border: none;
  font-family: var(--font-family-base);
  font-size: var(--font-size-s);
  color: var(--colour-text-base);
  text-underline-offset: 3px;
  text-align: center;
  cursor: pointer;
  transition: opacity var(--transition-duration) var(--transition-timing);
}
.snippet-collection-item__text-button:hover {
  opacity: 0.65;
  color: var(--colour-text-base);
}
{% endstylesheet %}
