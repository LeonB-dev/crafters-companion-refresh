{% doc %}
  Displays brand navigation bar with logo, links, and background.

  @param {metaobject} _parent_brand_metaobject - The parent brand metaobject containing logo, colours, and links

  @example
  {% render 'brand-nav', _parent_brand_metaobject: product.metafields.custom.parent_brand.value %}
{% enddoc %}
{% liquid
  assign show_parent_brand_nav = false

  assign parent_brand_logo = _parent_brand_metaobject.logo
  assign collection = collections[_parent_brand_metaobject.collection]
  assign page = pages[_parent_brand_metaobject.page]
  assign overlay_colour = _parent_brand_metaobject.colour_overlay
  assign text_colour = _parent_brand_metaobject.text_colour
  assign parent_brand = _parent_brand_metaobject.parent_brand

  assign background_image = _parent_brand_metaobject.background_image

  if template contains 'product'
    assign background_image = background_image | image_url: width: 1200
    assign background_image_1x = background_image | image_url: width: 800
    assign background_image_2x = background_image | image_url: width: 1920
  endif
%}

<style>
  .snippet-brand-nav{
  	color: {{ text_colour }};
  	border-bottom-color: {{ text_colour }};

  	{% if template contains 'product' %}
  		margin-bottom: 1.5rem;
  	{% endif %}
  }
  {% if template contains 'product' %}
  	.snippet-brand-nav::before {
  		content:'';
  		position:absolute;
  		inset: 0;
  		height: 100%;
  		width: 100%;
  		z-index: 1;
  		background-image: url({{- background_image -}});
  		background-image: -webkit-image-set(
  			url({{- background_image_1x -}}) 1x,
  			url({{- background_image_2x -}}) 2x);
  		background-image: image-set(
  			url({{- background_image_1x -}}) 1x,
  			url({{- background_image_2x -}}) 2x);
  		background-size:cover;
  		background-repeat: no-repeat;
  	}
  	.snippet-brand-nav::after {
  		content:'';
  		position:absolute;
  		inset: 0;
  		height: 100%;
  		width: 100%;
  		z-index: 5;
  		background-color: {{ overlay_colour }};
  		opacity:0.88;
  	}
  	.snippet-brand-nav .container{
  		position: relative;
  		z-index:10;
  	}
  {% else %}
  	.snippet-brand-nav {
  		background-color: {{ overlay_colour }};
  	}
  {% endif %}
</style>
<div class="snippet-brand-nav">
  <div class="container">
    <a href="{{ page.url }}" aria-label="" class="logo">
      {{ parent_brand_logo | image_url: height: 32 | image_tag: alt: parent_brand_logo.alt, loading: 'eager' }}
    </a>
    <ul>
      <li>
        <a href="{{ collection.url }}">Shop all</a>
      </li>
      <li>
        <a href="{{ page.url }}">About</a>
      </li>
    </ul>
  </div>
</div>

{% stylesheet %}
.snippet-brand-nav {
  position: relative;
  padding: 1.5rem 0;
  border-bottom-width: 1px;
  border-bottom-style: solid;
  overflow: hidden;
}
.snippet-brand-nav .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 2rem;
}
.snippet-brand-nav .logo {
  display: block;
}
.snippet-brand-nav .logo img {
  height: 2rem;
  width: auto;
  max-width: 12rem;
  object-fit: contain;
}
.snippet-brand-nav a {
  color: inherit;
  text-decoration: none;
}
.snippet-brand-nav ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 1rem;
}
@media (min-width: 768px) {
  .snippet-brand-nav ul {
    gap: 2rem;
  }
}
.snippet-brand-nav ul li:hover a, .snippet-brand-nav ul li:focus a {
  text-decoration: underline;
}
{% endstylesheet %}
