{"sections":{"featured_image_iteDh6":{"type":"featured-image","custom_css":["{background-color: #196f6e;}"],"name":"Featured Image","settings":{"url":"","image":"shopify:\/\/shop_images\/Top_Banner_Desktop_f8752b9a-7c67-4cd3-b81d-6498724ac90b.jpg","image_mobile":"shopify:\/\/shop_images\/Top_Banner_Mobile_4a1ef72b-b9e0-464b-b06d-cd9b838b06ca.jpg","disable_aspect_ratio":true,"enable_full_width":false,"margin_bottom":"none"}},"wishit_custom_html_M94pEQ":{"type":"wishit-custom-html","custom_css":["{background-color: #196f6e;}"," {padding-top: 20px;}"," {padding-bottom: 0px;}"],"name":"WishIt HTML\/CSS\/JS","settings":{"html":"<style>\n  .video-bar-container {\n    position: relative;\n    width: 100%;\n    max-width: 1300px;\n    aspect-ratio: 16 \/ 9; \/* maintains 16:9 ratio *\/\n    margin: auto;\n    background: black;\n    border-radius: 8px;\n    overflow: hidden;\n  }\n\n  video#custom-video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  .video-controls {\n    position: absolute;\n    bottom: 15px;\n    left: 15px;\n    display: flex;\n    gap: 20px;\n    background: rgba(0, 0, 0, 0.4);\n    padding: 8px 12px;\n    border-radius: 30px;\n    user-select: none;\n  }\n\n  .video-controls button {\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    padding: 0;\n    width: 36px;\n    height: 36px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .video-controls button svg {\n    fill: white;\n    width: 24px;\n    height: 24px;\n  }\n\n  \/* Smaller buttons on very small screens *\/\n  @media (max-width: 400px) {\n    .video-controls {\n      gap: 12px;\n      padding: 6px 10px;\n    }\n    .video-controls button {\n      width: 28px;\n      height: 28px;\n    }\n    .video-controls button svg {\n      width: 18px;\n      height: 18px;\n    }\n  }\n<\/style>\n\n<div class=\"video-bar-container\">\n  <video id=\"custom-video\" autoplay=\"\" muted=\"\" playsinline=\"\" loop=\"\">\n    <source src=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/162ecd1c8bb3487fb2f8e63efdd07ec6.mp4\">\n    Your browser does not support the video tag.\n  <\/source><\/video>\n\n  <div class=\"video-controls\">\n    <button id=\"playPauseBtn\" aria-label=\"Pause Video\" title=\"Play\/Pause\">\n      <svg id=\"icon-play-pause\" viewbox=\"0 0 24 24\">\n        <rect id=\"pause-left\" x=\"6\" y=\"5\" width=\"4\" height=\"14\"><\/rect>\n        <rect id=\"pause-right\" x=\"14\" y=\"5\" width=\"4\" height=\"14\"><\/rect>\n      <\/svg>\n    <\/button>\n    <button id=\"muteBtn\" aria-label=\"Unmute Video\" title=\"Mute\/Unmute\">\n      <svg id=\"icon-mute-unmute\" viewbox=\"0 0 24 24\">\n        <path id=\"speaker\" d=\"M3 9v6h4l5 5V4L7 9H3z\"><\/path>\n        <line id=\"mute-line\" x1=\"16\" y1=\"8\" x2=\"22\" y2=\"16\" stroke=\"white\" stroke-width=\"2\"><\/line>\n        <line id=\"mute-line2\" x1=\"22\" y1=\"8\" x2=\"16\" y2=\"16\" stroke=\"white\" stroke-width=\"2\"><\/line>\n      <\/svg>\n    <\/button>\n  <\/div>\n<\/div>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const video = document.getElementById(\"custom-video\");\n    const playPauseBtn = document.getElementById(\"playPauseBtn\");\n    const muteBtn = document.getElementById(\"muteBtn\");\n    const iconPlayPause = document.getElementById(\"icon-play-pause\");\n    const iconMuteUnmute = document.getElementById(\"icon-mute-unmute\");\n\n    function showPauseIcon() {\n      iconPlayPause.innerHTML = `\n        <rect id=\"pause-left\" x=\"6\" y=\"5\" width=\"4\" height=\"14\"><\/rect>\n        <rect id=\"pause-right\" x=\"14\" y=\"5\" width=\"4\" height=\"14\"><\/rect>`;\n      playPauseBtn.setAttribute(\"aria-label\", \"Pause Video\");\n      playPauseBtn.title = \"Pause\";\n    }\n    function showPlayIcon() {\n      iconPlayPause.innerHTML = `\n        <polygon points=\"6,4 20,12 6,20\"><\/polygon>`;\n      playPauseBtn.setAttribute(\"aria-label\", \"Play Video\");\n      playPauseBtn.title = \"Play\";\n    }\n\n    function showMuteIcon() {\n      iconMuteUnmute.innerHTML = `\n        <path id=\"speaker\" d=\"M3 9v6h4l5 5V4L7 9H3z\"><\/path>\n        <line id=\"mute-line\" x1=\"16\" y1=\"8\" x2=\"22\" y2=\"16\" stroke=\"white\" stroke-width=\"2\"><\/line>\n        <line id=\"mute-line2\" x1=\"22\" y1=\"8\" x2=\"16\" y2=\"16\" stroke=\"white\" stroke-width=\"2\"><\/line>`;\n      muteBtn.setAttribute(\"aria-label\", \"Unmute Video\");\n      muteBtn.title = \"Unmute\";\n    }\n    function showUnmuteIcon() {\n      iconMuteUnmute.innerHTML = `\n        <path id=\"speaker\" d=\"M3 9v6h4l5 5V4L7 9H3z\"><\/path>\n        <path id=\"sound-waves\" d=\"M16 9c1.333 1.333 1.333 4 0 5.333\" stroke=\"white\" stroke-width=\"2\" fill=\"none\"><\/path>\n        <path id=\"sound-waves2\" d=\"M18 7c2 2 2 6 0 8\" stroke=\"white\" stroke-width=\"2\" fill=\"none\"><\/path>`;\n      muteBtn.setAttribute(\"aria-label\", \"Mute Video\");\n      muteBtn.title = \"Mute\";\n    }\n\n    \/\/ Initialize icons\n    if (video.paused) {\n      showPlayIcon();\n    } else {\n      showPauseIcon();\n    }\n    if (video.muted) {\n      showMuteIcon();\n    } else {\n      showUnmuteIcon();\n    }\n\n    playPauseBtn.addEventListener(\"click\", function () {\n      if (video.paused) {\n        video.play();\n        showPauseIcon();\n      } else {\n        video.pause();\n        showPlayIcon();\n      }\n    });\n\n    muteBtn.addEventListener(\"click\", function () {\n      video.muted = !video.muted;\n      if (video.muted) {\n        showMuteIcon();\n      } else {\n        showUnmuteIcon();\n      }\n    });\n  });\n<\/script>"}},"featured_image_yYtPgw":{"type":"featured-image","custom_css":["{background-color: #196f6e;}"," {padding-top: 20px;}"," {padding-bottom: 0px;}"],"name":"Featured Image","settings":{"url":"shopify:\/\/pages\/new","image":"shopify:\/\/shop_images\/Shop_All_Desktop_9dd192fc-8acb-4d65-b4b9-282c4f65a471.jpg","