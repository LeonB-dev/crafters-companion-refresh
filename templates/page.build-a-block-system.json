    "82de33e6-e5e6-49fc-a351-b217e342a43d": {
      "type": "quote-slider",
      "blocks": {
        "d6c69151-113a-4b8e-b964-2d18ae230e83": {
          "type": "quote_slide",
          "settings": {
            "quote": "<p>Fabulous system, very quick and easy to use. My first block was a Hunter Star which I would never had attempted to cut with a rotary cutter.<\/p>",
            "author_text": "Lynette McLoughlin"
          }
        },
        "62e11e0a-27c6-4aa6-9480-2d401d11f478": {
          "type": "quote_slide",
          "settings": {
            "quote": "<p>I am very new to sewing\/ quilting, so there are no fancy blocks here. I did use the largest Build-A-Block square to cut the pieces for a very simple table runner. The accuracy of the die cutting made a huge difference to accuracy of my sewing... my seams actually matched up for once!<\/p>",
            "author_text": "Deborah Gill"
          }
        },
        "09494bd2-8221-4557-a00f-801fb16e6653": {
          "type": "quote_slide",
          "settings": {
            "quote": "<p>I adore the Build-A-Block system. It is so easy to use and cuts accurately every time. Not had much time to play yet, but the possibilities seem endless. The extra blocks online were a real bonus too.<\/p>",
            "author_text": "Bernadette Corner"
          }
        },
        "7bc08e9c-cc87-43ef-a770-ffd5fb43d15b": {
          "type": "quote_slide",
          "settings": {
            "quote": "<p>My first one is a Hunters Star. I'm so excited with all the possibilities and you won't be disappointed!<\/p>",
            "author_text": "Julie Burns"
          }
        }
      },
