        "81e76bef-ed61-4cb1-a936-92e54031dfb5": {
          "type": "info_block",
          "settings": {
            "small_heading": "",
            "heading": "Launch Day",
            "text": "<p>Take one giant leap, watch the show and explore our newest products! This show airs on the morning of a brand new launch day, so you’ll be able to see everything in action, grab brilliant bundles and learn more about the products.</p><p><strong>Check our </strong><a href=\"https://crafters-uk.myshopify.com/pages/crafters-tv-schedule\" title=\"https://crafters-uk.myshopify.com/pages/crafters-tv-schedule\"><strong>weekly schedule</strong></a><strong> for show times</strong></p>",
            "link_text": "",
            "link_url": "",
            "image": "shopify://shop_images/CTV_ShowsLaunch_day_b45cca97-73b3-4ad3-9e60-745f5d9fdce7.jpg"
          }
        },
