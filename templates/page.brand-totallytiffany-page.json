        "a051e613-e924-4938-9d54-328216b7a319": {
          "type": "content_block",
          "settings": {
            "heading": "ScrapRack",
            "text": "With an easy-to-use system, customisable pages and pockets, and the option to expand ScrapRack is the solution if you need a system that makes room for itself.",
