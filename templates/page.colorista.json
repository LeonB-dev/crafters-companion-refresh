      "type": "text-only",
      "custom_css": [

      ],
      "settings": {
        "large_text": "Totalling more than 200 staff around the UK and overseas!",
        "small_text": "<p>Now totalling more than 200 staff around the UK and overseas, we’re a friendly lot who like to put the customer at the heart of everything we do.<\/p><p>Whatever hobby or interest, take a look around our site to find ideas and inspiration to get you started, or maybe even a little treat or two for your craft room!<\/p><p><strong>Take a peak inside our world!<\/strong><\/p>",
        "link_text": "",
        "link_url": "",
        "left_align": true
      }
    },
