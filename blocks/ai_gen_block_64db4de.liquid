{% doc %}
  @prompt
    1 Image row with header. Each image links somewhere and has a title and subtitles. works on desktop and mobile, desktop width adjustable, different font sizes for mobile
    
    , font weight adjustable, Button width adjustable, Button centred under image, background colour, , image size adjustable, height and width adjustable on image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-row-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: 40px 20px;
  }

  .ai-image-row-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-image-row-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-image-row-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.header_font_size }}px;
    font-weight: {{ block.settings.header_font_weight }};
    color: {{ block.settings.header_color }};
    margin: 0;
  }

  .ai-image-row-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-image-row-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-image-row-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_width }}%;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-row-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    display: block;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-image-row-image-wrapper-{{ ai_gen_id }}:hover .ai-image-row-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-image-row-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-row-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-image-row-content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-image-row-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 10px 0;
  }

  .ai-image-row-item-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    font-weight: {{ block.settings.subtitle_font_weight }};
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 20px 0;
  }

  .ai-image-row-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: background-color 0.3s ease;
    width: {{ block.settings.button_width }}%;
    text-align: center;
  }

  .ai-image-row-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-row-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.mobile_columns }}, 1fr);
    }

    .ai-image-row-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size_mobile }}px;
    }

    .ai-image-row-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-image-row-item-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size_mobile }}px;
    }

    .ai-image-row-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }

    .ai-image-row-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_width_mobile }}%;
    }

    .ai-image-row-image-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}px;
    }

    .ai-image-row-image-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-row-container-{{ ai_gen_id }}">
    {% if block.settings.header_text != blank %}
      <div class="ai-image-row-header-{{ ai_gen_id }}">
        <h2 class="ai-image-row-title-{{ ai_gen_id }}">{{ block.settings.header_text }}</h2>
      </div>
    {% endif %}

    <div class="ai-image-row-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign link_key = 'link_' | append: i
          assign title_key = 'title_' | append: i
          assign subtitle_key = 'subtitle_' | append: i
          assign button_text_key = 'button_text_' | append: i
          assign enabled_key = 'enable_item_' | append: i

          assign image = block.settings[image_key]
          assign link = block.settings[link_key]
          assign title = block.settings[title_key]
          assign subtitle = block.settings[subtitle_key]
          assign button_text = block.settings[button_text_key]
          assign enabled = block.settings[enabled_key]
        %}

        {% if enabled %}
          <div class="ai-image-row-item-{{ ai_gen_id }}">
            <div class="ai-image-row-image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-image-row-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-image-row-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-image-row-content-{{ ai_gen_id }}">
              {% if title != blank %}
                <h3 class="ai-image-row-item-title-{{ ai_gen_id }}">{{ title }}</h3>
              {% endif %}

              {% if subtitle != blank %}
                <p class="ai-image-row-item-subtitle-{{ ai_gen_id }}">{{ subtitle }}</p>
              {% endif %}

              {% if link != blank and button_text != blank %}
                <a href="{{ link }}" class="ai-image-row-button-{{ ai_gen_id }}">
                  {{ button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

