{% doc %}
  @prompt
    3 image row both have seperate titles above and below, margin 1500px, top and bottle titles different sizes
    
    , weight adjustable, images link to other pages
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-row-{{ ai_gen_id }} {
    max-width: 1500px;
    margin: 0 auto;
    padding: 20px;
  }

  .ai-image-row__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .ai-image-row__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-row__top-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.top_title_size }}px;
    font-weight: {{ block.settings.top_title_weight }};
    color: {{ block.settings.top_title_color }};
    margin-bottom: 15px;
  }

  .ai-image-row__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 15px;
  }

  .ai-image-row__image-wrapper-{{ ai_gen_id }} a {
    display: block;
  }

  .ai-image-row__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-image-row__image-wrapper-{{ ai_gen_id }} a:hover .ai-image-row__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-image-row__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-row__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-image-row__bottom-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.bottom_title_size }}px;
    font-weight: {{ block.settings.bottom_title_weight }};
    color: {{ block.settings.bottom_title_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-image-row__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-image-row__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
{% endstyle %}

<div class="ai-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-row__grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign top_title_key = 'top_title_' | append: i
        assign bottom_title_key = 'bottom_title_' | append: i
        assign link_key = 'link_' | append: i

        assign image = block.settings[image_key]
        assign top_title = block.settings[top_title_key]
        assign bottom_title = block.settings[bottom_title_key]
        assign link = block.settings[link_key]
      %}

      <div class="ai-image-row__item-{{ ai_gen_id }}">
        {% if top_title != blank %}
          <h3 class="ai-image-row__top-title-{{ ai_gen_id }}">{{ top_title }}</h3>
        {% endif %}

        <div class="ai-image-row__image-wrapper-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-image-row__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-image-row__placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </a>
          {% else %}
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-image-row__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-image-row__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          {% endif %}
        </div>

        {% if bottom_title != blank %}
          <h4 class="ai-image-row__bottom-title-{{ ai_gen_id }}">{{ bottom_title }}</h4>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "3 image row",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Top titles"
    },
    {
      "type": "range",
      "id": "top_title_size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 24
    },
    {
      "type": "range",
      "id": "top_title_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Font weight",
      "default": 700
    },
    {
      "type": "color",
      "id": "top_title_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Bottom titles"
    },
    {
      "type": "range",
      "id": "bottom_title_size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 18
    },
    {
      "type": "range",
      "id": "bottom_title_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Font weight",
      "default": 400
    },
    {
      "type": "color",
      "id": "bottom_title_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "top_title_1",
      "label": "Top title",
      "default": "Top Title 1"
    },
    {
      "type": "text",
      "id": "bottom_title_1",
      "label": "Bottom title",
      "default": "Bottom Title 1"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "top_title_2",
      "label": "Top title",
      "default": "Top Title 2"
    },
    {
      "type": "text",
      "id": "bottom_title_2",
      "label": "Bottom title",
      "default": "Bottom Title 2"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "top_title_3",
      "label": "Top title",
      "default": "Top Title 3"
    },
    {
      "type": "text",
      "id": "bottom_title_3",
      "label": "Bottom title",
      "default": "Bottom Title 3"
    },
    {
      "type": "url",
      "id": "link_3",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "3 image row"
    }
  ]
}
{% endschema %}