{% doc %}
  @prompt
    10 images in a row, the images link to other pages and have a title, can the section have a changeable background image only with a title and text all in monserrat font, scrollable on mobile, all on page on desktop, image row width adjustable, font weight adjustable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{% style %}
  .ai-image-row-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    overflow: hidden;
  }

  .ai-image-row-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-image-row-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-row-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-row-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.1;
  }

  .ai-image-row-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-image-row-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-image-row-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
    font-family: 'Montserrat', sans-serif;
  }

  .ai-image-row-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-family: 'Montserrat', sans-serif;
  }

  .ai-image-row-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
    font-family: 'Montserrat', sans-serif;
  }

  .ai-image-row-container-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
  }

  .ai-image-row-container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-image-row-container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-image-row-container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 4px;
  }

  .ai-image-row-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    padding-bottom: 16px;
  }

  .ai-image-row-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.image_width }}px;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
  }

  .ai-image-row-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-image-row-link-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-image-row-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    margin-bottom: 12px;
    background-color: #f4f4f4;
  }

  .ai-image-row-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-row-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-image-row-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-row-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size }}px;
    font-weight: {{ block.settings.item_title_weight }};
    color: {{ block.settings.item_title_color }};
    margin: 0;
    font-family: 'Montserrat', sans-serif;
    word-wrap: break-word;
  }

  @media screen and (min-width: 750px) {
    .ai-image-row-container-{{ ai_gen_id }} {
      overflow-x: visible;
      max-width: {{ block.settings.desktop_max_width }}px;
      margin: 0 auto;
    }

    .ai-image-row-wrapper-{{ ai_gen_id }} {
      justify-content: center;
      flex-wrap: nowrap;
    }

    .ai-image-row-item-{{ ai_gen_id }} {
      flex: 1 1 0;
      min-width: 0;
      max-width: calc((100% - ({{ block.settings.image_gap }}px * 9)) / 10);
    }

    .ai-image-row-image-wrapper-{{ ai_gen_id }} {
      height: auto;
      aspect-ratio: 1 / 1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-image-row-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-image-row-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-image-row-item-{{ ai_gen_id }} {
      width: {{ block.settings.image_width | times: 0.8 }}px;
    }

    .ai-image-row-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-image-row-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-row-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-image-row-background-placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-image-row-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-image-row-content-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_text != blank %}
      <div class="ai-image-row-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-image-row-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_text != blank %}
          <div class="ai-image-row-text-{{ ai_gen_id }}">{{ block.settings.section_text }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-image-row-container-{{ ai_gen_id }}">
      <div class="ai-image-row-wrapper-{{ ai_gen_id }}">
        {% for i in (1..10) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign title_key = 'title_' | append: i
            assign link_key = 'link_' | append: i
            
            assign image = block.settings[image_key]
            assign title = block.settings[title_key]
            assign link = block.settings[link_key]
          %}

          <div class="ai-image-row-item-{{ ai_gen_id }}">
            {% if link != blank %}
              <a href="{{ link }}" class="ai-image-row-link-{{ ai_gen_id }}">
            {% else %}
              <div class="ai-image-row-link-{{ ai_gen_id }}">
            {% endif %}
              <div class="ai-image-row-image-wrapper-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 400 }}"
                    alt="{{ image.alt | default: title | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="ai-image-row-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              {% if title != blank %}
                <h3 class="ai-image-row-item-title-{{ ai_gen_id }}">{{ title }}</h3>
              {% endif %}
            {% if link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

