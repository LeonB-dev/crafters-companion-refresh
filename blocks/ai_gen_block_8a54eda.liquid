{% doc %}
  @prompt
    3 image row with buttons overlayed, button location adjustable
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-three-image-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-three-image-row__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-three-image-row__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
  }

  .ai-three-image-row__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-three-image-row__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-three-image-row__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-three-image-row__button-{{ ai_gen_id }} {
    position: absolute;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    display: inline-block;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-three-image-row__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-three-image-row__button-1-{{ ai_gen_id }} {
    top: {{ block.settings.button_1_position_y }}%;
    left: {{ block.settings.button_1_position_x }}%;
    transform: translate(-50%, -50%);
  }

  .ai-three-image-row__button-2-{{ ai_gen_id }} {
    top: {{ block.settings.button_2_position_y }}%;
    left: {{ block.settings.button_2_position_x }}%;
    transform: translate(-50%, -50%);
  }

  .ai-three-image-row__button-3-{{ ai_gen_id }} {
    top: {{ block.settings.button_3_position_y }}%;
    left: {{ block.settings.button_3_position_x }}%;
    transform: translate(-50%, -50%);
  }

  @media screen and (max-width: 989px) {
    .ai-three-image-row-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-three-image-row__item-{{ ai_gen_id }}:last-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-three-image-row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }

    .ai-three-image-row__item-{{ ai_gen_id }}:last-child {
      grid-column: auto;
    }

    .ai-three-image-row__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-three-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-three-image-row__item-{{ ai_gen_id }}">
    <div class="ai-three-image-row__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_1 %}
        <img
          src="{{ block.settings.image_1 | image_url: width: 800 }}"
          alt="{{ block.settings.image_1.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_1.width }}"
          height="{{ block.settings.image_1.height }}"
          class="ai-three-image-row__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-three-image-row__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    {% if block.settings.button_1_text != blank %}
      <a
        href="{{ block.settings.button_1_link }}"
        class="ai-three-image-row__button-{{ ai_gen_id }} ai-three-image-row__button-1-{{ ai_gen_id }}"
      >
        {{ block.settings.button_1_text }}
      </a>
    {% endif %}
  </div>

  <div class="ai-three-image-row__item-{{ ai_gen_id }}">
    <div class="ai-three-image-row__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_2 %}
        <img
          src="{{ block.settings.image_2 | image_url: width: 800 }}"
          alt="{{ block.settings.image_2.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_2.width }}"
          height="{{ block.settings.image_2.height }}"
          class="ai-three-image-row__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-three-image-row__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    {% if block.settings.button_2_text != blank %}
      <a
        href="{{ block.settings.button_2_link }}"
        class="ai-three-image-row__button-{{ ai_gen_id }} ai-three-image-row__button-2-{{ ai_gen_id }}"
      >
        {{ block.settings.button_2_text }}
      </a>
    {% endif %}
  </div>

  <div class="ai-three-image-row__item-{{ ai_gen_id }}">
    <div class="ai-three-image-row__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_3 %}
        <img
          src="{{ block.settings.image_3 | image_url: width: 800 }}"
          alt="{{ block.settings.image_3.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_3.width }}"
          height="{{ block.settings.image_3.height }}"
          class="ai-three-image-row__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-three-image-row__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    {% if block.settings.button_3_text != blank %}
      <a
        href="{{ block.settings.button_3_link }}"
        class="ai-three-image-row__button-{{ ai_gen_id }} ai-three-image-row__button-3-{{ ai_gen_id }}"
      >
        {{ block.settings.button_3_text }}
      </a>
    {% endif %}
  </div>
</div>

