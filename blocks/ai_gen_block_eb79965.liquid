{% doc %}
  @prompt
    full width banner with moveable title subtitle and button , different for mobile and desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: {{ block.settings.overlay_color }};
  }

  .ai-banner-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .ai-banner-image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 2;
  }

  .ai-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-banner-content-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.content_vertical_position }}%;
    left: {{ block.settings.content_horizontal_position }}%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: 1200px;
    padding: 0 20px;
    z-index: 3;
  }

  .ai-banner-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-banner-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-banner-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0 0 24px;
    line-height: 1.4;
  }

  .ai-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_min_height }}px;
    }

    .ai-banner-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-banner-image-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-banner-content-wrapper-{{ ai_gen_id }} {
      top: {{ block.settings.mobile_content_vertical_position }}%;
      left: {{ block.settings.mobile_content_horizontal_position }}%;
    }

    .ai-banner-content-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_text_alignment }};
    }

    .ai-banner-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_title_size }}px;
    }

    .ai-banner-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_subtitle_size }}px;
    }

    .ai-banner-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_button_font_size }}px;
    }
  }
{% endstyle %}

<div class="ai-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.image_desktop %}
    <img
      src="{{ block.settings.image_desktop | image_url: width: 2000 }}"
      alt="{{ block.settings.image_desktop.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.image_desktop.width }}"
      height="{{ block.settings.image_desktop.height }}"
      class="ai-banner-image-{{ ai_gen_id }} ai-banner-image-desktop-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="ai-banner-image-placeholder-{{ ai_gen_id }} ai-banner-image-desktop-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
      <div class="ai-banner-empty-state-{{ ai_gen_id }}">
        Next, add a desktop background image
      </div>
    </div>
  {% endif %}

  {% if block.settings.image_mobile %}
    <img
      src="{{ block.settings.image_mobile | image_url: width: 1000 }}"
      alt="{{ block.settings.image_mobile.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.image_mobile.width }}"
      height="{{ block.settings.image_mobile.height }}"
      class="ai-banner-image-{{ ai_gen_id }} ai-banner-image-mobile-{{ ai_gen_id }}"
    >
  {% elsif block.settings.image_desktop %}
    <img
      src="{{ block.settings.image_desktop | image_url: width: 1000 }}"
      alt="{{ block.settings.image_desktop.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.image_desktop.width }}"
      height="{{ block.settings.image_desktop.height }}"
      class="ai-banner-image-{{ ai_gen_id }} ai-banner-image-mobile-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="ai-banner-image-placeholder-{{ ai_gen_id }} ai-banner-image-mobile-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
      <div class="ai-banner-empty-state-{{ ai_gen_id }}">
        Next, add a mobile background image
      </div>
    </div>
  {% endif %}

  <div class="ai-banner-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-banner-content-wrapper-{{ ai_gen_id }}">
    <div class="ai-banner-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-banner-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <div class="ai-banner-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-banner-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Full width banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop background image"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile background image",
      "info": "If not set, desktop image will be used"
    },
    {
      "type": "range",
      "id": "mobile_min_height",
      "label": "Mobile minimum height",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Desktop content position"
    },
    {
      "type": "range",
      "id": "content_horizontal_position",
      "label": "Horizontal position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "content_vertical_position",
      "label": "Vertical position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Mobile content position"
    },
    {
      "type": "range",
      "id": "mobile_content_horizontal_position",
      "label": "Horizontal position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "mobile_content_vertical_position",
      "label": "Vertical position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Welcome to our store"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Desktop title size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_title_size",
      "label": "Mobile title size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Discover our latest collection"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Desktop subtitle size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_subtitle_size",
      "label": "Mobile subtitle size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#733089"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#5a2569"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Desktop button font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_button_font_size",
      "label": "Mobile button font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "Button padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Full width banner"
    }
  ]
}
{% endschema %}
