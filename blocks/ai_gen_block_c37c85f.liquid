{% doc %}
  @prompt
    image block, title under video in monseratt font, links to another page, wifth 1800px, width adjustable, image radius
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-block-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 100%;
  }

  .ai-image-block__link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    max-width: {{ block.settings.image_width }}px;
    width: 100%;
  }

  .ai-image-block__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-image-block__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-image-block__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_radius }}px;
    position: relative;
  }

  .ai-image-block__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-block__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-block__title-{{ ai_gen_id }} {
    margin-top: 16px;
    font-family: 'Montserrat', sans-serif;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-align: center;
    max-width: {{ block.settings.image_width }}px;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-image-block__link-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-image-block__title-{{ ai_gen_id }} {
      max-width: 100%;
      font-size: calc({{ block.settings.title_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-image-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.link_url != blank %}
    <a href="{{ block.settings.link_url }}" class="ai-image-block__link-{{ ai_gen_id }}">
      <div class="ai-image-block__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1800 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-image-block__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-block__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-block__empty-state-{{ ai_gen_id }}">
              Next, add an image
            </div>
          </div>
        {% endif %}
      </div>
      {% if block.settings.title != blank %}
        <h3 class="ai-image-block__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
      {% endif %}
    </a>
  {% else %}
    <div class="ai-image-block__link-{{ ai_gen_id }}">
      <div class="ai-image-block__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1800 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-image-block__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-block__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-block__empty-state-{{ ai_gen_id }}">
              Next, add an image
            </div>
          </div>
        {% endif %}
      </div>
      {% if block.settings.title != blank %}
        <h3 class="ai-image-block__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Image block",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Width",
      "min": 200,
      "max": 1800,
      "step": 100,
      "unit": "px",
      "default": 1800
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Image title"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1F1300"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Image block"
    }
  ]
}
{% endschema %}