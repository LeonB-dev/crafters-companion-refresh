{% doc %}
  @prompt
    3 Image row with header. Each image links somewhere and has a title and subtitles. works on desktop and mobile, esktop width adjustable, different font sizes for mobile
    
    , font weight adjustable, Button width adjustable, Button centred under image, background colour, IMAGES FULL WIDTH
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-row-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: 40px 20px;
  }

  .ai-image-row__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.desktop_width }}px;
    margin: 0 auto;
  }

  .ai-image-row__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-image-row__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-image-row__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-image-row__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-image-row__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 20px;
    position: relative;
  }

  .ai-image-row__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-row__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-row__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-image-row__content-{{ ai_gen_id }} {
    text-align: center;
    width: 100%;
  }

  .ai-image-row__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    margin: 0 0 10px;
    color: {{ block.settings.title_color }};
  }

  .ai-image-row__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    font-weight: {{ block.settings.subtitle_weight }};
    margin: 0 0 20px;
    color: {{ block.settings.subtitle_color }};
  }

  .ai-image-row__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    width: {{ block.settings.button_width }}%;
    max-width: 100%;
    text-align: center;
    transition: background-color 0.3s ease;
  }

  .ai-image-row__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-row__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-image-row__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-image-row__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-image-row__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size_mobile }}px;
    }

    .ai-image-row__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-row__container-{{ ai_gen_id }}">
    {% if block.settings.main_heading != blank %}
      <div class="ai-image-row__header-{{ ai_gen_id }}">
        <h2 class="ai-image-row__heading-{{ ai_gen_id }}">{{ block.settings.main_heading }}</h2>
      </div>
    {% endif %}

    <div class="ai-image-row__grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign title_key = 'title_' | append: i
          assign subtitle_key = 'subtitle_' | append: i
          assign link_key = 'link_' | append: i
          assign button_text_key = 'button_text_' | append: i

          assign image = block.settings[image_key]
          assign title = block.settings[title_key]
          assign subtitle = block.settings[subtitle_key]
          assign link = block.settings[link_key]
          assign button_text = block.settings[button_text_key]
        %}

        <div class="ai-image-row__item-{{ ai_gen_id }}">
          <div class="ai-image-row__image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-image-row__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-image-row__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-image-row__content-{{ ai_gen_id }}">
            {% if title != blank %}
              <h3 class="ai-image-row__title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}

            {% if subtitle != blank %}
              <p class="ai-image-row__subtitle-{{ ai_gen_id }}">{{ subtitle }}</p>
            {% endif %}

            {% if link != blank and button_text != blank %}
              <a href="{{ link }}" class="ai-image-row__button-{{ ai_gen_id }}">
                {{ button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

