{% doc %}
  @prompt
    5 Image row with header in monsteratt font. Each image links somewhere and has a title. works on desktop and mobile, can the images be 390 x 460, on mobile can i be in a scrollable line?, can the size on desktop be  1800px width, desktop width adjustable, different font sizes for mobile, shop now button under each image, mobile padding on left so first image is centred
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-row-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-image-row__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.desktop_width }}px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .ai-image-row__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-image-row__title-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-size: {{ block.settings.header_font_size }}px;
    font-weight: {{ block.settings.header_font_weight }};
    color: {{ block.settings.header_color }};
    margin: 0;
    text-transform: {{ block.settings.header_text_transform }};
  }

  .ai-image-row__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: {{ block.settings.desktop_gap }}px;
  }

  .ai-image-row__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
  }

  .ai-image-row__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 390 / 460;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 16px;
  }

  .ai-image-row__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-image-row__item-{{ ai_gen_id }}:hover .ai-image-row__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-image-row__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-row__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-row__content-{{ ai_gen_id }} {
    text-align: center;
    width: 100%;
  }

  .ai-image-row__item-title-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
  }

  .ai-image-row__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: 'Montserrat', sans-serif;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease, color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-image-row__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-row__container-{{ ai_gen_id }} {
      padding: 30px 0;
    }

    .ai-image-row__header-{{ ai_gen_id }} {
      padding: 0 20px;
      margin-bottom: 30px;
    }

    .ai-image-row__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size_mobile }}px;
    }

    .ai-image-row__grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      gap: {{ block.settings.mobile_gap }}px;
      padding-left: calc(50% - {{ block.settings.mobile_item_width | divided_by: 2.0 }}px);
      padding-right: 20px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-image-row__grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-image-row__item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_item_width }}px;
      scroll-snap-align: center;
    }

    .ai-image-row__item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-image-row__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }
  }
{% endstyle %}

<ai-image-row-{{ ai_gen_id }} class="ai-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-row__container-{{ ai_gen_id }}">
    {% if block.settings.header_text != blank %}
      <div class="ai-image-row__header-{{ ai_gen_id }}">
        <h2 class="ai-image-row__title-{{ ai_gen_id }}">{{ block.settings.header_text }}</h2>
      </div>
    {% endif %}

    <div class="ai-image-row__grid-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign title_key = 'title_' | append: i
          assign link_key = 'link_' | append: i
          assign button_text_key = 'button_text_' | append: i

          assign image = block.settings[image_key]
          assign title = block.settings[title_key]
          assign link = block.settings[link_key]
          assign button_text = block.settings[button_text_key]
        %}

        <div class="ai-image-row__item-{{ ai_gen_id }}">
          <div class="ai-image-row__image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              {% if link != blank %}
                <a href="{{ link }}">
                  <img
                    src="{{ image | image_url: width: 390 }}"
                    srcset="{{ image | image_url: width: 390 }} 390w, {{ image | image_url: width: 780 }} 780w"
                    sizes="(max-width: 749px) {{ block.settings.mobile_item_width }}px, 390px"
                    alt="{{ title | escape }}"
                    loading="lazy"
                    width="390"
                    height="460"
                    class="ai-image-row__image-{{ ai_gen_id }}"
                  >
                </a>
              {% else %}
                <img
                  src="{{ image | image_url: width: 390 }}"
                  srcset="{{ image | image_url: width: 390 }} 390w, {{ image | image_url: width: 780 }} 780w"
                  sizes="(max-width: 749px) {{ block.settings.mobile_item_width }}px, 390px"
                  alt="{{ title | escape }}"
                  loading="lazy"
                  width="390"
                  height="460"
                  class="ai-image-row__image-{{ ai_gen_id }}"
                >
              {% endif %}
            {% else %}
              <div class="ai-image-row__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-image-row__content-{{ ai_gen_id }}">
            {% if title != blank %}
              <h3 class="ai-image-row__item-title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}

            {% if link != blank %}
              <a href="{{ link }}" class="ai-image-row__button-{{ ai_gen_id }}">
                {% if button_text != blank %}
                  {{ button_text }}
                {% else %}
                  Shop now
                {% endif %}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</ai-image-row-{{ ai_gen_id }}>

