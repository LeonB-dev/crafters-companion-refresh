{% style %}
  .ai-image-row-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-image-row__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-image-row__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-row__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-image-row__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-row__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-row__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-row__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    padding: 20px;
  }

  .ai-image-row__content-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.desktop_content_y }}%;
    left: {{ block.settings.desktop_content_x }}%;
    transform: translate(-50%, -50%);
    pointer-events: auto;
    max-width: calc(100% - 40px);
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center; /* center all content horizontally */
    text-align: center;  /* center text inside */
  }

  .ai-image-row__title-{{ ai_gen_id }} {
    color: {{ block.settings.desktop_title_color }};
    font-size: {{ block.settings.desktop_title_size }}px;
    font-weight: {{ block.settings.desktop_title_weight }};
    margin: 0 0 {{ block.settings.desktop_title_spacing }}px 0;
    line-height: 1.2;
    word-wrap: break-word;
    overflow-wrap: break-word;
    text-align: center; /* ensure title is centered */
  }

  .ai-image-row__subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.desktop_subtitle_color }};
    font-size: {{ block.settings.desktop_subtitle_size }}px;
    font-weight: {{ block.settings.desktop_subtitle_weight }};
    margin: 0 0 {{ block.settings.desktop_subtitle_spacing }}px 0;
    line-height: 1.4;
    word-wrap: break-word;
    overflow-wrap: break-word;
    text-align: center; /* subtitle always centered */
  }

  .ai-image-row__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.desktop_button_padding_y }}px {{ block.settings.desktop_button_padding_x }}px;
    background-color: {{ block.settings.desktop_button_bg }};
    color: {{ block.settings.desktop_button_text }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.desktop_button_font_size }}px;
    font-weight: {{ block.settings.desktop_button_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.desktop_button_border_width }}px solid {{ block.settings.desktop_button_border_color }};
  }

  .ai-image-row__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.desktop_button_bg_hover }};
    color: {{ block.settings.desktop_button_text_hover }};
    border-color: {{ block.settings.desktop_button_border_hover }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-row__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-image-row__image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-image-row__overlay-{{ ai_gen_id }} {
      padding: 15px;
    }

    .ai-image-row__content-{{ ai_gen_id }} {
      top: {{ block.settings.mobile_content_y }}%;
      left: {{ block.settings.mobile_content_x }}%;
      max-width: calc(100% - 30px);
      display: flex;
      flex-direction: column;
      align-items: center; /* center all content horizontally */
      text-align: center;  /* center text inside */
    }

    .ai-image-row__title-{{ ai_gen_id }} {
      color: {{ block.settings.mobile_title_color }};
      font-size: {{ block.settings.mobile_title_size }}px;
      font-weight: {{ block.settings.mobile_title_weight }};
      margin: 0 0 {{ block.settings.mobile_title_spacing }}px 0;
      text-align: center;
    }

    .ai-image-row__subtitle-{{ ai_gen_id }} {
      color: {{ block.settings.mobile_subtitle_color }};
      font-size: {{ block.settings.mobile_subtitle_size }}px;
      font-weight: {{ block.settings.mobile_subtitle_weight }};
      margin: 0 0 {{ block.settings.mobile_subtitle_spacing }}px 0;
      text-align: center;
    }

    .ai-image-row__button-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_button_padding_y }}px {{ block.settings.mobile_button_padding_x }}px;
      background-color: {{ block.settings.mobile_button_bg }};
      color: {{ block.settings.mobile_button_text }};
      font-size: {{ block.settings.mobile_button_font_size }}px;
      font-weight: {{ block.settings.mobile_button_weight }};
      border: {{ block.settings.mobile_button_border_width }}px solid {{ block.settings.mobile_button_border_color }};
    }

    .ai-image-row__button-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.mobile_button_bg_hover }};
      color: {{ block.settings.mobile_button_text_hover }};
      border-color: {{ block.settings.mobile_button_border_hover }};
    }
  }
{% endstyle %}

<two-image-row-{{ ai_gen_id }} class="ai-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-row__container-{{ ai_gen_id }}">
    <div class="ai-image-row__item-{{ ai_gen_id }}">
      <div class="ai-image-row__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.desktop_image_1 %}
          <picture>
            <source media="(max-width: 749px)" srcset="{% if block.settings.mobile_image_1 %}{{ block.settings.mobile_image_1 | image_url: width: 800 }}{% else %}{{ block.settings.desktop_image_1 | image_url: width: 800 }}{% endif %}">
            <img
              src="{{ block.settings.desktop_image_1 | image_url: width: 1200 }}"
              alt="{{ block.settings.desktop_image_1.alt | escape }}"
              loading="lazy"
              class="ai-image-row__image-{{ ai_gen_id }}"
              width="{{ block.settings.desktop_image_1.width }}"
              height="{{ block.settings.desktop_image_1.height }}"
            >
          </picture>
        {% else %}
          <div class="ai-image-row__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-image-row__overlay-{{ ai_gen_id }}">
          <div class="ai-image-row__content-{{ ai_gen_id }}">
            {% if block.settings.title_1 != blank %}
              <h2 class="ai-image-row__title-{{ ai_gen_id }}">{{ block.settings.title_1 }}</h2>
            {% endif %}
            {% if block.settings.subtitle_1 != blank %}
              <p class="ai-image-row__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle_1 }}</p>
            {% endif %}
            {% if block.settings.button_text_1 != blank and block.settings.button_link_1 != blank %}
              <a href="{{ block.settings.button_link_1 }}" class="ai-image-row__button-{{ ai_gen_id }}">
                {{ block.settings.button_text_1 }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="ai-image-row__item-{{ ai_gen_id }}">
      <div class="ai-image-row__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.desktop_image_2 %}
          <picture>
            <source media="(max-width: 749px)" srcset="{% if block.settings.mobile_image_2 %}{{ block.settings.mobile_image_2 | image_url: width: 800 }}{% else %}{{ block.settings.desktop_image_2 | image_url: width: 800 }}{% endif %}">
            <img
              src="{{ block.settings.desktop_image_2 | image_url: width: 1200 }}"
              alt="{{ block.settings.desktop_image_2.alt | escape }}"
              loading="lazy"
              class="ai-image-row__image-{{ ai_gen_id }}"
              width="{{ block.settings.desktop_image_2.width }}"
              height="{{ block.settings.desktop_image_2.height }}"
            >
          </picture>
        {% else %}
          <div class="ai-image-row__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-image-row__overlay-{{ ai_gen_id }}">
          <div class="ai-image-row__content-{{ ai_gen_id }}">
            {% if block.settings.title_2 != blank %}
              <h2 class="ai-image-row__title-{{ ai_gen_id }}">{{ block.settings.title_2 }}</h2>
            {% endif %}
            {% if block.settings.subtitle_2 != blank %}
              <p class="ai-image-row__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle_2 }}</p>
            {% endif %}
            {% if block.settings.button_text_2 != blank and block.settings.button_link_2 != blank %}
              <a href="{{ block.settings.button_link_2 }}" class="ai-image-row__button-{{ ai_gen_id }}">
                {{ block.settings.button_text_2 }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</two-image-row-{{ ai_gen_id }}>

<script>
  (function() {
    class TwoImageRow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('two-image-row-{{ ai_gen_id }}', TwoImageRow{{ ai_gen_id }});
  })();
</script>

