{% doc %}
  @prompt
    fully responsive, image width adjustable customizable banner where merchants can change media, heading, subheading, button, and layout independently for desktop and mobile, content position fully adjustable, space between button and subtitle adjustable, font weight adjustable, subheading size adjustable, button for mobile position at bottom of image, title and subtitle for mobile at top, button for mobile position at bottom of image, title and subtitle for mobile at top, desktop - subtitle and button centered under title, position of title, subtitle and button fully customisable, content width adjustable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-banner-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    min-height: 400px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-content-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    padding: 40px;
    box-sizing: border-box;
  }

  .ai-banner-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-banner-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.spacing_heading_subheading }}px 0;
    line-height: 1.2;
  }

  .ai-banner-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: {{ block.settings.subheading_weight }};
    margin: 0 0 {{ block.settings.spacing_subheading_button }}px 0;
    line-height: 1.4;
  }

  .ai-banner-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-banner-container-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      margin: 0 auto;
    }

    .ai-banner-content-wrapper-{{ ai_gen_id }} {
      {% if block.settings.desktop_horizontal_position == 'left' %}
        justify-content: flex-start;
      {% elsif block.settings.desktop_horizontal_position == 'center' %}
        justify-content: center;
      {% elsif block.settings.desktop_horizontal_position == 'right' %}
        justify-content: flex-end;
      {% endif %}

      {% if block.settings.desktop_vertical_position == 'top' %}
        align-items: flex-start;
      {% elsif block.settings.desktop_vertical_position == 'middle' %}
        align-items: center;
      {% elsif block.settings.desktop_vertical_position == 'bottom' %}
        align-items: flex-end;
      {% endif %}
    }

    .ai-banner-content-{{ ai_gen_id }} {
      max-width: {{ block.settings.desktop_content_width }}px;

      {% if block.settings.desktop_text_align == 'left' %}
        align-items: flex-start;
      {% elsif block.settings.desktop_text_align == 'center' %}
        align-items: center;
      {% elsif block.settings.desktop_text_align == 'right' %}
        align-items: flex-end;
      {% endif %}
    }

    .ai-banner-heading-{{ ai_gen_id }} {
      text-align: {{ block.settings.desktop_text_align }};
    }

    .ai-banner-subheading-{{ ai_gen_id }} {
      text-align: {{ block.settings.desktop_text_align }};
    }

    .ai-banner-button-{{ ai_gen_id }} {
      {% if block.settings.desktop_text_align == 'left' %}
        align-self: flex-start;
      {% elsif block.settings.desktop_text_align == 'center' %}
        align-self: center;
      {% elsif block.settings.desktop_text_align == 'right' %}
        align-self: flex-end;
      {% endif %}
    }
  }

  @media screen and (max-width: 749px) {
    .ai-banner-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-banner-content-wrapper-{{ ai_gen_id }} {
      padding: 20px;
      flex-direction: column;

      {% if block.settings.mobile_horizontal_position == 'left' %}
        justify-content: flex-start;
      {% elsif block.settings.mobile_horizontal_position == 'center' %}
        justify-content: center;
      {% elsif block.settings.mobile_horizontal_position == 'right' %}
        justify-content: flex-end;
      {% endif %}

      {% if block.settings.mobile_vertical_position == 'top' %}
        align-items: flex-start;
      {% elsif block.settings.mobile_vertical_position == 'middle' %}
        align-items: center;
      {% elsif block.settings.mobile_vertical_position == 'bottom' %}
        align-items: flex-end;
      {% endif %}
    }

    .ai-banner-content-{{ ai_gen_id }} {
      width: 100%;
      max-width: {{ block.settings.mobile_content_width }}px;

      {% if block.settings.mobile_text_align == 'left' %}
        align-items: flex-start;
      {% elsif block.settings.mobile_text_align == 'center' %}
        align-items: center;
      {% elsif block.settings.mobile_text_align == 'right' %}
        align-items: flex-end;
      {% endif %}
    }

    .ai-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.spacing_heading_subheading_mobile }}px;
      text-align: {{ block.settings.mobile_text_align }};
    }

    .ai-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
      margin-bottom: {{ block.settings.spacing_subheading_button_mobile }}px;
      text-align: {{ block.settings.mobile_text_align }};
    }

    .ai-banner-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
      {% if block.settings.mobile_button_full_width %}
        width: 100%;
      {% endif %}

      {% if block.settings.mobile_text_align == 'left' %}
        align-self: flex-start;
      {% elsif block.settings.mobile_text_align == 'center' %}
        align-self: center;
      {% elsif block.settings.mobile_text_align == 'right' %}
        align-self: flex-end;
      {% endif %}
    }
  }
{% endstyle %}

<ai-banner-{{ ai_gen_id }} class="ai-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-container-{{ ai_gen_id }}">
    <div class="ai-banner-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.desktop_image %}
        <picture>
          {% if block.settings.mobile_image %}
            <source
              media="(max-width: 749px)"
              srcset="{{ block.settings.mobile_image | image_url: width: 750 }} 750w,
                      {{ block.settings.mobile_image | image_url: width: 1500 }} 1500w"
            >
          {% endif %}
          <img
            src="{{ block.settings.desktop_image | image_url: width: 1500 }}"
            srcset="{{ block.settings.desktop_image | image_url: width: 1500 }} 1500w,
                    {{ block.settings.desktop_image | image_url: width: 2000 }} 2000w"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            class="ai-banner-image-{{ ai_gen_id }}"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
          >
        </picture>
      {% else %}
        <div class="ai-banner-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      <div class="ai-banner-content-wrapper-{{ ai_gen_id }}">
        <div class="ai-banner-content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}

          {% if block.settings.subheading != blank %}
            <div class="ai-banner-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
          {% endif %}

          {% if block.settings.button_text != blank and block.settings.button_link != blank %}
            <a href="{{ block.settings.button_link }}" class="ai-banner-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</ai-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class AiBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('ai-banner-{{ ai_gen_id }}', AiBanner{{ ai_gen_id }});
  })();
</script>

