{% doc %}
  @prompt
    banner section with title and 3 buttons on same row, title takes up 1/3 buttons take up 2/3, banner width 1500px, font weight adjustable, buttons have borders, banner width adjustable, background width adjustable, banner and background width separately adjustable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-outer-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: {{ block.settings.vertical_padding }}px 20px;
  }

  .ai-banner-background-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.background_width }}px;
    background-color: {{ block.settings.background_color }};
    display: flex;
    justify-content: center;
    padding: {{ block.settings.background_padding }}px;
    border-radius: {{ block.settings.background_border_radius }}px;
  }

  .ai-banner-content-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.banner_width }}px;
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
  }

  .ai-banner-title-{{ ai_gen_id }} {
    flex: 0 0 calc(33.333% - {{ block.settings.gap | divided_by: 2.0 }}px);
    margin: 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    line-height: 1.2;
  }

  .ai-banner-buttons-{{ ai_gen_id }} {
    flex: 0 0 calc(66.667% - {{ block.settings.gap | divided_by: 2.0 }}px);
    display: flex;
    gap: {{ block.settings.button_gap }}px;
  }

  .ai-banner-button-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-banner-content-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 20px;
    }

    .ai-banner-title-{{ ai_gen_id }} {
      flex: 1 1 auto;
      width: 100%;
      text-align: center;
    }

    .ai-banner-buttons-{{ ai_gen_id }} {
      flex: 1 1 auto;
      width: 100%;
      flex-direction: column;
    }
  }
{% endstyle %}

<div class="ai-banner-outer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-background-{{ ai_gen_id }}">
    <div class="ai-banner-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-banner-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      <div class="ai-banner-buttons-{{ ai_gen_id }}">
        {% if block.settings.button_1_text != blank %}
          <a
            href="{{ block.settings.button_1_link }}"
            class="ai-banner-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_1_text }}
          </a>
        {% endif %}

        {% if block.settings.button_2_text != blank %}
          <a
            href="{{ block.settings.button_2_link }}"
            class="ai-banner-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_2_text }}
          </a>
        {% endif %}

        {% if block.settings.button_3_text != blank %}
          <a
            href="{{ block.settings.button_3_link }}"
            class="ai-banner-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_3_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

