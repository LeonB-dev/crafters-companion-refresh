{% doc %}
  @prompt
    2 image row with buttons, title and subtitle overlayed, button & title location adjustable, more adjustability on text and button, able to move title and buttons on x & y axis
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-row-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-image-row__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-image-row__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-row__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-image-row__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-row__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-row__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-row__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
  }

  .ai-image-row__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: {{ block.settings.content_padding }}px;
    z-index: 2;
  }

  .ai-image-row__text-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-image-row__title-{{ ai_gen_id }} {
    position: absolute;
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: {{ block.settings.title_weight }};
    text-align: {{ block.settings.text_align }};
    max-width: {{ block.settings.text_max_width }}%;
  }

  .ai-image-row__subtitle-{{ ai_gen_id }} {
    position: absolute;
    margin: 0;
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    font-weight: {{ block.settings.subtitle_weight }};
    text-align: {{ block.settings.text_align }};
    max-width: {{ block.settings.text_max_width }}%;
  }

  .ai-image-row__button-{{ ai_gen_id }} {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .ai-image-row__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-row__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-image-row__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-image-row__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.8 }}px;
    }

    .ai-image-row__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-row__container-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign subtitle_key = 'subtitle_' | append: i
        assign button_text_key = 'button_text_' | append: i
        assign button_link_key = 'button_link_' | append: i
        assign title_x_key = 'title_x_' | append: i
        assign title_y_key = 'title_y_' | append: i
        assign subtitle_x_key = 'subtitle_x_' | append: i
        assign subtitle_y_key = 'subtitle_y_' | append: i
        assign button_x_key = 'button_x_' | append: i
        assign button_y_key = 'button_y_' | append: i

        assign image = block.settings[image_key]
        assign title = block.settings[title_key]
        assign subtitle = block.settings[subtitle_key]
        assign button_text = block.settings[button_text_key]
        assign button_link = block.settings[button_link_key]
        assign title_x = block.settings[title_x_key]
        assign title_y = block.settings[title_y_key]
        assign subtitle_x = block.settings[subtitle_x_key]
        assign subtitle_y = block.settings[subtitle_y_key]
        assign button_x = block.settings[button_x_key]
        assign button_y = block.settings[button_y_key]
      %}

      <div class="ai-image-row__item-{{ ai_gen_id }}">
        <div class="ai-image-row__image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 1200 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-image-row__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-row__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="ai-image-row__overlay-{{ ai_gen_id }}"></div>

          <div class="ai-image-row__content-{{ ai_gen_id }}">
            <div class="ai-image-row__text-wrapper-{{ ai_gen_id }}">
              {% if title != blank %}
                <h2
                  class="ai-image-row__title-{{ ai_gen_id }}"
                  style="left: {{ title_x }}%; top: {{ title_y }}%;"
                >
                  {{ title }}
                </h2>
              {% endif %}

              {% if subtitle != blank %}
                <p
                  class="ai-image-row__subtitle-{{ ai_gen_id }}"
                  style="left: {{ subtitle_x }}%; top: {{ subtitle_y }}%;"
                >
                  {{ subtitle }}
                </p>
              {% endif %}

              {% if button_text != blank %}
                <a
                  href="{{ button_link }}"
                  class="ai-image-row__button-{{ ai_gen_id }}"
                  style="left: {{ button_x }}%; top: {{ button_y }}%;"
                >
                  {{ button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

