{% doc %}
  @prompt
    Seven Image row with header in monsteratt font. Each image links somewhere and has a title. works on desktop and mobile, can the images be 390 x 460, on mobile can i be in a scrollable line?, can the size on desktop be  1800px width, desktop width adjustable, different font sizes for mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-seven-image-row-{{ ai_gen_id }} {
    width: 100%;
    padding: 40px 20px;
  }

  .ai-seven-image-row__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.desktop_width }}px;
    margin: 0 auto;
  }

  .ai-seven-image-row__header-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-size: {{ block.settings.heading_size_desktop }}px;
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 30px;
    color: {{ block.settings.heading_color }};
    font-weight: {{ block.settings.heading_weight }};
  }

  .ai-seven-image-row__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: {{ block.settings.image_gap }}px;
  }

  .ai-seven-image-row__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-seven-image-row__link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-seven-image-row__link-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-seven-image-row__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 390 / 460;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-seven-image-row__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-seven-image-row__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-seven-image-row__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-seven-image-row__title-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-size: {{ block.settings.title_size_desktop }}px;
    text-align: center;
    color: {{ block.settings.title_color }};
    font-weight: {{ block.settings.title_weight }};
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-seven-image-row-{{ ai_gen_id }} {
      padding: 30px 0;
    }

    .ai-seven-image-row__header-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: 20px;
      padding: 0 20px;
    }

    .ai-seven-image-row__grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: {{ block.settings.image_gap_mobile }}px;
      padding: 0 20px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-seven-image-row__grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-seven-image-row__item-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 195px;
      scroll-snap-align: start;
    }

    .ai-seven-image-row__image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 390 / 460;
    }

    .ai-seven-image-row__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-seven-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-seven-image-row__container-{{ ai_gen_id }}">
    {% if block.settings.main_heading != blank %}
      <h2 class="ai-seven-image-row__header-{{ ai_gen_id }}">{{ block.settings.main_heading }}</h2>
    {% endif %}

    <div class="ai-seven-image-row__grid-{{ ai_gen_id }}">
      {% for i in (1..7) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign title_key = 'title_' | append: i
          assign link_key = 'link_' | append: i
          
          assign image = block.settings[image_key]
          assign title = block.settings[title_key]
          assign link = block.settings[link_key]
        %}

        <div class="ai-seven-image-row__item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-seven-image-row__link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-seven-image-row__link-{{ ai_gen_id }}">
          {% endif %}
            
            <div class="ai-seven-image-row__image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 390 }}"
                  srcset="{{ image | image_url: width: 390 }} 1x, {{ image | image_url: width: 780 }} 2x"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="390"
                  height="460"
                  class="ai-seven-image-row__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-seven-image-row__placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if title != blank %}
              <h3 class="ai-seven-image-row__title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}

          {% if link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

