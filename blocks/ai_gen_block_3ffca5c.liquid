{% doc %}
  @prompt
    video block, title under video in monseratt font, links to another page, wifth 1800px
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-block-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 1500px;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
  }

  .ai-video-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    position: relative;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-video-link-{{ ai_gen_id }}:hover .ai-video-wrapper-{{ ai_gen_id }} {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-video-wrapper-{{ ai_gen_id }} iframe,
  .ai-video-wrapper-{{ ai_gen_id }} video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    pointer-events: none;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 500; /* Medium weight */
    font-weight: {{ block.settings.heading_weight }};
    margin: {{ block.settings.heading_spacing }}px 0 0;
    transition: color 0.3s ease;
  }

  .ai-video-link-{{ ai_gen_id }}:hover .ai-video-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_hover_color }};
  }

  .ai-video-description-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0 0 {{ block.settings.description_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-video-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.5 }}px;
    }

    .ai-video-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-video-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}


<div class="ai-video-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.description != blank %}
    <div class="ai-video-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
  {% endif %}

  {% if block.settings.link_url != blank %}
    <a href="{{ block.settings.link_url }}" class="ai-video-link-{{ ai_gen_id }}">
  {% endif %}

  <div class="ai-video-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      {% liquid
        assign video_url = block.settings.video_url
        assign youtube_id = ''
        assign vimeo_id = ''

        if video_url contains 'youtube.com/watch'
          assign youtube_id = video_url | split: 'v=' | last | split: '&' | first
        elsif video_url contains 'youtu.be/'
          assign youtube_id = video_url | split: 'youtu.be/' | last | split: '?' | first
        elsif video_url contains 'vimeo.com/'
          assign vimeo_id = video_url | split: 'vimeo.com/' | last | split: '?' | first
        endif
      %}

      {% if youtube_id != blank %}
        <iframe
          src="https://www.youtube.com/embed/{{ youtube_id }}?rel=0&modestbranding=1"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
          title="{{ block.settings.heading | default: 'Video' | escape }}"
        ></iframe>
      {% elsif vimeo_id != blank %}
        <iframe
          src="https://player.vimeo.com/video/{{ vimeo_id }}?title=0&byline=0&portrait=0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          loading="lazy"
          title="{{ block.settings.heading | default: 'Video' | escape }}"
        ></iframe>
      {% else %}
        <video
          controls
          {% if block.settings.autoplay %}autoplay muted loop{% endif %}
          playsinline
        >
          <source src="{{ video_url }}" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      {% endif %}
    {% else %}
      <div class="ai-video-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-video-empty-state-{{ ai_gen_id }}">
          Next, add a video URL
        </div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.heading != blank %}
    <h2 class="ai-video-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.link_url != blank %}
    </a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL",
      "info": "Supports YouTube, Vimeo, or direct video file URLs"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL",
      "info": "Make the video clickable and link to another page"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": false,
      "info": "Only works for direct video files, not YouTube or Vimeo"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Title"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Title weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Title spacing",
      "default": 16
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Description spacing",
      "default": 20
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Title color",
      "default": "#1F1300"
    },
    {
      "type": "color",
      "id": "heading_hover_color",
      "label": "Title hover color",
      "default": "#733089"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#1F1300"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Video background",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Video"
    }
  ]
}
{% endschema %}