{% doc %}
  @prompt
    2 image/video row, left image right video, no spacing, no text under video, full video showing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    width: 100%;
  }

  .ai-media-row__item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    overflow: hidden;
  }

  .ai-media-row__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-media-row__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-media-row__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-media-row__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-media-row__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-media-row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-media-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-media-row__item-{{ ai_gen_id }}">
    {% if block.settings.left_image %}
      <img
        src="{{ block.settings.left_image | image_url: width: 2000 }}"
        alt="{{ block.settings.left_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.left_image.width }}"
        height="{{ block.settings.left_image.height }}"
        class="ai-media-row__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-media-row__placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-media-row__empty-state-{{ ai_gen_id }}">
          Add left image
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-media-row__item-{{ ai_gen_id }}">
    {% if block.settings.right_video %}
      {{
        block.settings.right_video
        | video_tag:
          image_size: '1100x',
          autoplay: block.settings.autoplay,
          loop: block.settings.loop,
          muted: block.settings.muted,
          controls: block.settings.show_controls,
          class: 'ai-media-row__video-' | append: ai_gen_id
      }}
    {% else %}
      <div class="ai-media-row__placeholder-{{ ai_gen_id }}">
        {{ 'product-apparel-1' | placeholder_svg_tag }}
        <div class="ai-media-row__empty-state-{{ ai_gen_id }}">
          Add right video
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Image video row",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Left image"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Right video"
    },
    {
      "type": "video",
      "id": "right_video",
      "label": "Video"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Muted",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "aspect_ratio",
      "min": 30,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "Aspect ratio",
      "default": 75
    }
  ],
  "presets": [
    {
      "name": "Image video row"
    }
  ]
}
{% endschema %}
