{% doc %}
  @prompt
    5 images in a row, the images link to other pages and have a title, can the section have a changeable background image only with a title and text all in monserrat font, font weight adjustable, mobile layout - 1&2 on 1 row, 3&4 on next row, hide 5th image, border radius adjustable, shop all button colour adjustable with border, Image title separate from image, 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-row-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
    {% else %}
      background-color: #f4f4f4;
    {% endif %}
    padding: 60px 20px;
  }

  .ai-image-row-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-image-row-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-image-row-title-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.title_font_weight }};
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .ai-image-row-text-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.text_font_weight }};
    font-size: {{ block.settings.text_font_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-image-row-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 40px;
  }

  .ai-image-row-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-image-row-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    aspect-ratio: 1;
  }

  .ai-image-row-link-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-image-row-link-{{ ai_gen_id }}:hover img {
    transform: scale(1.05);
  }

  .ai-image-row-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-row-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-image-row-item-title-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.image_title_font_weight }};
    font-size: {{ block.settings.image_title_font_size }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    margin: 0;
  }

  .ai-image-row-button-wrapper-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-image-row-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.button_font_weight }};
    font-size: {{ block.settings.button_font_size }}px;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_color }};
    border: 2px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ai-image-row-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-row-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-image-row-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-image-row-item-{{ ai_gen_id }}:nth-child(5) {
      display: none;
    }

    .ai-image-row-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.8 }}px;
    }

    .ai-image-row-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_font_size | times: 0.9 }}px;
    }

    .ai-image-row-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.image_title_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<div class="ai-image-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-row-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_text != blank %}
      <div class="ai-image-row-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-image-row-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_text != blank %}
          <div class="ai-image-row-text-{{ ai_gen_id }}">{{ block.settings.section_text }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-image-row-grid-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign link_key = 'link_' | append: i
          assign title_key = 'title_' | append: i
          
          assign image = block.settings[image_key]
          assign link = block.settings[link_key]
          assign title = block.settings[title_key]
        %}

        <div class="ai-image-row-item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-image-row-link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-image-row-link-{{ ai_gen_id }}">
          {% endif %}
            {% if image %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              <div class="ai-image-row-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          {% if link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}

          {% if title != blank %}
            <h3 class="ai-image-row-item-title-{{ ai_gen_id }}">{{ title }}</h3>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if block.settings.button_text != blank %}
      <div class="ai-image-row-button-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_link }}" class="ai-image-row-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

