{% doc %}
  @prompt
    banner section with title and 3 buttons on same row, title takes up 1/3 buttons take up 2/3, banner width 1500px, font weight adjustable, buttons have borders, banner width adjustable, background width adjustable
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-container-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px 20px;
  }

  .ai-banner-content-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.banner_width }}px;
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
  }

  .ai-banner-title-{{ ai_gen_id }} {
    flex: 0 0 calc(100% / 3);
    margin: 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    line-height: 1.2;
  }

  .ai-banner-buttons-{{ ai_gen_id }} {
    flex: 0 0 calc(100% / 3 * 2);
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    align-items: center;
  }

  .ai-banner-button-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-banner-content-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 20px;
    }

    .ai-banner-title-{{ ai_gen_id }} {
      flex: 1;
      text-align: center;
    }

    .ai-banner-buttons-{{ ai_gen_id }} {
      flex: 1;
      flex-direction: column;
      width: 100%;
    }

    .ai-banner-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-banner-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-content-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-banner-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <div class="ai-banner-buttons-{{ ai_gen_id }}">
      {% if block.settings.button_1_text != blank %}
        <a
          href="{{ block.settings.button_1_link }}"
          class="ai-banner-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_1_text }}
        </a>
      {% endif %}

      {% if block.settings.button_2_text != blank %}
        <a
          href="{{ block.settings.button_2_link }}"
          class="ai-banner-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_2_text }}
        </a>
      {% endif %}

      {% if block.settings.button_3_text != blank %}
        <a
          href="{{ block.settings.button_3_link }}"
          class="ai-banner-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_3_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

