    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Minimum height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
