{% doc %}
  @prompt
    I want to create a shopify banner that lets me put a heading, sub-heading and button where ever I want, all font size, weight, colours fully customisable. width of the banner also adjustable, different images and placements of content for mobile and desktop, image width adjustble
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
    overflow: hidden;
  }

  .ai-custom-banner__container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
    min-height: {{ block.settings.min_height_desktop }}px;
  }

  .ai-custom-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height_desktop }}px;
  }

  .ai-custom-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    display: block;
  }

  .ai-custom-banner__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.min_height_desktop }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-custom-banner__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-custom-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.content_position_y_desktop }}%;
    left: {{ block.settings.content_position_x_desktop }}%;
    transform: translate(-50%, -50%);
    text-align: {{ block.settings.text_align_desktop }};
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}%;
  }

  .ai-custom-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-custom-banner__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size_desktop }}px;
    font-weight: {{ block.settings.subheading_weight }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px 0;
    line-height: 1.4;
  }

  .ai-custom-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_y }}px {{ block.settings.button_padding_x }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-custom-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_color_hover }};
    color: {{ block.settings.button_text_color_hover }};
    border-color: {{ block.settings.button_border_color_hover }};
  }

  .ai-custom-banner__mobile-image-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-banner__container-{{ ai_gen_id }} {
      width: 100%;
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-custom-banner__image-wrapper-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-custom-banner__image-placeholder-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-custom-banner__desktop-image-{{ ai_gen_id }} {
      display: none;
    }

    .ai-custom-banner__mobile-image-{{ ai_gen_id }} {
      display: block;
    }

    .ai-custom-banner__content-{{ ai_gen_id }} {
      top: {{ block.settings.content_position_y_mobile }}%;
      left: {{ block.settings.content_position_x_mobile }}%;
      text-align: {{ block.settings.text_align_mobile }};
      max-width: {{ block.settings.content_max_width_mobile }}%;
    }

    .ai-custom-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-custom-banner__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
    }

    .ai-custom-banner__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-custom-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-custom-banner__container-{{ ai_gen_id }}">
    <div class="ai-custom-banner__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-custom-banner__image-{{ ai_gen_id }} ai-custom-banner__desktop-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-custom-banner__image-placeholder-{{ ai_gen_id }} ai-custom-banner__desktop-image-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
          class="ai-custom-banner__image-{{ ai_gen_id }} ai-custom-banner__mobile-image-{{ ai_gen_id }}"
        >
      {% elsif block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 1000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-custom-banner__image-{{ ai_gen_id }} ai-custom-banner__mobile-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-custom-banner__image-placeholder-{{ ai_gen_id }} ai-custom-banner__mobile-image-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-custom-banner__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-custom-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-custom-banner__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
  <a href="{{ block.settings.button_link }}" class="ai-custom-banner__button-{{ ai_gen_id }}" target="_blank" rel="noopener noreferrer">
    {{ block.settings.button_text }}
  </a>
{% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
