      },
      {
        "type": "image_picker",
        "id": "search_result_thumbnail_page_fallback",
        "label": "Fallback image for pages"
      },
      {
        "type": "header",
        "content": "Query Options"
      },
      {
        "type": "checkbox",
        "id": "resource_product",
        "default": true,
        "label": "Search for products to be shown in results"
      },
      {
        "type": "checkbox",
        "id": "resource_collection",
        "default": true,
        "label": "Search for collections to be shown in results"
      },
      {
        "type": "checkbox",
        "id": "resource_article",
        "default": true,
        "label": "Search for articles to be shown in results"
      },
      {
        "type": "checkbox",
        "id": "resource_page",
        "default": true,
        "label": "Search for pages to be shown in results"
      },
      {
        "type": "range",
        "id": "resource_limit",
        "label": "Results Limit",
        "info": "This will apply to each resource type if the box below is unchecked",
        "default": 4,
        "min": 0,
        "max": 10,
        "step": 1
      },
      {
        "type": "checkbox",
        "id": "resource_limit_all",
        "default": false,
        "label": "Apply results limit to all types combined?",
        "info": "This would mean if Results Limit is set to 5 and this box is checked results will show 5 items TOTAL across products, collections, etc"
      },
      {
        "type": "select",
        "id": "show_unavailable",
        "label": "Show Unavailable/OOS Items?",
        "options": [
          {
            "value": "show",
            "label": "Show unavailable items"
          },
          {
            "value": "hide",
            "label": "Hide unavailable items"
          },
          {
            "value": "last",
            "label": "Show these items last (sort to bottom)"
          }
        ],
        "default": "last"
      },
      {
        "type": "header",
        "content": "Results Options"
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_vendor",
        "default": false,
        "label": "Show vendor in predictive search",
        "info": "Visible when search suggestions enabled."
      },
      {
        "type": "checkbox",
        "id": "predictive_search_show_price",
        "default": false,
        "label": "Show price in predictive search",
        "info": "Visible when search suggestions enabled."
      },
      {
        "type": "text",
        "id": "additional_fields",
        "label": "Additional Fields - Info Only",
        "info": "Search is performed by default on headline information e.g. product titles, article authors etc. This is recommended for best search performance. If custom functionality is required speak to Herd to discuss implications and arrange development."
      }
    ]
  },
