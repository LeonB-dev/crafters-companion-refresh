{% liquid
  assign template_name = 'section-link-blocks'

  assign heading = section.settings.heading
  assign text = section.settings.text
  assign blocks = section.blocks | map: 'settings'

  assign margin_bottom = section.settings.margin_bottom
%}


<div class="{{- template_name }} u-space-below-{{- margin_bottom }}" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="wrapper">
      {% if heading != blank %}
        <h2 class="u-heading-sm">{{ heading }}</h2>
      {% endif %}
      {{ text }}
      {% if blocks.size > 0 %}
        <div class="link-blocks">
          {% for block in blocks %}
            <a href="{{ link_url }}" class="link-block">
              <img src="{{- block.image | image_url: width: 150 -}}" alt="{{- block.image.alt | default: block.link_text -}}" height="150" width="150" loading="lazy">
              <span class="link-title">{{ block.link_text }}</span>
              {%- render 'icon', _name: 'icon-arrow-right' -%}
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
.section-link-blocks {
  position: relative;
}
.section-link-blocks .container {
  display: flex;
  justify-content: center;
}
.section-link-blocks .container .wrapper {
  width: 100%;
  max-width: 100%;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}
@media (min-width: 768px) {
  .section-link-blocks .container .wrapper {
    max-width: 44rem;
  }
}
.section-link-blocks .container .wrapper h2,
.section-link-blocks .container .wrapper p {
  margin-bottom: 0;
}
.section-link-blocks .container .wrapper .link-blocks {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.section-link-blocks .container .wrapper .link-blocks .link-block {
  text-decoration: none;
  display: grid;
  grid-template-columns: 5rem 1fr 1rem;
  align-items: center;
  gap: 1.5rem;
}
.section-link-blocks .container .wrapper .link-blocks .link-block:not(:first-child) {
  padding-top: 1rem;
  border-top: 1px solid var(--colour-whisper);
}
.section-link-blocks .container .wrapper .link-blocks .link-block img {
  aspect-ratio: 1/1;
  width: 100%;
  object-fit: cover;
}
.section-link-blocks .container .wrapper .link-blocks .link-block .link-title {
  color: var(--colour-black);
  display: block;
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.75rem;
}
.section-link-blocks .container .wrapper .link-blocks .link-block svg {
  width: 1rem;
  height: 0.5rem;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Link Blocks",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Add margin below",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        }
      ],
      "default": "lg"
    }
  ],
  "blocks": [
    {
      "type": "link_block",
      "name": "Link Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Minimum width: 200px and 1/1 aspect ratio."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Link Blocks",
      "category": "Content"
    }
  ]
}
{% endschema %}
