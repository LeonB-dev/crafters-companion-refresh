          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "This will override the default image. Minimum width: 400px and 5/7 aspect ratio."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "info": "This will override the default page/collection title"
        }
      ]
    },
    {
      "type": "product_block",
      "name": "Product block",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
