{%- liquid
  assign template_name = 'section-campaign-blocks'

  assign kicker = section.settings.kicker
  assign heading = section.settings.heading | remove: '<p>' | remove: '</p>' | replace: '<strong>', '<strong><span>' | replace: '</strong>', '</span></strong>'
  assign text = section.settings.text

  assign link_url = section.settings.link_url
  assign link_text = section.settings.link_text

  assign heading_class = 'u-heading-lg heading'
  assign kicker_class = 'u-text-md kicker'

  assign disable_h1_tags = section.settings.disable_h1_tags
  assign h1_tag = section.settings.h1_tag

  assign margin_bottom = section.settings.margin_bottom
%}


<div class="{{- template_name }}  u-space-below-{{- margin_bottom }} overflow-hidden" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="content u-content-offset">
      {% if kicker != blank %}
        {% if h1_tag == 'kicker' and disable_h1_tags == false %}
          <h1 class="{{- kicker_class -}}">{{ kicker }}</h1>
        {% else %}
          <p class="{{- kicker_class -}}">{{ kicker }}</p>
        {% endif %}
      {% endif %}
      {% if h1_tag == 'heading' and disable_h1_tags == false %}
        <h1 class="{{- heading_class -}}">{{- heading -}}</h1>
      {% else %}
        <h2 class="{{- heading_class -}}">{{- heading -}}</h2>
      {% endif %}
      {{- text -}}
      {%- if link_url != blank and link_text != blank -%}
        <a href="{{- link_url -}}" class="c-btn main primary">{{- link_text -}}</a>
      {%- endif -%}
    </div>
    <div class="swiper-container" data-scb-slider>
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {% liquid
            assign heading = block.settings.heading
            assign image = block.settings.image

            if block.type == 'collection_block'
              assign collection = collections[block.settings.collection]
              assign page_url = collection.url
              assign page_heading = collection.title
              assign page_image = collection.image
              assign page_lozenge = collection.metafields.promotion.lozenge_text
            elsif block.type == 'page_block'
              assign page = pages[block.settings.page]
              assign page_url = page.url
              assign page_heading = page.title
              assign page_image = page.metafields.custom.featured_image
              assign page_lozenge = page.metafields.promotion.lozenge_text
            elsif block.type == 'product_block'
              assign product = block.settings.product
              assign page_url = product.url
              assign page_lozenge = block.settings.lozenge
            endif

            if heading != blank
              assign page_heading = heading
            endif

            if image != blank
              assign page_image = image
            endif
          %}
          <div class="swiper-slide">
            {%
              render 'category-item',
              _url: page_url,
              _image: page_image,
              _heading: page_heading,
              _lozenge: page_lozenge
              _loading: 'eager'
            -%}
          </div>
        {%- endfor -%}
      </div>
      <div class="swiper-nav">
        <button class=" c-btn swiper-button prev" aria-label="Previous" data-scb-prev>
          {%- render 'icon', _name: 'icon-arrow-left' -%}
        </button>
        <button class="c-btn swiper-button next" aria-label="Next" data-scb-next>
          {%- render 'icon', _name: 'icon-arrow-right' -%}
        </button>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.section-campaign-blocks {
  margin: 1.5rem 0;
}
.section-campaign-blocks .container {
  display: flex;
  gap: 2.5rem;
  position: relative;
  padding-bottom: 4rem;
}
@media (max-width: 767.98px) {
  .section-campaign-blocks .container {
    flex-direction: column;
  }
}
@media (min-width: 768px) {
  .section-campaign-blocks .container {
    display: grid;
    grid-template-columns: 1fr 52%;
    align-items: center;
  }
}
@media (min-width: 1280px) {
  .section-campaign-blocks .container {
    grid-template-columns: 1fr 60%;
    gap: 4.5rem;
  }
}
@media (min-width: 768px) {
  .section-campaign-blocks .container.is-active .content {
    opacity: 0;
    transition-delay: 0s;
  }
}
@media (min-width: 768px) {
  .section-campaign-blocks .content {
    opacity: 1;
    transition: opacity var(--transition-duration) var(--transition-timing) 0s;
    transition-delay: var(--transition-duration);
  }
}
.section-campaign-blocks .content .kicker {
  display: block;
  margin-bottom: 0.5rem;
  color: var(--colour-royal-purple);
}
.section-campaign-blocks .swiper-slide {
  width: auto;
  height: auto;
  margin-right: 1rem;
}
.section-campaign-blocks .swiper-nav {
  position: absolute;
  right: 1rem;
  bottom: 0;
}
.section-campaign-blocks .snippet-category-item {
  width: 16.25rem;
  height: 100%;
}
@media (min-width: 768px) {
  .section-campaign-blocks .snippet-category-item {
    width: 21.25rem;
  }
}
{% endstylesheet %}

{% javascript %}
(()=>{"use strict";const e="is-active";var t,i;t="section-campaign-blocks",i={async onLoad(){this.loadSlider()},loadSlider(){window.theme.Swiper?this.initSlider():document.addEventListener("theme:inititialised",(()=>{this.initSlider()}),{once:!0})},initSlider(){this.container.querySelectorAll("[data-scb-slider]").forEach((t=>{const i=t.querySelector("[data-scb-prev]"),s=t.querySelector("[data-scb-next]");new window.theme.Swiper(t,{slidesPerView:"auto",loop:!1,speed:1e3,spaceBetween:16,simulateTouch:!1,navigation:{prevEl:i,nextEl:s},breakpoints:{[theme.breakpoints.xl]:{}},on:{slideChange:function(i){i.activeIndex>=1?t.parentNode.classList.add(e):t.parentNode.classList.remove(e)}}})}))}},Shopify.theme.sections&&Shopify.theme.sections.register?(0===Shopify.theme.sections.getInstances(t).length&&Shopify.theme.sections.register(t,i),Shopify.theme.sections.load(t)):function(e,t){var i={name:e,events:t};theme.sections.push(i)}(t,i)})();
