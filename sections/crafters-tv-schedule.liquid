{% schema %}
{
  "name": "CTV Schedule",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Section text colour",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "banner_background_color",
      "label": "Dates banner background colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "banner_text_color",
      "label": "Dates banner text colour",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "show_name_color",
      "label": "Show name colour",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "show_time_color",
      "label": "Show time colour",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "show_separator_color",
      "label": "Show separator colour",
      "default": "#cccccc"
    }
  ],
  "blocks": []
}
{% endschema %}
