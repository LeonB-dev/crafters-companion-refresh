{%- liquid
  assign template_name = 'section-hero-banner'
  assign use_autoplay = section.settings.use_autoplay
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
%}


<div
  class="{{- template_name }}"
  data-section-type="{{- template_name -}}"
  data-section-id="{{ section.id }}"
>
  {%- render 'paper-edge', _section: section -%}
  <div class="swiper-container" data-autoplay="{{- use_autoplay -}}" data-hb-slider data-transition-time="{{ section.settings.slide_transition_time | times: 1000 }}">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% liquid
          assign text_colour = block.settings.text_colour
          assign primary_colour = block.settings.primary_colour
          assign button_colour = block.settings.button_colour
          assign subtitle = block.settings.subtitle
          assign title = block.settings.title
          assign content = block.settings.content
          assign cta_text = block.settings.cta_text
          assign link_url = block.settings.link_url
          assign secondary_link_text = block.settings.secondary_link_text
          assign secondary_link_url = block.settings.secondary_link_url
          assign video = block.settings.video
          assign image_desktop = block.settings.image_desktop
          assign image_mobile = block.settings.image_mobile | default: image_desktop
          assign image_alt = image_desktop.alt
        %}

        <div class="hb-slide swiper-slide">
          <div class="hb-slide__background" style="background-color: {{ primary_colour }};">
            <div class="hb-content__grid {% if video %}has-video{% endif %}">
              <div class="hb-content__text">
                <span class="hb-content__subtitle">{{ subtitle }}</span>
                <h2>{{ title }}</h2>
                <div class="hb-slide__content">
                  {{ content }}
                </div>
                <div class="hb-slide__buttons">
                  <a class="c-btn button lozenge-l" href="{{- link_url -}}" class="c-btn" style="color: {{ text_colour }}; background: {{ button_colour }}">{{ cta_text }}</a>
                  <a href="{{- secondary_link_url -}}" class="c-btn underlined">{{ secondary_link_text }}</a>
                </div>
              </div>
              {% if video %}
                <div class="hb-slide__video">
                  {{ video | video_tag: image_size: '400x', autoplay: false, loop: true, controls: false, muted: true }}
                  <button
                    type="button"
                    class="c-btn video-play"
                    aria-label="Play video"
                    data-ci-video-control
                  >
                    {%- render 'icon', _name: 'icon-play', _class: 'play' -%}
                    {%- render 'icon', _name: 'icon-pause', _class: 'pause' -%}
                  </button>
                </div>
              {% endif %}
            </div>
          </div>

          {% capture picture %}
            <picture>
              <source media="(min-width:1500px)" srcset="{{- image_desktop | image_url: width: 1920 -}}">
              <source media="(min-width:1100px)" srcset="{{- image_desktop | image_url: width: 1500 -}}">
              <source media="(min-width:800px)" srcset="{{- image_desktop | image_url: width: 1024 -}}">
              <source media="(max-width: 767px)" srcset="{{- image_mobile | image_url: width: 800 -}}">
              <img fetchpriority="high" src="{{- image_desktop | image_url: width: 800 -}}" alt="{{- image_alt -}}" height="{{ image_desktop.height }}" width="{{ image_desktop.width }}" loading="eager" class="image" />
            </picture>
          {% endcapture %}
          {% if link_url != blank %}
            <a href="{{- link_url -}}">
              {{ picture }}
            </a>
          {% else %}
            {{ picture }}
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 %}
      <div class="swiper-nav slider-ui">
        <div class="container">
          {% if use_autoplay %}
            <svg width="30" height="30" viewBox="0 0 30 30" class="circular-progress" style="--transition-time: {{ section.settings.slide_transition_time | times: 1000 }}ms">
              <circle class="bg"></circle>
              <circle class="fg"></circle>
            </svg>
          {% endif %}
          <div class="swiper-pagination" data-swiper-pagination></div>
          <div>
            <button class="slider-ui__prev" type="button" data-hb-prev>
              {%- render 'icon', _name: 'icon-prev' -%}
              <span class="sr-only">Previous</span>
            </button>
            <button data-hb-next class="slider-ui__next active" type="button" data-hb-next>
              {%- render 'icon', _name: 'icon-next' -%}
              <span class="sr-only">Next</span>
            </button>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
  #{{ section.id }}.section-hero-banner {
    margin-top: {{ margin_top }}px;
    margin-bottom: {{ margin_bottom }}px;
  }

  #{{ section.id }} button.slider-ui__prev {
    background: {{ primary_colour | color_modify: 'alpha', 0.25 }};
    color: {{ text_colour }};
  }
  #{{ section.id }}.section-hero-banner .slider-ui button.active {
    background: {{ primary_colour }};
    color: {{ text_colour }};
  }
</style>

{% stylesheet %}
.section-hero-banner {
  position: relative;
}
.section-hero-banner picture {
  object-fit: cover;
  width: 100%;
  height: 100%;
}
.section-hero-banner picture img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.section-hero-banner .hb-slide {
  display: grid;
  grid-template-columns: 2fr 1fr;
  align-self: center;
}
@media (max-width: 767.98px) {
  .section-hero-banner .hb-slide {
    grid-template-columns: 1fr;
  }
  .section-hero-banner .hb-slide picture {
    order: 0;
  }
  .section-hero-banner .hb-slide .hb-slide__video {
    display: none;
  }
}
@media screen and (max-width: 767px) {
  .section-hero-banner .hb-slide {
    align-self: initial;
    height: auto;
  }
}
.section-hero-banner .hb-slide__background {
  padding: 12rem 2rem;
  display: grid;
  align-items: center;
}
@media (max-width: 767.98px) {
  .section-hero-banner .hb-slide__background {
    order: 1;
  }
}
@media screen and (max-width: 767px) {
  .section-hero-banner .hb-slide__background {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
}
.section-hero-banner .hb-slide__background .hb-content__grid.has-video {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 1rem;
  align-items: center;
}
@media (max-width: 767.98px) {
  .section-hero-banner .hb-slide__background .hb-content__grid.has-video {
    grid-template-columns: 1fr;
  }
}
.section-hero-banner .hb-slide__background .hb-slide__buttons {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}
.section-hero-banner .hb-slide__background .hb-content__subtitle {
  display: block;
  margin-bottom: 1.5rem;
}
.section-hero-banner .hb-slide__background h2 {
  line-height: 1;
  margin-bottom: 1.5rem;
}
.section-hero-banner .hb-slide__background p {
  margin-bottom: 1.5rem;
  font-size: 1.15rem;
}
.section-hero-banner .hb-slide__video {
  position: relative;
}
.section-hero-banner .hb-slide__video .video-play {
  position: absolute;
  left: 0.5rem;
  bottom: 0.5rem;
  z-index: 5;
  padding: 0;
  height: 2rem;
  width: 2rem;
  border-radius: 100%;
  border: 1px solid var(--colour-white);
  display: grid;
  place-items: center;
}
.section-hero-banner .hb-slide__video .video-play svg {
  height: 0.75rem;
  width: 0.75rem;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  transition: all var(--transition-duration) var(--transition-timing) 0s;
  fill: white;
}
.section-hero-banner .hb-slide__video .video-play svg.play {
  opacity: 1;
}
.section-hero-banner .hb-slide__video .video-play svg.pause {
  opacity: 0;
}
.section-hero-banner .hb-slide__video.playing .video-play svg.play {
  opacity: 0;
}
.section-hero-banner .hb-slide__video.playing .video-play svg.pause {
  opacity: 1;
}
.section-hero-banner .swiper-pagination {
  align-items: center;
  gap: 0.3rem;
}
.section-hero-banner .swiper-pagination span.swiper-pagination-bullet,
.section-hero-banner .swiper-pagination span.swiper-pagination-bullet-active {
  background: var(--colour-grey-mid);
  border-radius: 50%;
  width: 8px;
  height: 8px;
  color: pink;
}
.section-hero-banner .swiper-pagination span.swiper-pagination-bullet-active {
  background: var(--colour-black);
}
.section-hero-banner .swiper-nav {
  z-index: 2;
  gap: 0.5rem;
  position: absolute;
  bottom: 4.5rem;
  padding: 0;
}
.section-hero-banner .swiper-nav .container {
  max-width: none;
  padding-left: 2rem;
  padding-right: 2rem;
}
.section-hero-banner .swiper-nav > .container div {
  gap: 0.5rem;
}
@media screen and (max-width: 767px) {
  .section-hero-banner .swiper-nav {
    bottom: 1.5rem;
  }
  .section-hero-banner .swiper-nav > .container {
    display: flex;
    justify-content: flex-end;
  }
}

.circular-progress {
  --size: 30px;
  --half-size: calc(var(--size) / 2);
  --stroke-width: 3px;
  --radius: calc((var(--size) - var(--stroke-width)) / 2);
  --circumference: calc(var(--radius) * pi * 2);
  --dash: calc((var(--progress) * var(--circumference)) / 100);
  animation: none;
}
.circular-progress.in-progress {
  animation: progress-animation var(--transition-time) linear 0ms forwards;
}
.circular-progress circle {
  cx: var(--half-size);
  cy: var(--half-size);
  r: var(--radius);
  stroke-width: var(--stroke-width);
  fill: none;
  stroke-linecap: round;
}
.circular-progress circle.bg {
  stroke: #ddd;
}
.circular-progress circle.fg {
  transform: rotate(-90deg);
  transform-origin: var(--half-size) var(--half-size);
  stroke-dasharray: var(--dash) calc(var(--circumference) - var(--dash));
  transition: stroke-dasharray 0.3s linear 0s;
  stroke: #000000;
}

@property --progress {
  syntax: "<number>";
  inherits: false;
  initial-value: 0;
}
@keyframes progress-animation {
  from {
    --progress: 0;
  }
  to {
    --progress: 100;
  }
}
{% endstylesheet %}

