{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "overflow-hidden",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_autoplay",
      "label": "Slide Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "slide_transition_time",
      "label": "Slide Transition Time",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "color",
          "id": "text_colour",
          "label": "Text Colour",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "primary_colour",
          "label": "Primary Colour",
          "info": "This is the primary colour used for the background of the slide.",
          "default": "#FEF5F6"
        },
        {
          "type": "color",
          "id": "button_colour",
          "label": "Button Colour",
          "default": "#F3A2AC"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Subtitle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Content</p>"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA Text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "CTA URL"
        },
        {
          "type": "text",
          "id": "secondary_link_text",
          "label": "Secondary Link Text"
        },
        {
          "type": "url",
          "id": "secondary_link_url",
          "label": "Secondary Link URL"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Image (Desktop)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Image (Mobile)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Content"
    }
  ]
}
{% endschema %}
