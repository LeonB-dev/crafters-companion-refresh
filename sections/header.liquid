{
  "name": "Header",
  "class": "site-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "url",
      "id": "clearance_link_url",
      "label": "Clearance URL"
    },
    {
      "type": "text",
      "id": "clearance_link_text",
      "label": "Clearance URL Link Text"
    }
  ],
  "blocks": [
    {
      "type": "promo_blocks",
      "name": "Promotion Block",
      "settings": [
        {
          "type": "header",
          "content": "Settings"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Position",
          "info": "The exact name from level 1 of the navigation."
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "", "label": "Default" },
            { "value": "alt", "label": "Alt" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "info": "This will override the default title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "This will override the default image"
        },
        {
          "type": "header",
          "content": "Alt Style Options"
        },
        {
          "type": "checkbox",
          "id": "show_label",
          "label": "Show top-left label",
