  fill: white;
  stroke-width: 1;
}
.section-header .actions .nav-open {
  text-decoration: none;
  color: inherit;
  background: transparent;
  border: 0;
  -webkit-appearance: none;
          appearance: none;
  padding: 0;
  margin: 0;
}
.section-header .actions .nav-open:focus {
  outline: none;
}
.section-header .actions .nav-open:hover {
