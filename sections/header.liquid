}
.section-header .nav-container .nav-back svg {
  height: 0.5rem;
  width: 1rem;
  fill: currentColor;
}
.section-header .nav-container .nav-close {
  margin-left: auto;
}
.section-header .nav-container .nav-close:focus {
  border: 1px solid var(--colour-emperor);
}
.section-header .nav-container .nav-close svg {
  height: 25px;
  width: 25px;
}
.section-header .nav {
  --link-padding-xs: 1rem 2.5rem 1rem 1.5rem;
  flex-grow: 1;
  position: relative;
  font-size: var(--font-size-xl);
  padding-top: 6px;
}
@media (max-width: 1023.98px) {
  .section-header .nav {
    background-color: var(--colour-purple-x-light);
  }
}
@media (max-width: 1023.98px) and (hover: none) {
  .section-header .nav {
    overflow-y: auto;
    overflow-x: hidden;
    padding-bottom: 240px;
  }
}
@media (min-width: 1024px) {
  .section-header .nav {
    padding-bottom: 0.5rem;
  }
}
.section-header .nav ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.section-header .nav ul li > a {
  display: inline-flex;
  text-decoration: none;
  align-items: center;
  gap: 0.25rem;
}
.section-header .nav ul li > a .nav-icon-desktop {
