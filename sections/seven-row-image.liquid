{% assign image_count = 0 %}
{% for i in (1..7) %}
  {% assign image_key = 'image' | append: i %}
  {% if section.settings[image_key] %}
    {% assign image_count = image_count | plus: 1 %}
  {% endif %}
{% endfor %}

<div class="seven-image-row-wrapper image-count-{{ image_count }}">
  {% if section.settings.main_heading != blank %}
    <h2 class="seven-image-main-header">{{ section.settings.main_heading }}</h2>
  {% endif %}

  <div class="seven-image-row">
    {% for i in (1..7) %}
      {% capture image_key %}image{{ i }}{% endcapture %}
      {% capture link_key %}link{{ i }}{% endcapture %}
      {% capture heading_key %}heading{{ i }}{% endcapture %}
      {% capture text_key %}text{{ i }}{% endcapture %}

      {% assign image = section.settings[image_key] %}
      {% assign link = section.settings[link_key] %}
      {% assign heading = section.settings[heading_key] %}
      {% assign text = section.settings[text_key] %}

      {% if image %}
        <div class="seven-image-block">
          <a href="{{ link | default: '#' }}" class="seven-block-link">
            <img src="{{ image | image_url: width: 2000 }}" alt="{{ heading | escape }}">
            <div class="seven-text-content">
              <h3>{{ heading }}</h3>
              <p>{{ text }}</p>
            </div>
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<style>
/* ---- SEVEN IMAGE ROW ---- */

.seven-image-row-wrapper {
  max-width: 1800px;
  margin: 0 auto;
  padding: 0 20px;
  text-align: center;
}

.seven-image-main-header {
  font-family: "Montserrat", sans-serif;
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 30px;
}

.seven-image-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
}

.seven-image-block {
  text-align: center;
  flex: 1 1 calc(14.28% - 20px);
  max-width: calc(14.28% - 20px);
}

.seven-block-link {
  text-decoration: none;
  color: inherit;
  display: block;
  transition: transform 0.3s ease;
}

.seven-block-link:hover img {
  transform: scale(1.03);
}

.seven-image-block img {
  width: 100%;
  height: auto;
  border-radius: 8px;
  transition: transform 0.3s ease;
}

.seven-text-content {
  margin-top: 10px;
  padding: 0 6px;
}

.seven-text-content h3 {
  font-size: 16px;
  font-weight: 700;
  margin: 0;
}

.seven-text-content p {
  font-size: 14px;
  color: #333;
  margin-top: 6px;
}

/* MOBILE: horizontal scroll layout */
@media screen and (max-width: 768px) {
  .seven-image-row {
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: 16px;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 0 10px 10px 10px;
  }

  .seven-image-row::-webkit-scrollbar {
    display: none;
  }

  .seven-image-block {
    flex: 0 0 80%;
    max-width: 80%;
  }

  .seven-image-main-header {
    font-size: 22px;
  }
}
</style>
