{% schema %}
{
  "name": {
    "de": "Suchseite",
    "en": "Search",
    "es": "Búsqueda",
    "fr": "Recherche",
    "it": "Ricerca",
    "pt-BR": "Pesquisa"
  },
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_ajax",
      "default": true,
      "label": "Enable AJAX",
      "info": "Enables real-time filtering, sorting and pagination using AJAX."
    },
    {
      "type": "checkbox",
      "id": "enable_filters",
      "default": true,
      "label": "Enable Filters"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "Enable Sorting"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_results",
      "default": true,
      "label": "Enable Infinite Load More",
      "info": "Loads more results on same page with Load More/Load Less buttons instead of page numbers"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 1,
      "max": 30,
      "step": 1,
      "label": "Products per Page",
      "default": 24
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Products per Row",
      "default": 3
    }
  ],
  "blocks": []
}
{% endschema %}
