{%- liquid
  assign template_name = 'section-shop-the-day-header'

  assign heading = ''
  assign title = collection.title | split: '-' | first
  assign heading = collection.title | remove: title | remove: '- '
  assign description = collection.description

  assign date_replace = heading | replace: '-', '/'
  assign date = date_replace | date: '%e %B, %Y'

  assign article_url = collection.metafields.custom.linked_ctv_article_url.value
  assign shop_the_date = collection.metafields.custom.linked_ctv_collection.value
  assign url_parts = article_url | split: '/' | reverse
  assign article_handle = url_parts[0]
  assign blog_handle = url_parts[1]
  assign article_handle_template = 'blog_category/article_handle'
  assign article_handle = article_handle_template | replace: 'blog_category', blog_handle | replace: 'article_handle', article_handle
  assign article = articles[article_handle]
%}
<div class="{{- template_name }} u-space-below-lg overflow-hidden" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="wrapper">
    {%- render 'paper-edge', _edge_version: 'edge-03', _bottom_edge_colour: 'white' -%}
    <div class="container">
      {%- render 'crafters-tv-heading', _title: title, _heading: date, _text: description, _text_class: '' -%}
      {%- if shop_the_date != blank or article_url != blank -%}
        <div class="actions">
          {%- if shop_the_date != blank -%}
            <a href="{{ shop_the_date.url }}" class="c-btn main quinary" data-page-handle="{{ article.handle }}">
              {{- 'ctv.shop_the_day' | t -}}
            </a>
          {%- endif -%}
          {%- if article_url != blank -%}
            <a href="{{ article_url }}" class="c-btn main tertiary" data-page-handle="{{ article.handle }}">
              {{- 'ctv.watch' | t -}}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>


{% stylesheet %}
.section-shop-the-day-header .wrapper {
  padding: 3rem 0 4rem 0;
  position: relative;
  z-index: 1;
  color: var(--colour-sugar-cane);
  overflow: hidden;
}
@media (min-width: 768px) {
  .section-shop-the-day-header .wrapper {
    padding: 4.5rem 0 7rem 0;
  }
}
.section-shop-the-day-header .wrapper:before {
  content: "";
  background: radial-gradient(circle, #90489c 0%, #4b3ab0 100%);
  position: absolute;
  inset: 0;
  height: calc(100% - 1px);
  width: 100%;
  z-index: 1;
}
.section-shop-the-day-header .wrapper::after {
  content: "";
  background-image: url("data:image/svg+xml,%3C%3Fxml version='1.0' encoding='UTF-8' standalone='no'%3F%3E%3C!DOCTYPE svg PUBLIC '-//W3C//DTD SVG 1.1//EN' 'http://www.w3.org/Graphics/SVG/1.1/DTD/svg11.dtd'%3E%3Csvg width='100%25' height='100%25' viewBox='0 0 456 618' version='1.1' xmlns='http://www.w3.org/2000/svg' xmlns:xlink='http://www.w3.org/1999/xlink' xml:space='preserve' xmlns:serif='http://www.serif.com/' style='fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2;'%3E%3Cpath d='M17.425,276.477C-4.861,292.432 -4.86,325.568 17.425,341.524L392.553,610.1C419.023,629.052 455.838,610.132 455.838,577.577L455.838,40.423C455.838,7.868 419.023,-11.052 392.553,7.9L17.425,276.477Z' style='fill:rgb(31,19,0);fill-opacity:0.1;fill-rule:nonzero;'/%3E%3C/svg%3E%0A");
  background-repeat: no-repeat;
  background-size: 100%;
  background-position: top 4% right -24vw;
  z-index: 5;
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  opacity: 1;
}
@media (min-width: 768px) {
  .section-shop-the-day-header .wrapper::after {
    background-image: url("data:image/svg+xml,%3Csvg clip-rule='evenodd' fill-rule='evenodd' stroke-linejoin='round' stroke-miterlimit='2' viewBox='0 0 1087 1522' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='m16.714 728.189c-22.285 15.956-22.285 49.091 0 65.047l1006.536 720.644c26.47 18.95 63.29.03 63.29-32.53v-1441.279c0-32.555-36.82-51.476-63.29-32.524z' fill='%231f1300' fill-opacity='.1' fill-rule='nonzero'/%3E%3C/svg%3E");
    background-position: top -20rem right -24vw;
  }
}
@media (min-width: 1024px) {
  .section-shop-the-day-header .wrapper::after {
    background-position: top -28rem right -24vw;
  }
}
@media (min-width: 1024px) {
  .section-shop-the-day-header .wrapper::after {
    background-position: top -40rem right -32vw;
  }
}
@media (min-width: 1280px) {
  .section-shop-the-day-header .wrapper::after {
    background-position: top -44rem right -36vw;
  }
}
@media (min-width: 1600px) {
  .section-shop-the-day-header .wrapper::after {
    background-position: top -52rem right -40vw;
  }
}
.section-shop-the-day-header .container {
  position: relative;
  z-index: 10;
}
.section-shop-the-day-header .actions {
  display: flex;
  justify-content: center;
  gap: 2rem;
  margin-top: 2rem;
}
.section-shop-the-day-header .snippet-crafters-tv-heading {
  margin-bottom: 0;
}
.section-shop-the-day-header .text {
  display: grid;
  justify-content: center;
  text-align: center;
}
.section-shop-the-day-header .text p:last-of-type {
  margin: 0;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Shop the Day",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    }
  ],
  "blocks": []
}
{% endschema %}
