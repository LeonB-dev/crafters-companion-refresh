{% liquid
  assign template_name = 'section-article'

  assign title = article.title

  assign image = article.image
  assign image_alt = image.alt | default: title

  assign content = article.content
  assign author = article.author
  assign url = article.url | escape
  assign date = article.published_at | date: '%e %B, %Y'
  assign blog_url = article.url | split: '/'
  assign blog_name = blogs[blog_url[2]].title
  assign blog_handle = blog_name | handleize
  assign blog = blogs[blog_handle]
  assign craft_area = article.metafields.custom.craft_area

  assign author_details = article.metafields.custom.author.value
  assign author_image = author_details.image
  assign author_first_name = author_details.first_name
  assign author_last_name = author_details.last_name
  assign author_name_tag = author | handleize
  assign author_bio = author_details.bio
  assign author_tag = author_details.tag | handleize
  assign author_url = ''
  if author_tag != blank
    assign author_url = blog.url | append: '/tagged/' | append: author_tag
  endif

  for tag in article.tags
    if tag contains 'Category'
      assign tag_category = tag | split: '_' | last
    endif
  endfor

  assign word_count = content | strip_html | split: ' ' | size
  assign average_words_per_minute = 150
  assign read_time = word_count | divided_by: average_words_per_minute | ceil

  if read_time == 0
    assign read_time = 1
  endif

  assign suffix = ' minute'
  if read_time > 1
    assign suffix = ' minutes'
  endif

  assign enable_featured_image = section.settings.enable_featured_image
%}

{{- 'section-article.css' | asset_url | stylesheet_tag -}}

{% comment %}
  <pre>
    author_image: {{ author_image.image | image_url }}<br/>
    author_name: {{ author_name }}<br/>
    author_bio: {{ author_bio }}
  </pre>
{% endcomment %}

<div class="{{- template_name }} u-space-below-md" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="container breadcrumb">
    {%- render 'breadcrumb-article', _blog: blog, _craft_area: craft_area, _title: title -%}
  </div>
  <div class="header">
    <h1 class="u-heading-lg centre">{{- title -}}</h1>
    <ol>
      <li>
        {%- render 'icon', _name: 'icon-clock' -%}
        {{ 'template.article.read_time' | t }} <strong>{{ read_time | append: suffix }}</strong>
      </li>
      <li>
        {%- render 'icon', _name: 'icon-person' -%}
        {{ 'template.article.written_by' | t }} <strong>{{ author }}</strong>
      </li>
      <li>
        {%- render 'icon', _name: 'icon-calendar' -%}
        <time class="date">
          {{ 'template.article.published_on' | t }} <strong>{{ date -}}</strong>
        </time>
      </li>
    </ol>
  </div>
  {%- if image != blank and enable_featured_image == true -%}
    {{- image | image_url: width: 390 | image_tag: widths: '400, 600, 800', alt: image_alt, loading: 'eager', class: 'featured-image' -}}
  {%- endif -%}
  <div class="container">
    <div class="c-rte">
      {{- content -}}
    </div>
    {%- if author_image != blank and author_bio != blank -%}
      <div class="author">
        <figure class="author-image">
          {{- author_image | image_url: width: 80, height: 80 | image_tag: alt: author, loading: 'lazy' -}}
        </figure>
        <div class="author-details">
          <p class="u-text-xl name">{{ author_first_name }} {{ author_last_name }}</p>
          <p>{{- author_bio -}}</p>
          {%- if author_url != blank -%}
            <a href="{{- author_url -}}" class="c-btn alt primary">
              {{ 'template.article.read_more_posts' | t: name: author_first_name }}
              {% render 'icon', _name: 'icon-arrow-right' -%}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    <ol class="tags">
      {%- for tag in article.tags -%}
        {% liquid
          if tag contains '_'
            assign tag = tag | split: '_' | last
          endif
        %}
        <li>
          {{- tag | split: '_' | last | link_to_tag: tag -}}
        </li>
      {%- endfor -%}
    </ol>
    {%- render 'article-comments' -%}
  </div>
</div>

{% schema %}
{
  "name": "Article",
  "tag": "article",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_featured_image",
      "label": "Enable featured image",
      "default": false
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Article",
      "category": "Content"
    }
  ],
  "enabled_on": {
    "templates": ["article"]
  }
}
{% endschema %}
