{% schema %}
  {
    "name": "Customer Account",
    "tag": "section",
    "settings": [
      {
        "type": "header",
        "content": "Settings"
      }, {
        "type": "checkbox",
        "id": "enable_loyalty_section",
        "label": "Enable Loyalty Section",
        "default": false
      }, {
        "type": "checkbox",
        "id": "enable_loyalty_loading",
        "label": "Enable Loyalty Tier Loading Message?",
        "default": true
      }
    ],
    "blocks": []
  }
{% endschema %}