{% liquid
  assign template_name = 'section-list-blocks'

  assign list_blocks = section.blocks | map: 'settings'
  assign margin_bottom = section.settings.margin_bottom
%}


<div class="{{- template_name }} u-space-below-{{- margin_bottom }}" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="container">
    {% for list_block in list_blocks %}
      <div class="list-block">
        <span class="list-title">{{ list_block.title }}</span>
        {{ list_block.list }}
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
.section-list-blocks {
  position: relative;
}
.section-list-blocks .container {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media (min-width: 576px) {
  .section-list-blocks .container {
    grid-template-columns: 1fr 1fr;
  }
}
@media (min-width: 1024px) {
  .section-list-blocks .container {
    grid-template-columns: 1fr 1fr 1fr 1fr;
  }
}
.section-list-blocks .container .list-block {
  padding: 2rem;
  border: 1px solid var(--colour-emperor);
  border-radius: 1rem;
}
.section-list-blocks .container .list-block .list-title {
  display: block;
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.75rem;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid var(--colour-emperor);
  margin-bottom: 1.25rem;
}
.section-list-blocks .container .list-block ul {
  padding-left: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.section-list-blocks .container .list-block ul li {
  font-size: 1rem;
  font-weight: 600;
  line-height: 1.5rem;
}
{% endstylesheet %}

{% schema %}
{
  "name": "List Blocks",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Add margin below",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        }
      ],
      "default": "lg"
    }
  ],
  "blocks": [
    {
      "type": "list_block",
      "name": "List Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "list",
          "label": "List",
          "info": "Please use the list option in the richtext editor"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "List Blocks",
      "category": "Content"
    }
  ]
}
{% endschema %}
