<div id="custom-banner-{{ section.id }}" 
     class="custom-banner-test"
     style="
      --banner-width-desktop: {{ section.settings.banner_width_desktop }}%;
      --banner-width-mobile: {{ section.settings.banner_width_mobile }}%;
      
      --heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
      --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
      
      --subheading-size-desktop: {{ section.settings.subheading_size_desktop }}px;
      --subheading-size-mobile: {{ section.settings.subheading_size_mobile }}px;
      
      --heading-weight-desktop: {{ section.settings.heading_weight_desktop }};
      --heading-weight-mobile: {{ section.settings.heading_weight_mobile }};
      
      --subheading-weight-desktop: {{ section.settings.subheading_weight_desktop }};
      --subheading-weight-mobile: {{ section.settings.subheading_weight_mobile }};
      
      --heading-color: {{ section.settings.heading_color }};
      --subheading-color: {{ section.settings.subheading_color }};
      
      --text-width-desktop: {{ section.settings.text_width_desktop }}%;
      --text-width-mobile: {{ section.settings.text_width_mobile }}%;
      
      --button-bg: {{ section.settings.button_bg }};
      --button-text: {{ section.settings.button_color }};
      --button-weight-desktop: {{ section.settings.button_weight_desktop }};
      --button-weight-mobile: {{ section.settings.button_weight_mobile }};
      --button-size-desktop: {{ section.settings.button_size_desktop }}px;
      --button-size-mobile: {{ section.settings.button_size_mobile }}px;

      --content-gap-desktop: {{ section.settings.content_gap_desktop }}px;
      --content-gap-mobile: {{ section.settings.content_gap_mobile }}px;
     ">

  {% if section.settings.desktop_image %}
    <img src="{{ section.settings.desktop_image | img_url: '2048x' }}" class="desktop-banner-image">
  {% endif %}
  
  {% if section.settings.mobile_image %}
    <img src="{{ section.settings.mobile_image | img_url: '2048x' }}" class="mobile-banner-image">
  {% endif %}

  <div class="banner-content">
    
    {% if section.settings.heading %}
      <h2 class="banner-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.subheading %}
      <div class="banner-subheading">{{ section.settings.subheading }}</div>
    {% endif %}
    
    {% if section.settings.button_text and section.settings.button_link %}
      <a href="{{ section.settings.button_link }}" class="banner-button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
    
  </div>
</div>

<style>

/* GENERAL */

#custom-banner-{{ section.id }}{
  position: relative;
  margin: 0 auto;
}

#custom-banner-{{ section.id }} img{
  display:block;
  width:100%;
}

#custom-banner-{{ section.id }} .banner-content{
  position:absolute;
  top: {{ section.settings.content_top_desktop }}%;
  left: {{ section.settings.content_left_desktop }}%;
  transform: translate(-50%, -50%);
  text-align: {{ section.settings.content_position_desktop }};
  display:flex;
  flex-direction:column;
  align-items:center;
  gap: var(--content-gap-desktop);
}


/* DESKTOP */

@media screen and (min-width:768px){

  #custom-banner-{{ section.id }}{
    width: var(--banner-width-desktop);
  }

  #custom-banner-{{ section.id }} .desktop-banner-image{display:block;}
  #custom-banner-{{ section.id }} .mobile-banner-image{display:none;}

  #custom-banner-{{ section.id }} .banner-heading,
  #custom-banner-{{ section.id }} .banner-subheading{
    width: var(--text-width-desktop);
    margin: 0 auto;
  }

  #custom-banner-{{ section.id }} .banner-heading{
    font-size: var(--heading-size-desktop);
    font-weight: var(--heading-weight-desktop);
    color: var(--heading-color);
  }

  #custom-banner-{{ section.id }} .banner-subheading,
  #custom-banner-{{ section.id }} .banner-subheading p{
    font-size: var(--subheading-size-desktop);
    font-weight: var(--subheading-weight-desktop);
    color: var(--subheading-color);
  }

  #custom-banner-{{ section.id }} .banner-button{
    font-size: var(--button-size-desktop);
    font-weight: var(--button-weight-desktop);
    color: var(--button-text);
    background-color: var(--button-bg);
    padding:12px 28px;
    text-decoration:none;
    border-radius:4px;
    display:inline-block;
    transition:all .3s ease;
  }

  #custom-banner-{{ section.id }} .banner-button:hover{
    opacity:0.85;
  }

}


/* MOBILE */

@media screen and (max-width:767px){

  #custom-banner-{{ section.id }}{
    width: var(--banner-width-mobile);
  }

  #custom-banner-{{ section.id }} .desktop-banner-image{display:none;}
  #custom-banner-{{ section.id }} .mobile-banner-image{display:block;}

  #custom-banner-{{ section.id }} .banner-content{
    top: {{ section.settings.content_top_mobile }}%;
    left:50%;
    transform:translateX(-50%);
    text-align: {{ section.settings.content_position_mobile }};
    width:100%;
    gap: var(--content-gap-mobile);
  }

  #custom-banner-{{ section.id }} .banner-heading,
  #custom-banner-{{ section.id }} .banner-subheading{
    width: var(--text-width-mobile);
    margin:0 auto;
  }

  /* ✅ Fixed mobile font-size variables */
  #custom-banner-{{ section.id }} .banner-heading{
    font-size: var(--heading-size-mobile);
    font-weight: var(--heading-weight-mobile);
    color: var(--heading-color);
  }

  #custom-banner-{{ section.id }} .banner-subheading,
  #custom-banner-{{ section.id }} .banner-subheading p{
    font-size: var(--subheading-size-mobile);
    font-weight: var(--subheading-weight-mobile);
    color: var(--subheading-color);
    word-wrap: break-word;
  }

  #custom-banner-{{ section.id }} .banner-button{
    font-size: var(--button-size-mobile);
    font-weight: var(--button-weight-mobile);
    color: var(--button-text);
    background-color: var(--button-bg);
    padding:12px 28px;
    text-decoration:none;
    border-radius:4px;
    display:inline-block;
  }

  #custom-banner-{{ section.id }} .banner-button:hover{
    opacity:0.85;
  }

}

</style>
{% schema %}
{
  "name": "Custom Responsive Banner",
  "settings": [

    {"type":"image_picker","id":"desktop_image","label":"Desktop Banner Image"},
    {"type":"image_picker","id":"mobile_image","label":"Mobile Banner Image"},

    {"type":"text","id":"heading","label":"Heading","default":"Your Heading Here"},
    {"type":"richtext","id":"subheading","label":"Subheading"},

    {"type":"url","id":"button_link","label":"Button Link"},
    {"type":"text","id":"button_text","label":"Button Text","default":"Click Here"},

    {"type":"range","id":"banner_width_desktop","label":"Banner Width (Desktop %)","min":50,"max":100,"step":1,"default":100},
    {"type":"range","id":"content_top_desktop","label":"Content Top (Desktop %)","min":0,"max":100,"step":1,"default":50},
    {"type":"range","id":"content_left_desktop","label":"Content Left (Desktop %)","min":0,"max":100,"step":1,"default":50},

    {"type":"range","id":"text_width_desktop","label":"Desktop Text Width (%)","min":30,"max":100,"step":1,"default":60},

    {"type":"select","id":"content_position_desktop","label":"Content Alignment (Desktop)",
      "options":[
        {"value":"left","label":"Left"},
        {"value":"center","label":"Center"},
        {"value":"right","label":"Right"}
      ],
      "default":"center"
    },

    {"type":"range","id":"content_gap_desktop","label":"Content Spacing (Desktop px)","min":0,"max":100,"step":2,"default":20},

    {"type":"range","id":"heading_size_desktop","label":"Heading Size (Desktop px)","min":14,"max":80,"step":1,"default":36},
    {"type":"range","id":"subheading_size_desktop","label":"Subheading Size (Desktop px)","min":12,"max":60,"step":1,"default":20},
    {"type":"range","id":"button_size_desktop","label":"Button Size (Desktop px)","min":12,"max":36,"step":1,"default":16},

    {"type":"range","id":"heading_weight_desktop","label":"Heading Weight (Desktop)","min":100,"max":900,"step":100,"default":700},
    {"type":"range","id":"subheading_weight_desktop","label":"Subheading Weight (Desktop)","min":100,"max":900,"step":100,"default":400},
    {"type":"range","id":"button_weight_desktop","label":"Button Weight (Desktop)","min":100,"max":900,"step":100,"default":600},

    {"type":"range","id":"banner_width_mobile","label":"Banner Width (Mobile %)","min":50,"max":100,"step":1,"default":100},
    {"type":"range","id":"content_top_mobile","label":"Content Top (Mobile %)","min":0,"max":100,"step":1,"default":50},
    {"type":"range","id":"text_width_mobile","label":"Mobile Text Width (%)","min":50,"max":100,"step":1,"default":90},

    {"type":"select","id":"content_position_mobile","label":"Content Alignment (Mobile)",
      "options":[
        {"value":"left","label":"Left"},
        {"value":"center","label":"Center"},
        {"value":"right","label":"Right"}
      ],
      "default":"center"
    },

    {"type":"range","id":"content_gap_mobile","label":"Content Spacing (Mobile px)","min":0,"max":100,"step":2,"default":16},

    {"type":"range","id":"heading_size_mobile","label":"Heading Size (Mobile px)","min":12,"max":60,"step":1,"default":24},
    {"type":"range","id":"subheading_size_mobile","label":"Subheading Size (Mobile px)","min":10,"max":50,"step":1,"default":16},
    {"type":"range","id":"button_size_mobile","label":"Button Size (Mobile px)","min":10,"max":30,"step":1,"default":14},

    {"type":"range","id":"heading_weight_mobile","label":"Heading Weight (Mobile)","min":100,"max":900,"step":100,"default":700},
    {"type":"range","id":"subheading_weight_mobile","label":"Subheading Weight (Mobile)","min":100,"max":900,"step":100,"default":400},
    {"type":"range","id":"button_weight_mobile","label":"Button Weight (Mobile)","min":100,"max":900,"step":100,"default":600},

    {"type":"color","id":"heading_color","label":"Heading Color","default":"#000000"},
    {"type":"color","id":"subheading_color","label":"Subheading Color","default":"#333333"},
    {"type":"color","id":"button_color","label":"Button Text Color","default":"#ffffff"},
    {"type":"color","id":"button_bg","label":"Button Background Color","default":"#000000"}

  ],

  "presets":[
    {
      "name":"Custom Responsive Banner",
      "category":"Banner"
    }
  ]
}
{% endschema %}