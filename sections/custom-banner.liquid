{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    /* Video Options */
{
  "type": "checkbox",
  "id": "use_video",
  "label": "Use Video Instead of Image",
  "default": false
},
{
  "type": "video",
  "id": "desktop_video_file",
  "label": "Desktop Video Upload"
},
{
  "type": "video",
  "id": "mobile_video_file",
  "label": "Mobile Video Upload"
},
{
  "type": "video_url",
  "id": "desktop_video_url",
  "label": "Desktop Video URL (YouTube/Vimeo)",
  "accept": ["youtube", "vimeo"]
},
{
  "type": "video_url",
  "id": "mobile_video_url",
  "label": "Mobile Video URL (YouTube/Vimeo)",
  "accept": ["youtube", "vimeo"]
},

    /* Image Options */
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Banner Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Banner Image"
    },

    /* Button Options */
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },

    /* Desktop Position */
    {
      "type": "range",
      "id": "button_top_desktop",
      "label": "Button Vertical Position (Desktop %)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "range",
      "id": "button_left_desktop",
      "label": "Button Horizontal Position (Desktop %)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },

    /* Mobile Position */
    {
      "type": "range",
      "id": "button_top_mobile",
      "label": "Button Vertical Position (Mobile %)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "range",
      "id": "button_left_mobile",
      "label": "Button Horizontal Position (Mobile %)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },

    /* Desktop Styles */
    {
      "type": "range",
      "id": "button_padding_desktop",
      "label": "Button Padding (Desktop px)",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "button_border_radius_desktop",
      "label": "Button Corner Roundness (Desktop px)",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "button_width_desktop",
      "label": "Button Width (Desktop px)",
      "min": 50,
      "max": 500,
      "step": 5,
      "default": 200
    },

    /* Mobile Styles */
    {
      "type": "range",
      "id": "button_padding_mobile",
      "label": "Button Padding (Mobile px)",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "button_border_radius_mobile",
      "label": "Button Corner Roundness (Mobile px)",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "button_width_mobile",
      "label": "Button Width (Mobile px)",
      "min": 50,
      "max": 300,
      "step": 5,
      "default": 150
    }
  ],
  "presets": [
    {
      "name": "Custom Banner",
      "category": "Banner"
    }
  ]
}
{% endschema %}

{% stylesheet %}
.custom-banner {
  position: relative;
  width: 100%;
  overflow: hidden;
}
.custom-banner img,
.custom-banner__video {
  width: 100%;
  display: block;
  height: auto;
}
.custom-banner iframe.custom-banner__video {
  width: 100%;
  height: 100%;
}
.custom-banner__button {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transform: translate(-50%, -50%);
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
}

/* Mobile Styles */
@media screen and (max-width: 768px) {
  .custom-banner .desktop-image,
  .custom-banner .desktop-video { display: none; }
  .custom-banner .mobile-image,
  .custom-banner .mobile-video { display: block; }

  .custom-banner__button {
    top: var(--button-top-mobile, 50%);
    left: var(--button-left-mobile, 50%);
    padding: var(--button-padding-mobile, 10px) 24px;
    border-radius: var(--button-radius-mobile, 4px);
    width: var(--button-width-mobile, 150px);
  }
}

/* Desktop Styles */
@media screen and (min-width: 769px) {
  .custom-banner .mobile-image,
  .custom-banner .mobile-video { display: none; }
  .custom-banner .desktop-image,
  .custom-banner .desktop-video { display: block; }

  .custom-banner__button {
    top: var(--button-top-desktop, 50%);
    left: var(--button-left-desktop, 50%);
    padding: var(--button-padding-desktop, 12px) 24px;
    border-radius: var(--button-radius-desktop, 5px);
    width: var(--button-width-desktop, 200px);
  }
}
{% endstylesheet %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap');
</style>

<div class="custom-banner">
  {% if section.settings.use_video %}
    {%- comment -%} Desktop Video {%- endcomment -%}
    {% if section.settings.desktop_video_file != blank %}
      {{ section.settings.desktop_video_file | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'custom-banner__video desktop-video' }}
    {% elsif section.settings.desktop_video_url != blank %}
      {{ section.settings.desktop_video_url | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'custom-banner__video desktop-video' }}
    {% endif %}

    {%- comment -%} Mobile Video {%- endcomment -%}
    {% if section.settings.mobile_video_file != blank %}
      {{ section.settings.mobile_video_file | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'custom-banner__video mobile-video' }}
    {% elsif section.settings.mobile_video_url != blank %}
      {{ section.settings.mobile_video_url | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'custom-banner__video mobile-video' }}
    {% endif %}
  {% else %}
    {% if section.settings.desktop_image %}
      <img src="{{ section.settings.desktop_image | image_url: width: 2048, height: 2048 }}" alt="Banner" class="desktop-image">
    {% endif %}
    {% if section.settings.mobile_image %}
      <img src="{{ section.settings.mobile_image | image_url: width: 2048, height: 2048 }}" alt="Banner" class="mobile-image">
    {% endif %}
  {% endif %}

  {% if section.settings.button_text and section.settings.button_link %}
    <a href="{{ section.settings.button_link }}" 
       class="custom-banner__button"
       style="
        --button-top-desktop: {{ section.settings.button_top_desktop }}%;
        --button-left-desktop: {{ section.settings.button_left_desktop }}%;
        --button-top-mobile: {{ section.settings.button_top_mobile }}%;
        --button-left-mobile: {{ section.settings.button_left_mobile }}%;
        background-color: {{ section.settings.button_bg_color }};
        color: {{ section.settings.button_text_color }};
        --button-padding-desktop: {{ section.settings.button_padding_desktop }}px;
        --button-radius-desktop: {{ section.settings.button_border_radius_desktop }}px;
        --button-width-desktop: {{ section.settings.button_width_desktop }}px;
        --button-padding-mobile: {{ section.settings.button_padding_mobile }}px;
        --button-radius-mobile: {{ section.settings.button_border_radius_mobile }}px;
        --button-width-mobile: {{ section.settings.button_width_mobile }}px;
       ">
      {{ section.settings.button_text }}
    </a>
  {% endif %}
</div>

