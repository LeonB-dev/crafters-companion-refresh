{% comment %}
Custom Image Section with desktop/mobile images, adjustable width, and fully positionable overlay content
{% endcomment %}

<section class="custom-image-section" style="--content-x: {{ section.settings.content_x }}%; --content-y: {{ section.settings.content_y }}%; --content-align: {{ section.settings.text_align }};">
  <div class="image-wrapper" style="max-width: {{ section.settings.desktop_width }}%;">

    {% if section.settings.desktop_image != blank %}
      <img
        class="desktop-image"
        src="{{ section.settings.desktop_image | image_url: width: 2000 }}"
        alt="{{ section.settings.desktop_image.alt | escape }}"
        loading="lazy"
      >
    {% endif %}

    {% if section.settings.mobile_image != blank %}
      <img
        class="mobile-image"
        src="{{ section.settings.mobile_image | image_url: width: 1000 }}"
        alt="{{ section.settings.mobile_image.alt | escape }}"
        loading="lazy"
      >
    {% endif %}

    <div class="overlay-content">
      {% if section.settings.title != blank %}
        <h2 class="title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <p class="subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

  </div>
</section>

<style>
.custom-image-section {
  display: flex;
  justify-content: center;
  padding: {{ section.settings.section_padding }}px 0;
}

.image-wrapper {
  position: relative;
  width: 100%;
}

.desktop-image,
.mobile-image {
  width: 100%;
  height: auto;
  display: block;
}

.mobile-image {
  display: none;
}

.overlay-content {
  position: absolute;
  top: var(--content-y);
  left: var(--content-x);
  transform: translate(-50%, -50%);
  text-align: var(--content-align);
  color: {{ section.settings.text_color }};
}

.title {
  font-size: {{ section.settings.title_size }}px;
  font-weight: {{ section.settings.title_weight }};
  margin-bottom: 0.5em;
}

.subtitle {
  font-size: {{ section.settings.subtitle_size }}px;
  font-weight: {{ section.settings.subtitle_weight }};
  margin-bottom: 1em;
}

.btn {
  display: inline-block;
  padding: 12px 24px;
  background: {{ section.settings.button_bg }};
  color: {{ section.settings.button_text }};
  text-decoration: none;
  border-radius: {{ section.settings.button_radius }}px;
}

@media (max-width: 768px) {
  .desktop-image {
    display: none;
  }

  .mobile-image {
    display: block;
  }

  .image-wrapper {
    max-width: 100% !important;
  }
} 
</style>

{% schema %}
{
  "name": "Custom Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "range",
      "id": "desktop_width",
      "label": "Desktop image width (%)",
      "min": 50,
      "max": 100,
      "step": 1,
      "default": 100
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "content_x",
      "label": "Content horizontal position (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "range",
      "id": "content_y",
      "label": "Content vertical position (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title font size (px)",
      "min": 16,
      "max": 80,
      "default": 36
    },
    {
      "type": "range",
      "id": "title_weight",
      "label": "Title font weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle font size (px)",
      "min": 12,
      "max": 40,
      "default": 18
    },
    {
      "type": "range",
      "id": "subtitle_weight",
      "label": "Subtitle font weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 50,
      "default": 4
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section vertical padding",
      "min": 0,
      "max": 100,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Custom Image Hero"
    }
  ]
}
{% endschema %}