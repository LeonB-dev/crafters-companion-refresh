{%- liquid
  assign template_name = 'section-swym'
%}

<div class="{{- template_name -}}" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="container">{{ page.content }}</div>
</div>

{% stylesheet %}
#wrapper .swym-wishlist-container-title-bar {
  border: 0;
  display: flex;
  flex-direction: column;
  padding: 0;
}
#wrapper .swym-wishlist-container-title-bar .swym-wishlist-main-title {
  font-family: var(--font-family-heading);
  font-size: clamp(2rem, 0.7vw + 1.9rem, 2.5rem);
  margin-bottom: 1.5rem;
  line-height: normal;
  font-weight: 500;
  letter-spacing: 0;
}
#wrapper .swym-wishlist-container-title-bar .swym-user-login-status::before {
  display: none;
}
#wrapper .swym-wishlist-container-content * {
  font-family: var(--font-family-base);
}
#wrapper .swym-wishlist-container-content .swym-wishlist-selector {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 2rem;
}
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card {
  margin: 0;
  box-shadow: none;
  border: 1px solid var(--colour-emperor);
  border-radius: var(--border-radius-lg);
}
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card .swym-wishlist-header,
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card .swym-wishlist-product-count {
  display: flex;
  justify-content: center;
}
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card .swym-wishlist-header {
  padding: 1.5rem 1.5rem 1rem;
  font-size: 1.25rem;
  font-weight: 500;
}
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card .swym-wishlist-header .swym-wishlist-name {
  font-weight: 500;
}
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card .swym-wishlist-product-count {
  font-size: 0.875rem;
}
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card .swym-wishlist-link {
  position: relative;
  padding-right: 2rem;
  text-transform: capitalize;
  font-weight: 500;
}
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card .swym-wishlist-link::after {
  content: "";
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  background-image: url("data:image/svg+xml,%3Csvg width='100%25' height='100%25' viewBox='0 0 17 9' version='1.1' xmlns='http://www.w3.org/2000/svg' xmlns:xlink='http://www.w3.org/1999/xlink' xml:space='preserve' xmlns:serif='http://www.serif.com/' style='fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2;'%3E%3Cg transform='matrix(1,0,0,1,-0.5,-0.500096)'%3E%3Cpath d='M6.342,4.515L4.205,4.515C3.929,4.515 3.705,4.739 3.705,5.015C3.705,5.291 3.929,5.515 4.205,5.515L6.342,5.515C6.618,5.515 6.842,5.291 6.842,5.015C6.842,4.739 6.618,4.515 6.342,4.515Z'/%3E%3C/g%3E%3Cg transform='matrix(1,0,0,1,-0.5,-0.500096)'%3E%3Cpath d='M2.068,4.515L1,4.515C0.724,4.515 0.5,4.739 0.5,5.015C0.5,5.291 0.724,5.515 1,5.515L2.068,5.515C2.344,5.515 2.568,5.291 2.568,5.015C2.568,4.739 2.344,4.515 2.068,4.515Z'/%3E%3C/g%3E%3Cg transform='matrix(1,0,0,1,-0.5,-0.500096)'%3E%3Cpath d='M15.843,4.5L8.478,4.515C8.202,4.515 7.979,4.74 7.979,5.016C7.98,5.292 8.204,5.515 8.48,5.515L15.843,5.5C14.9,6.502 12.871,8.657 12.871,8.657C12.682,8.858 12.692,9.175 12.893,9.364C13.094,9.553 13.41,9.544 13.599,9.343L17.364,5.343C17.455,5.246 17.5,5.122 17.5,4.999L17.5,4.997C17.5,4.852 17.438,4.722 17.339,4.63L13.599,0.657C13.41,0.456 13.094,0.447 12.893,0.636C12.692,0.825 12.682,1.142 12.871,1.343L15.843,4.5Z'/%3E%3C/g%3E%3C/svg%3E");
  background-size: 1rem;
  background-repeat: no-repeat;
  background-position: center;
  height: 1rem;
  width: 1rem;
}
#wrapper .swym-wishlist-container-content .swym-wishlist-list-card .swym-empty-wishlist-list {
  font-weight: 400;
  font-size: 0.875rem;
}
#wrapper .swym-wishlist-detail-header {
  padding: 1rem 0;
  gap: 1rem;
  background-color: transparent;
  border: 0;
  display: flex;
  justify-content: center;
}
@media (min-width: 768px) {
  #wrapper .swym-wishlist-detail-header {
    gap: 2rem;
  }
}
#wrapper .swym-wishlist-detail-header .swym-spacer {
  display: none;
}
#wrapper .swym-wishlist-selector-dropdown {
  margin: 0;
  display: none;
}
#wrapper .swym-ui-component .swym-wishlist-detail-separator {
  display: none;
}
#wrapper .swym-ui-component .swym-wishlist-context-menu .swym-wishlist-context-menu-bg {
  background-color: transparent;
}
#wrapper .swym-wishlist-context-menu-content {
  background-color: var(--colour-white);
  border: 1px solid var(--colour-emperor);
  border-radius: var(--border-radius-sm);
  box-shadow: none;
  right: 2.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 1.5rem;
}
@media only screen and (max-width: 900px) {
  #wrapper .swym-wishlist-context-menu-content {
    width: calc(100% - 2rem);
    left: 1rem;
    bottom: 1rem;
    padding: 1rem;
  }
}
#wrapper .swym-wishlist-context-menu-content::after {
  display: none;
}
#wrapper .swym-wishlist-context-menu-content .swym-wishlist-context-menu-item {
  padding: 0 !important;
  border-color: var(--colour-whisper);
}
@media only screen and (max-width: 900px) {
  #wrapper .swym-wishlist-context-menu-content .swym-wishlist-context-menu-item:first-of-type {
    padding-bottom: 1rem !important;
  }
}
#wrapper .swym-wishlist-context-menu {
  margin: 0;
}
#wrapper .swym-action-container {
  position: relative;
  top: auto;
  right: auto;
}
#wrapper .swym-share-btn {
  border: 0;
  margin: 0;
}
#wrapper .swym-action-bar {
  display: flex;
  justify-content: center;
  padding: 0 0 1rem;
}
#wrapper .swym-action-bar .swym-back-btn span {
  font-size: 0.675rem;
}
#wrapper .swym-wishlist-grid {
  display: grid;
  gap: 1rem;
  grid-template-columns: 1fr 1fr;
  padding: 0;
  margin-bottom: 3rem;
}
@media (min-width: 768px) {
  #wrapper .swym-wishlist-grid {
    grid-template-columns: 1fr 1fr 1fr;
  }
}
@media (min-width: 1280px) {
  #wrapper .swym-wishlist-grid {
    margin-bottom: 3rem;
  }
}
#wrapper .swym-wishlist-grid li {
  width: 100%;
  margin: 0;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item {
  border-radius: var(--border-radius-lg);
  border-color: var(--colour-emperor);
  margin: 0;
  justify-content: flex-start;
  overflow: hidden;
  width: 100%;
  height: 100%;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-delete-btn {
  top: 0;
  right: 0;
  height: 2.5rem;
  width: 2.5rem;
  background-color: var(--colour-emperor);
  border-bottom-left-radius: var(--border-radius-lg);
  border-width: 0 0 1px 1px;
  border-style: solid;
  border-color: var(--colour-emperor);
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-delete-btn .swym-icon {
  display: flex;
  align-items: center;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-delete-btn .swym-icon::before {
  color: var(--colour-white);
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-wishlist-image-wrapper {
  height: -webkit-fit-content;
  height: -moz-fit-content;
  height: fit-content;
  max-height: none;
  margin-bottom: 1rem;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-wishlist-image-wrapper img {
  aspect-ratio: 1;
  display: block;
  height: auto;
  width: 100%;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-is-button {
  flex-grow: 1;
  display: flex;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-is-button .swym-title {
  padding: 0 1rem;
  margin: 0;
  white-space: normal;
  font-weight: 500;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-variant-title {
  display: none;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-product-price {
  padding: 0 1rem 1rem;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item .swym-product-final-price {
  font-weight: 500;
  font-size: 1rem;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item button.swym-add-to-cart-btn {
  background-color: var(--colour-emperor) !important;
  color: var(--colour-white) !important;
  padding: 0.75rem 1rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 15;
  height: 2.675rem;
  max-height: 2.675rem;
  text-transform: none !important;
  font-weight: 400 !important;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item button.swym-add-to-cart-btn:disabled {
  opacity: 1 !important;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item button.swym-add-to-cart-btn.swym-disabled {
  background-color: var(--colour-emperor) !important;
  color: var(--colour-white) !important;
}
#wrapper .swym-wishlist-grid .swym-wishlist-item button.swym-add-to-cart-btn:hover:not(.swym-disabled) {
  text-decoration: underline;
  opacity: 1 !important;
}
#wrapper .swym-wishlist-product-detail-container {
  padding: 0;
  margin-bottom: 3rem;
}
@media (min-width: 1280px) {
  #wrapper .swym-wishlist-product-detail-container {
    width: 80vw;
    max-width: 960px;
    margin: 0 auto;
  }
}
#wrapper .swym-wishlist-product-detail-container .swym-image-thumbnails {
  height: 20rem;
  overflow-y: auto;
}
@media (max-width: 767.98px) {
  #wrapper .swym-wishlist-product-detail-container .swym-image-thumbnails {
    display: none;
  }
}
#wrapper .swym-wishlist-product-detail-container .swym-wishlist-product-detail-image-container {
  margin: 0;
}
#wrapper .swym-wishlist-product-detail-container .swym-wishlist-product-detail-content {
  background-color: var(--colour-white);
  border: 1px solid var(--colour-emperor);
  padding: 2rem;
  border-radius: var(--border-radius-lg);
}
#wrapper .swym-wishlist-product-detail-container .swym-wishlist-product-detail-info {
  padding: 0;
}
@media (min-width: 768px) {
  #wrapper .swym-wishlist-product-detail-container .swym-wishlist-product-detail-info {
    display: grid;
    grid-template-columns: 56% 1fr;
    gap: 2rem;
  }
}
#wrapper .swym-wishlist-product-detail-container .react-swipeable-view-container > div {
  display: flex;
  justify-content: center;
}
#wrapper .swym-wishlist-product-detail-container .react-swipeable-view-container > div img {
  aspect-ratio: 1;
  object-fit: contain;
}
@media (min-width: 768px) {
  #wrapper .swym-wishlist-product-detail-container .react-swipeable-view-container > div img {
    width: 100%;
  }
}
#wrapper .swym-wishlist-product-detail-container .swym-image-full {
  margin: 0;
  width: 100%;
}
#wrapper .swym-wishlist-product-detail-container .swym-action-button-container {
  display: none;
}
#wrapper .swym-wishlist-product-detail-container .swym-wishlist-product-detail-text-container * {
  font-weight: 500;
  font-size: 1rem;
  line-height: 1.4;
}
@media (max-width: 767.98px) {
  #wrapper .swym-wishlist-product-detail-container .swym-wishlist-product-detail-text-container * {
    text-align: center;
  }
}
@media (min-width: 768px) {
  #wrapper .swym-wishlist-product-detail-container .swym-wishlist-product-detail-text-container .swym-wishlist-product-title {
    font-size: 1.5rem;
    font-weight: 600;
  }
}
#wrapper .swym-wishlist-product-detail-container .swym-more-details {
  margin-bottom: 0;
}
@media (min-width: 768px) {
  #wrapper .swym-wishlist-product-detail-container .swym-more-details {
    margin-top: 2rem;
  }
}
#wrapper .swym-wishlist-product-detail-container .swym-more-details a {
  text-decoration: underline;
  font-size: 0.875rem;
}
#wrapper .swym-wishlist-product-detail-tab-bar {
  box-shadow: none;
  margin-top: 2rem;
  background-color: transparent;
}
#wrapper .swym-wishlist-product-detail-tab-bar button.swym-product-tab {
  background-color: var(--colour-emperor);
  height: 0.5rem;
  width: 0.5rem;
}
#wrapper .swym-wishlist-product-detail-tab-bar button.swym-product-tab.swym-selected {
  background-color: var(--colour-royal-purple);
}
#wrapper .swym-empty-wishlist-container .swym-empty-wishlist-title {
  font-size: 2rem;
  margin-bottom: 1.5rem;
  line-height: normal;
  font-weight: 500;
  text-align: center;
}
#wrapper .swym-empty-wishlist-container .swym-empty-wishlist-text {
  text-align: center;
}
#wrapper .swym-empty-wishlist-container .swym-button {
  border-radius: var(--border-radius-xl);
  height: 3rem;
  padding: 0 2rem;
  font-size: 1rem;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  transform: none;
  transition: all var(--transition-duration) var(--transition-timing) 0s;
  background-color: var(--colour-emperor);
  color: var(--colour-white) !important;
}
#wrapper .swym-empty-wishlist-container .swym-button:hover, #wrapper .swym-empty-wishlist-container .swym-button:focus {
  transform: scale(1.1);
}
#wrapper .swym-share-wishlist-modal .swym-share-wishlist-modal-dialog {
  padding: 0;
  box-shadow: none;
  position: static;
}
#wrapper .swym-share-wishlist-modal .swym-text-heading {
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
  line-height: normal;
  font-weight: 500;
}
#wrapper .swym-share-wishlist-login-modal .swym-share-wishlist-login-modal-dialog {
  padding: 0;
  box-shadow: none;
  position: static;
}
#wrapper .swym-share-wishlist-login-modal .swym-text-heading {
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
  line-height: normal;
  font-weight: 500;
}
#wrapper .swym-share-wishlist-login-modal .swym-button {
  border-radius: var(--border-radius-xl);
  height: 3rem;
  padding: 0 2rem;
  font-size: 1rem;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  transform: none;
  transition: all var(--transition-duration) var(--transition-timing) 0s;
  background-color: var(--colour-emperor);
  color: var(--colour-white) !important;
  justify-content: center;
}
#wrapper .swym-share-wishlist-login-modal .swym-button:hover, #wrapper .swym-share-wishlist-login-modal .swym-button:focus {
  transform: scale(1.1);
}

.swym-add-all-to-cart-btn.swym-button.swym-button-1 {
  text-decoration: none;
  color: inherit;
  background: transparent;
  border: 0;
  -webkit-appearance: none;
          appearance: none;
  width: -webkit-max-content;
  width: max-content;
  border: 1px solid var(--colour-sugar-cane);
  background-color: var(--colour-emperor);
  color: var(--colour-sugar-cane);
  border-radius: var(--border-radius-xl);
  height: 3rem;
  padding: 0 2rem;
  font-size: 1rem;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  background-color: transparent;
  transform: none;
  transition: all var(--transition-duration) var(--transition-timing) 0s;
}
.swym-add-all-to-cart-btn.swym-button.swym-button-1:focus {
  outline: none;
}
.swym-add-all-to-cart-btn.swym-button.swym-button-1:hover {
  text-decoration: none;
  outline: none;
}
.swym-add-all-to-cart-btn.swym-button.swym-button-1:disabled {
  opacity: 0.5;
  pointer-events: none;
}
.swym-add-all-to-cart-btn.swym-button.swym-button-1:hover, .swym-add-all-to-cart-btn.swym-button.swym-button-1:focus {
  transform: scale(1.1);
}
{% endstylesheet %}
