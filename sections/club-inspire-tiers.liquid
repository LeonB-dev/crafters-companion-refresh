{%- liquid
  assign template_name = 'section-club-inspire-tiers'

  assign heading = section.settings.heading
  assign header_text = section.settings.header_text
  assign image = section.settings.image

  assign promo_heading = section.settings.promo_heading

  assign margin_bottom = section.settings.margin_bottom
-%}


<div class="{{- template_name }} u-space-below-{{- margin_bottom }}" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="container">
    {%-
      render 'section-header',
      _heading: heading,
      _image: image,
      _offset: true,
      _text: header_text
    -%}
    <div class="tier-blocks u-space-below-md">
      <div class="tier pearl">
        <h2 class="u-heading-sm heading"><span>{{- settings.pearl_title -}}</span></h2>
        <p class="u-text-xl points"><strong>{{- 'template.customers.loyalty.points' | t: points: settings.pearl_points -}}</strong></p>
        <p class="benefits"><small>{{- 'template.customers.loyalty.benefits' | t -}}</small></p>
        <ul class="c-check-list red">
          <li>{{- 'template.customers.loyalty.pearl_discount' | t: discount: settings.first_order_discount -}}</li>
        </ul>
      </div>
      <div class="tier bronze">
        <h2 class="u-heading-sm heading"><span>{{- settings.bronze_title -}}</span></h2>
        <p class="u-text-xl points"><strong>{{- 'template.customers.loyalty.points' | t: points: settings.bronze_points -}}</strong></p>
        <p class="benefits"><small>{{- 'template.customers.loyalty.benefits' | t -}}</small></p>
        <ul class="c-check-list red">
          <li>{{- 'template.customers.loyalty.percent_off_orders' | t: discount: settings.bronze_discount -}}</li>
        </ul>
      </div>
      <div class="tier silver">
        <h2 class="u-heading-sm heading"><span>{{- settings.silver_title -}}</span></h2>
        <p class="u-text-xl points"><strong>{{- 'template.customers.loyalty.points' | t: points: settings.silver_points -}}</strong></p>
        <p class="benefits"><small>{{- 'template.customers.loyalty.benefits' | t -}}</small></p>
        <ul class="c-check-list red">
          <li>{{- 'template.customers.loyalty.percent_off_orders' | t: discount: settings.silver_discount -}}</li>
        </ul>
      </div>
      <div class="tier gold">
        <h2 class="u-heading-sm heading"><span>{{- settings.gold_title -}}</span></h2>
        <p class="u-text-xl points"><strong>{{- 'template.customers.loyalty.points' | t: points: settings.gold_points -}}</strong></p>
        <p class="benefits"><small>{{- 'template.customers.loyalty.benefits' | t -}}</small></p>
        <ul class="c-check-list red">
          <li>{{- 'template.customers.loyalty.percent_off_orders' | t: discount: settings.gold_discount -}}</li>
        </ul>
      </div>
      <div class="tier platinum">
        <h2 class="u-heading-sm heading"><span>{{- settings.platinum_title -}}</span></h2>
        <p class="u-text-xl points"><strong>{{- 'template.customers.loyalty.points' | t: points: settings.platinum_points -}}</strong></p>
        <p class="benefits"><small>{{- 'template.customers.loyalty.benefits' | t -}}</small></p>
        <ul class="c-check-list red">
          <li>{{- 'template.customers.loyalty.percent_off_orders' | t: discount: settings.platinum_discount -}}</li>
        </ul>
      </div>
    </div>
    <div class="message">
      <h2 class="u-heading-sm heading">{{- promo_heading -}}</h2>
      <div class="actions">
        <a href="{{- routes.account_register_url -}}" class="c-btn main quinary">
          {{- 'template.customers.loyalty.sign_up_text' | t -}}
        </a>
        <a href="{{- routes.account_login_url -}}" class="c-btn alt primary">
          {{- 'template.customers.loyalty.sign_in_text' | t -}}
          {%- render 'icon', _name: 'icon-arrow-right' -%}
        </a>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
@media (min-width: 576px) and (max-width: 1023.98px) {
  .section-club-inspire-tiers .container {
    padding: 0;
  }
}
@media (min-width: 576px) and (max-width: 1023.98px) {
  .section-club-inspire-tiers .snippet-section-header {
    padding: 0 1rem;
  }
}
.section-club-inspire-tiers .tier-blocks {
  display: flex;
  gap: 1rem;
  padding-top: 1rem;
}
@media (max-width: 767.98px) {
  .section-club-inspire-tiers .tier-blocks {
    flex-direction: column;
  }
}
@media (min-width: 576px) and (max-width: 1023.98px) {
  .section-club-inspire-tiers .tier-blocks {
    padding: 0 1rem 2rem;
  }
}
@media (min-width: 1024px) and (max-width: 1279.98px) {
  .section-club-inspire-tiers .tier-blocks {
    padding: 0 0 2rem;
  }
}
@media (min-width: 576px) and (max-width: 1279.98px) {
  .section-club-inspire-tiers .tier-blocks {
    overflow-x: auto;
  }
  .section-club-inspire-tiers .tier-blocks::-webkit-scrollbar {
    width: 12px;
    height: 12px;
  }
  .section-club-inspire-tiers .tier-blocks::-webkit-scrollbar-thumb {
    background: var(--colour-royal-purple);
    border: 8px solid var(--colour-royal-purple);
    border-radius: 0;
  }
  .section-club-inspire-tiers .tier-blocks::-webkit-scrollbar-track {
    background: var(--colour-whisper);
  }
}
.section-club-inspire-tiers .tier {
  border-radius: var(--border-radius-lg);
  border: 1px solid var(--colour-emperor);
  background-color: var(--colour-white);
  padding: 2rem;
}
@media (min-width: 768px) {
  .section-club-inspire-tiers .tier {
    flex: 1;
  }
}
@media (min-width: 768px) and (max-width: 1279.98px) {
  .section-club-inspire-tiers .tier {
    min-width: 16rem;
  }
}
.section-club-inspire-tiers .tier .heading {
  position: relative;
  margin-bottom: 1.5rem;
}
.section-club-inspire-tiers .tier .heading::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 0;
  height: 3.5rem;
  width: 3.5rem;
  transform: translate(-1rem, -50%);
  background-image: url("data:image/svg+xml,%3Csvg width='457' height='448' viewBox='0 0 457 448' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0.0146598 223.956C1.40989 345.015 100.131 442.71 221.701 442.71C274.006 442.71 322.049 424.603 359.952 394.338C370.044 386.285 384.73 396.151 381.04 408.513C377.721 419.627 373.513 430.536 368.4 441.134C366.181 445.711 371.778 450.123 375.717 446.89C382.36 441.419 388.761 435.491 394.849 429.132C457.918 363.245 469.863 264.425 444.708 178.419C436.61 150.742 424.665 124.367 409.342 100.869C387.403 67.2049 355.933 38.9849 319.511 21.8241C290.185 8.00974 257.983 0.559676 225.569 0.0322774C224.373 0.0109749 223.167 8.92915e-07 221.971 8.92915e-07C99.3815 -0.0109731 -1.39738 101.133 0.0146598 223.956Z' fill='%23F25F5C'/%3E%3C/svg%3E%0A");
  background-size: contain;
  background-repeat: no-repeat;
  opacity: 0.12;
  z-index: 1;
}
.section-club-inspire-tiers .tier .heading span {
  position: relative;
  z-index: 5;
}
.section-club-inspire-tiers .tier .points,
.section-club-inspire-tiers .tier .benefits {
  margin-bottom: 1rem;
}
.section-club-inspire-tiers .c-check-list li {
  display: block;
}
.section-club-inspire-tiers .message {
  max-width: 50rem;
}
@media (max-width: 1023.98px) {
  .section-club-inspire-tiers .message {
    padding: 0 1rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
}
@media (min-width: 1024px) {
  .section-club-inspire-tiers .message {
    padding-left: 7.5rem;
    box-sizing: content-box;
  }
}
@media (min-width: 1280px) {
  .section-club-inspire-tiers .message {
    padding-left: 10.5rem;
  }
}
.section-club-inspire-tiers .message .heading strong {
  color: var(--colour-carnation);
}
.section-club-inspire-tiers .message .actions {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}
.section-club-inspire-tiers .message .actions .alt {
  font-size: 1rem;
  font-weight: 500;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Club Inspire - Tiers",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "header_text",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Promotion Message"
    },
    {
      "type": "inline_richtext",
      "id": "promo_heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Add margin below",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        }
      ],
      "default": "lg"
    }
  ],
  "blocks": [
  ]
}
{% endschema %}
