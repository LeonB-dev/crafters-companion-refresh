{%- liquid
  assign template_name = 'section-latest-articles'

  assign margin_bottom = section.settings.margin_bottom
%}

{{- 'snippet-article-item.css' | asset_url | stylesheet_tag -}}

<div class="{{- template_name }} u-space-below-{{- margin_bottom }} overflow-hidden" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  {%-
    render 'paper-edge',
    _section: section
  -%}
  <div class="container">
    {%-
      render 'section-header',
      _image: section.settings.image,
      _heading: section.settings.heading
      _text: section.settings.text
      _offset: true,
      _heading_class: 'u-heading-xs',
      _link_url: section.settings.link_url
      _link_text: section.settings.link_text
      _loading: 'lazy'
    -%}
    <div class="articles">
      {% for article in section.settings.blog.articles limit: 6 %}
        {%-
          render 'article-item',
          _article: article
        -%}
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
.section-latest-articles .snippet-section-header {
  margin-bottom: 2.5rem;
}
.section-latest-articles .articles {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media (min-width: 576px) {
  .section-latest-articles .articles {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (min-width: 1024px) {
  .section-latest-articles .articles {
    grid-template-columns: repeat(3, 1fr);
  }
}
{% endstylesheet %}

