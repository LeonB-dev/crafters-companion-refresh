{% liquid
  assign template_name = 'section-customer-order'
  assign title = 'template.customers.account.welcome' | t: name: customer.first_name
%}

{{- 'section-customer.css' | asset_url | stylesheet_tag -}}
{{- 'section-customer-order.css' | asset_url | stylesheet_tag -}}

<div class="section-customer {{ template_name -}}" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="container">
    {%- render 'customer-header', _title: 'Order details', _subheading: order.name -%}
    {%- render 'customer-aside', customer: customer, _account_link: true -%}
    <div class="content">
      <div class="addresses">
        <dl class="billing">
          <dt>Billing Address</dt>
          <dd>
            <address>
              {{- order.billing_address | format_address | remove: '<p>' | remove: '</p>' -}}
            </address>
          </dd>
        </dl>
        {%- if order.shipping_address -%}
          <dl class="shipping">
            <dt>Shipping Address</dt>
            <dd>
              <address>
                {{- order.shipping_address | format_address | remove: '<p>' | remove: '</p>' -}}
              </address>
            </dd>
          </dl>
        {%- endif -%}
      </div>
      <div class="details">
        <dl>
          <dt>Order Placed:</dt>
          <dd>{{ order.created_at | date: '%B %d, %Y %I:%M%p' }}</dd>
        </dl>
        {%- if order.cancelled -%}
          <dl>
            <dt>Cancelled On:</dt>
            <dd>
              {{ order.cancelled_at | date: '%B %d, %Y %I:%M%p' -}}
              <br>
              {{ order.cancel_reason }}
            </dd>
          </dl>
        {%- endif -%}
        <dl>
          <dt>Payment Status:</dt>
          <dd>{{ order.financial_status | capitalize }}</dd>
        </dl>
        <dl>
          <dt>Fulfillment Status:</dt>
          <dd>

            {%- if line_item.fulfillment -%}
              <p>
                Fulfilled {{ line_item.fulfillment.created_at | date: '%b %d' }}
                {% if line_item.fulfillment.tracking_number %}
                  <br>
                  <a href="{{ line_item.fulfillment.tracking_url }}">{{ line_item.fulfillment.tracking_company }} #{{ line_item.fulfillment.tracking_number }}</a>
                {% endif %}
              </p>
            {% else %}
              Unfulfilled
            {%- endif -%}
          </dd>
        </dl>
        <div class="c-table">
          <table>
            <thead>
              <tr>
                <th class="product">Product</th>
                <th class="sku">SKU</th>
                <th class="price">Price</th>
                <th class="quantity">Quantity</th>
                <th class="total">Total</th>
              </tr>
            </thead>
            <tbody>
              {% for line_item in order.line_items %}
                <tr id="{{ line_item.id }}" class="{% cycle 'odd', 'even' %}">
                  <td class="product">
                    {% assign image = line_item.image | default: blank %}
                    {% if image == blank %}
                      {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
                    {% else %}
                      {{ line_item.image | image_url: width: 200 | image_tag }}
                    {% endif %}
                    {{ line_item.title | link_to: line_item.product.url }}
                  </td>
                  <td class="sku">{{ line_item.sku }}</td>
                  <td class="price money">{{ line_item.price | money }}</td>
                  <td class="quantity">{{ line_item.quantity }}</td>
                  <td class="total money">{{ line_item.quantity | times: line_item.price | money }}</td>
                </tr>
              {% endfor %}
            </tbody>
            <tfoot>
              <tr>
                <th colspan="4">Subtotal:</th>
                <td>{{ order.subtotal_price | money }}</td>
              </tr>
              {%- for discount in order.discounts -%}
                <tr>
                  <th colspan="4">{{ discount.code }} Discount:</th>
                  <td>{{ discount.savings | money }}</td>
                </tr>
              {%- endfor -%}
              {%- for shipping_method in order.shipping_methods -%}
                <tr>
                  <th colspan="4">Shipping ({{ shipping_method.title }}):</th>
                  <td>{{ shipping_method.price | money }}</td>
                </tr>
              {%- endfor -%}
              {%- for tax_line in order.tax_lines -%}
                <tr>
                  <th colspan="4">
                    Tax ({{ tax_line.title }}
                    {{ tax_line.rate | times: 100 }}%):
                  </th>
                  <td>{{ tax_line.price | money }}</td>
                </tr>
              {%- endfor -%}
              <tr>
                <th colspan="4">Total:</th>
                <td>{{ order.total_price | money }}</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>