{% comment %}
  Promotional Image Grid - Fully Customizable, Mobile Stacked
{% endcomment %}

<div class="promo-grid-wrapper">
  <div class="promo-grid">
    {% for block in section.blocks %}
      {% assign s = block.settings %}
      {% assign clickable = s.full_card_click %}
      
      <div class="promo-grid-item" {{ block.shopify_attributes }} style="max-width: {{ s.banner_width }}%;">
        
        {% if clickable and s.button_link != blank %}
          <a href="{{ s.button_link }}" class="full-card-link">
        {% endif %}
        
        {% if s.image %}
          <div class="promo-image">
            <img
              class="desktop-image"
              src="{{ s.image | image_url: width: 2000 }}"
              alt="{{ s.heading | escape }}"
            >
            {% if s.image_mobile %}
              <img
                class="mobile-image"
                src="{{ s.image_mobile | image_url: width: 1000 }}"
                alt="{{ s.heading | escape }}"
              >
            {% endif %}
          </div>
        {% endif %}
        
        <div class="promo-content" style="padding-top: {{ s.padding_top }}px; padding-bottom: {{ s.padding_bottom }}px;">
          {% if s.heading != blank %}
            <h3 style="
              font-size: {{ s.heading_font_size }}px;
              font-weight: {{ s.heading_font_weight }};
              color: {{ s.heading_color }};
              margin-bottom: {{ s.spacing_heading_text }}px;
            ">{{ s.heading }}</h3>
          {% endif %}

          {% if s.text != blank %}
            <p style="
              font-size: {{ s.text_font_size }}px;
              font-weight: {{ s.text_font_weight }};
              color: {{ s.text_color }};
              margin-bottom: {{ s.spacing_text_button }}px;
            ">{{ s.text }}</p>
          {% endif %}

          {% if s.button_label != blank and s.button_link != blank %}
            <a
              href="{{ s.button_link }}"
              class="promo-button {% if s.button_width == 'full' %}full-width{% endif %}"
              style="
                background-color: {{ s.button_bg }};
                color: {{ s.button_text_colour }};
                border: {{ s.button_border_width }}px solid {{ s.button_border_colour }};
                border-radius: {{ s.button_border_radius }}px;
                padding: {{ s.button_padding_top }}px {{ s.button_padding_sides }}px;
              "
              onmouseover="
                this.style.backgroundColor='{{ s.button_hover_bg }}';
                this.style.color='{{ s.button_hover_text_colour }}';
              "
              onmouseout="
                this.style.backgroundColor='{{ s.button_bg }}';
                this.style.color='{{ s.button_text_colour }}';
              "
            >
              {{ s.button_label }}
            </a>
          {% endif %}
        </div>

        {% if clickable and s.button_link != blank %}
          </a>
        {% endif %}

      </div>
    {% endfor %}
  </div>
</div>

<style>
.promo-grid-wrapper {
  max-width: 1550px;
  margin: 0 auto;
  padding: 0 20px;
}

.promo-grid {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  justify-content: center;
}

.promo-grid-item {
  text-align: center;
  position: relative;
}

.full-card-link {
  display: block;
  color: inherit;
  text-decoration: none;
}

.promo-image img {
  width: 100%;
  border-radius: 8px;
}

.mobile-image {
  display: none;
}

.promo-button {
  display: inline-block;
  font-family: "Montserrat", sans-serif;
  font-weight: 600;
  transition: all 0.25s ease;
  text-decoration: none;
}

.promo-button.full-width {
  width: 100%;
}

/* Desktop breakpoints */
@media screen and (max-width: 900px) {
  .promo-grid-item {
    flex: 1 1 48%;
    max-width: 48%;
  }
}

/* Mobile: stacked tiles full width */
@media screen and (max-width: 768px) {
  .promo-grid {
    flex-direction: column;
    gap: 20px; /* spacing between stacked tiles */
  }

  .promo-grid-item {
    max-width: 100% !important;
    flex: 1 1 100%;
  }

  .desktop-image {
    display: none;
  }

  .mobile-image {
    display: block;
  }
}
</style>

{% schema %}
{
  "name": "Promotional Image Grid",
  "max_blocks": 10,
  "settings": [],
  "blocks": [
    {
      "type": "image_block",
      "name": "Image Block",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Desktop image" },
        { "type": "image_picker", "id": "image_mobile", "label": "Mobile image" },

        { "type": "text", "id": "heading", "label": "Heading", "default": "Sale: Women" },
        { "type": "text", "id": "text", "label": "Text", "default": "Up to 50% off selected styles." },

        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "button_link", "label": "Button link" },

        { "type": "color", "id": "button_bg", "label": "Button background", "default": "#000000" },
        { "type": "color", "id": "button_text_colour", "label": "Button text colour", "default": "#ffffff" },
        { "type": "color", "id": "button_hover_bg", "label": "Button hover background", "default": "#333333" },
        { "type": "color", "id": "button_hover_text_colour", "label": "Button hover text colour", "default": "#ffffff" },
        { "type": "color", "id": "button_border_colour", "label": "Button border colour", "default": "#000000" },

        { "type": "number", "id": "button_border_width", "label": "Button border width (px)", "default": 0 },
        { "type": "range", "id": "button_border_radius", "label": "Button border radius", "min": 0, "max": 50, "step": 1, "default": 6 },
        { "type": "range", "id": "button_padding_top", "label": "Button padding top/bottom (px)", "min": 0, "max": 50, "step": 1, "default": 12 },
        { "type": "range", "id": "button_padding_sides", "label": "Button padding left/right (px)", "min": 5, "max": 50, "step": 1, "default": 24 },

        {
          "type": "select",
          "id": "button_width",
          "label": "Button width",
          "options": [
            { "value": "auto", "label": "Auto" },
            { "value": "full", "label": "Full width" }
          ],
          "default": "auto"
        },

        { "type": "checkbox", "id": "full_card_click", "label": "Make entire card clickable?", "default": false },
        { "type": "range", "id": "banner_width", "label": "Banner width (%)", "min": 20, "max": 100, "step": 1, "default": 32 },

        { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 0, "max": 100, "step": 1, "default": 12 },
        { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 0, "max": 100, "step": 1, "default": 12 },

        { "type": "range", "id": "spacing_heading_text", "label": "Spacing between heading and text (px)", "min": 0, "max": 50, "step": 1, "default": 6 },
        { "type": "range", "id": "spacing_text_button", "label": "Spacing between text and button (px)", "min": 0, "max": 50, "step": 1, "default": 12 },

        { "type": "range", "id": "heading_font_size", "label": "Heading font size (px)", "min": 10, "max": 60, "step": 1, "default": 18 },
        { "type": "select", "id": "heading_font_weight", "label": "Heading font weight", "options": [
            { "value": "400", "label": "400" },
            { "value": "500", "label": "500" },
            { "value": "600", "label": "600" },
            { "value": "700", "label": "700" }
          ],
          "default": "700"
        },
        { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#000000" },

        { "type": "range", "id": "text_font_size", "label": "Text font size (px)", "min": 10, "max": 40, "step": 1, "default": 14 },
        { "type": "select", "id": "text_font_weight", "label": "Text font weight", "options": [
            { "value": "400", "label": "400" },
            { "value": "500", "label": "500" },
            { "value": "600", "label": "600" },
            { "value": "700", "label": "700" }
          ],
          "default": "500"
        },
        { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promotional Image Grid",
      "category": "Custom"
    }
  ]
}
{% endschema %}
