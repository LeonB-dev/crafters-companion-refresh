{% liquid
  capture contentForQuerystring
    echo content_for_header
  endcapture

  assign pageUrl = contentForQuerystring | split: '"pageurl":"' | last | split: '"' | first | split: '.myshopify.com' | last | replace: '\/', '/' | replace: '%20', ' ' | replace: '\u0026', '&'
  assign querystring = pageUrl | split: '?' | last
  assign paginate_value = querystring | split: 'paginateby=' | last | slice: 0, 2 | replace: '&', ''
%}

{%- paginate collection.products by paginate_value -%}
  {%- if collection.products.size > 0 or search.results.size > 0 -%}
    {%- if paginate.previous -%}
      <div class="pagination prev" data-collection-pagination-less>
        {%- assign previous_url = paginate.previous.url | default: '#' -%}
        <a class="c-btn main tertiary center" href="{{ previous_url | url }}" data-collection-pagination-less-btn>{{ 'pagination.load_previous' | t }}</a>
      </div>
    {%- endif -%}
    <div hidden data-split></div>
    {% liquid
      if collection.products
        for product in collection.products
        render 'stmt-product-card', product: product, collection: collection, _sticker_logo: sticker_logo, _sticker_logo_alt: sticker_logo_alt
        endfor
      endif
    %}
    <div hidden data-split></div>
    {%- if paginate.next -%}
      <div class="pagination next" data-collection-pagination-more>
        {%- assign next_url = paginate.next.url | default: '#' -%}
        <a class="c-btn main tertiary center" href="{{ next_url | url }}" data-collection-pagination-more-btn>{{ 'pagination.load_more' | t }}</a>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="s-collection__empty">
      <p>{{ template.collection.empty }}</p>
    </div>
  {%- endif -%}
{%- endpaginate -%}
