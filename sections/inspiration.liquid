{% schema %}
{
  "name": "Inspiration",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "id": "title",
      "type": "inline_richtext",
      "label": "Title",
      "default": "Looking for your next bit of inspiration?"
    },
    {
      "id": "description",
      "type": "richtext",
      "label": "Description",
      "default": "<p>You've come to the right place! Take a look through our blog for our latest craft hints and tips, news, demonstration videos, launches and more.</p>"
    },
    {
      "id": "link_text",
      "type": "text",
      "label": "Link Text",
      "default": "See more"
    },
    {
      "id": "link_url",
      "type": "url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Blogs"
    },
    {
      "id": "blogs_title",
      "type": "text",
      "label": "Featured Blogs Title",
      "default": "Latest Blogs"
    },
    {
      "type": "link_list",
      "id": "blog_menu",
      "label": "Blogs Menu",
      "info": "The menu is used to find all blogs."
    },
    {
      "id": "blogs_tag",
      "type": "text",
      "label": "Tag To Filter Blogs (optional)",
      "info": "If entered, blogs shown will be filtered on this tag rather than just showing most recent"
    },
    {
      "id": "blog_limit",
      "type": "number",
      "label": "Featured Blogs Limit",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "autoplay_blogs",
      "label": "Autoplay Blog Slider?",
      "default": false
    },
    {
      "type": "header",
      "content": "Carousels"
    },
    {
      "type": "checkbox",
      "id": "autoplay_inspiration",
      "label": "Autoplay Inspirational Image Sliders?",
      "default": true
    },
    {
      "type": "header",
      "content": "Paper Edges"
    },
    {
      "type": "select",
      "id": "edge_version",
      "label": "Edge version",
      "options": [
        {
          "value": "edge-01",
          "label": "One"
        },
        {
          "value": "edge-02",
          "label": "Two"
        },
        {
          "value": "edge-03",
          "label": "Three"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "top_edge_colour",
      "label": "Top edge colour",
      "options": [
        {
          "value": "green",
          "label": "Green"
        },
        {
          "value": "pink",
          "label": "Pink"
        },
        {
          "value": "purple",
          "label": "Purple"
        },
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "is-hidden",
          "label": "None"
        }
      ],
      "default": "white"
    },
    {
      "type": "select",
      "id": "bottom_edge_colour",
      "label": "Bottom edge colour",
      "options": [
        {
          "value": "green",
          "label": "Green"
        },
        {
          "value": "pink",
          "label": "Pink"
        },
        {
          "value": "purple",
          "label": "Purple"
        },
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "is-hidden",
          "label": "None"
        }
      ],
      "default": "white"
    },
    {
      "type": "select",
      "id": "background_colour",
      "label": "Background colour",
      "info": "This can only be applied if a edge version is selected",
      "options": [
        {
          "value": "black-squeeze",
          "label": "Green"
        },
        {
          "value": "pippin",
          "label": "Pink"
        },
        {
          "value": "whisper",
          "label": "Purple"
        }
      ],
      "default": "whisper"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Add margin below",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        }
      ],
      "default": "lg"
    }
  ],
  "blocks": [
    {
      "name": "Carousel Image",
      "type": "image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Minimum width: 400px and 3/2 aspect ratio."
        },
        {
          "type": "article",
          "id": "article",
          "label": "article"
        }
      ]
    },
    {
      "name": "Carousel Video",
      "type": "video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "article",
          "id": "article",
          "label": "article"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inspiration",
      "category": "Content"
    }
  ]
}
{% endschema %}
