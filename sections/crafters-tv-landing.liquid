  background-repeat: no-repeat;
  background-size: 100%;
  background-position: top 4% right -24vw;
  z-index: 5;
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  opacity: 1;
}
@media (min-width: 768px) {
  .section-crafters-tv-landing .wrapper::after {
    background-image: url("data:image/svg+xml,%3Csvg clip-rule='evenodd' fill-rule='evenodd' stroke-linejoin='round' stroke-miterlimit='2' viewBox='0 0 1087 1522' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='m16.714 728.189c-22.285 15.956-22.285 49.091 0 65.047l1006.536 720.644c26.47 18.95 63.29.03 63.29-32.53v-1441.279c0-32.555-36.82-51.476-63.29-32.524z' fill='%231f1300' fill-opacity='.1' fill-rule='nonzero'/%3E%3C/svg%3E");
    background-position: top -20rem right -24vw;
  }
}
@media (min-width: 1024px) {
  .section-crafters-tv-landing .wrapper::after {
    background-position: top -28rem right -24vw;
  }
}
@media (min-width: 1024px) {
  .section-crafters-tv-landing .wrapper::after {
    background-position: top -40rem right -32vw;
  }
}
@media (min-width: 1280px) {
  .section-crafters-tv-landing .wrapper::after {
    background-position: top -44rem right -36vw;
  }
}
@media (min-width: 1600px) {
  .section-crafters-tv-landing .wrapper::after {
    background-position: top -52rem right -40vw;
  }
}
.section-crafters-tv-landing .container {
  position: relative;
  z-index: 10;
}
.section-crafters-tv-landing .actions {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 2rem;
  margin-bottom: 3rem;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] {
  width: 44rem;
  margin: 0 auto;
}
@media (max-width: 767.98px) {
  .section-crafters-tv-landing div[data-ctl-desktop-slider] {
    display: none;
  }
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide {
  display: grid;
  height: 28rem;
  width: 44rem;
  gap: 1rem;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide:not(.grid-trio) .media-content {
  position: absolute;
  inset: 0;
  height: 100%;
  width: 100%;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio {
  width: 38rem;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.wide {
  grid-template-columns: auto 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 1rem;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.wide > * {
  height: 100%;
  width: 100%;
  position: relative;
  overflow: hidden;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.wide > *:first-of-type {
  grid-column: 1/span 2;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.wide > *:nth-last-of-type(2) {
  grid-column: 1;
  aspect-ratio: 1;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.wide > *:last-of-type {
  grid-column: 2;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.wide > *:not(:first-of-type) {
  grid-row: 2;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.wide > *:not(:nth-last-of-type(2)) img, .section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.wide > *:not(:nth-last-of-type(2)) video {
  position: absolute;
  inset: 0;
  height: 100%;
  width: 100%;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.tall {
  grid-template-columns: 1fr auto;
  grid-template-rows: 1fr 1fr;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.tall > * {
  height: 100%;
  width: 100%;
  position: relative;
  overflow: hidden;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.tall > *:not(:first-of-type) {
  aspect-ratio: 1;
  grid-column: 2;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.tall > *:first-of-type {
  grid-column: 1;
  grid-row: 1/span 2;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.tall > *:nth-of-type(2) {
  grid-row: 1;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.tall > *:last-of-type {
  grid-row: 2;
}
.section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.tall:first-of-type img, .section-crafters-tv-landing div[data-ctl-desktop-slider] .swiper-slide.grid-trio.tall:first-of-type video {
  position: absolute;
  inset: 0;
  height: 100%;
  width: 100%;
}
.section-crafters-tv-landing div[data-ctl-mobile-slider] {
  padding: 0 1rem;
}
@media (min-width: 768px) {
  .section-crafters-tv-landing div[data-ctl-mobile-slider] {
    display: none;
  }
}
.section-crafters-tv-landing div[data-ctl-mobile-slider] img, .section-crafters-tv-landing div[data-ctl-mobile-slider] video {
  aspect-ratio: 3/2;
}
.section-crafters-tv-landing .swiper-container img, .section-crafters-tv-landing .swiper-container video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: var(--border-radius-lg);
}
{% endstylesheet %}

