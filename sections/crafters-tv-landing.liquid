{%- liquid
  assign template_name = 'section-crafters-tv-landing'
  assign live_show_url = shop.metafields.ctv.live_show.value

  if live_show_url == "false"
    assign live_show_url = blank
  endif
%}


<div class="{{- template_name }} u-space-below-lg overflow-hidden" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  <div class="wrapper">
    {%- render 'paper-edge', _edge_version: 'edge-03', _bottom_edge_colour: 'white' -%}
    <div class="container">
      {%-
        render 'crafters-tv-heading',
        _title: section.settings.title,
        _heading: section.settings.heading,
        _text: section.settings.text,
        _text_class: 'u-text-xl'
      -%}
      <div class="actions">
        {% if live_show_url != blank %}
          <a href="{{- live_show_url -}}" class="c-btn main tertiary has-icon">
            {%- render 'icon', _name: 'icon-tv' %}
            {{ 'ctv.watch_live' | t }}
            {%- render 'icon', _name: 'icon-arrow-right' %}
          </a>
        {% endif %}
        <a href="{{- settings.ctv_schedule_link -}}" class="c-btn main secondary has-icon">
          {%- render 'icon', _name: 'icon-tv' %}
          {{ 'ctv.view_schedule' | t }}
          {%- render 'icon', _name: 'icon-arrow-right' %}
        </a>
      </div>
      <div class="swiper-container" data-ctl-desktop-slider>
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}

            {% liquid
              assign video = block.settings.video
              assign image = block.settings.image
            %}

            {%- if forloop.index == 1 -%}
              <div class="swiper-slide grid-single">
            {%- endif -%}
            {%- if forloop.index == 2 -%}
              </div>
              <div class="swiper-slide grid-trio wide">
            {%- endif %}
            {%- if forloop.index == 5 -%}
              </div>
              <div class="swiper-slide ">
            {%- endif -%}
            {%- if forloop.index == 6 -%}
              </div>
              <div class="swiper-slide grid-trio tall">
              {%- endif -%}
              <div class="media-content">
                {%- if block.type == 'video' -%}
                  {{- video | video_tag: image_size: '740px', autoplay: true, loop: true, controls: false, muted: true -}}
                {%- else -%}
                  {{- image | image_url: width: 800 | image_tag: widths: '400, 600, 800', alt: image.alt, loading: 'eager' -}}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
      <div class="swiper-container" data-ctl-mobile-slider>
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div class="swiper-slide">
              {%- if block.type == 'video' -%}
                {{- video | video_tag: image_size: '600px', loop: true, controls: false, muted: true -}}
                {%- else -%}
                {{- image | image_url: width: 800 | image_tag: widths: '400, 600, 800', alt: image.alt, loading: 'eager' -}}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.section-crafters-tv-landing .wrapper {
  padding: 3rem 0 4rem 0;
  position: relative;
  z-index: 1;
  color: var(--colour-sugar-cane);
  overflow: hidden;
}
@media (min-width: 768px) {
  .section-crafters-tv-landing .wrapper {
    padding: 4.5rem 0 7rem 0;
  }
}
.section-crafters-tv-landing .wrapper:before {
  content: "";
  background: radial-gradient(circle, #90489c 0%, #4b3ab0 100%);
  position: absolute;
  inset: 0;
  height: calc(100% - 1px);
  width: 100%;
  z-index: 1;
}
