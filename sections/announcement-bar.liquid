{% unless section.settings.index_only == true and template.name != 'index' %}
 

  {% assign numberOfAnnoucements = 0 %}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'announcement' -%}
        {%- if block.settings.text != blank -%}
          {% assign numberOfAnnoucements = numberOfAnnoucements | plus: 1 %}
        {%- endif -%}
    {%- endcase -%}
  {%- endfor -%}

  {% assign timePerAnnouncement = 5  %}
  {% assign animationTotalDuration = numberOfAnnoucements | times: timePerAnnouncement %}

  {%  style %}

    .announcement-items__container > .announcement-item {
      width: 100%;
      position: absolute  ;
      top: 0;
      display: flex;
      justify-content: center;
      {% if numberOfAnnoucements > 1 %}
        animation: rotate-slides {{ animationTotalDuration }}s ease-in-out infinite;
      {% endif %}
    }

    {% assign percentageForEachSlide =  100.00 | divided_by: numberOfAnnoucements %}
    {% assign transitionPercentageForEachSlide = percentageForEachSlide | times: 0.15 %}

@keyframes rotate-slides {
{%- liquid
  assign step1End = percentageForEachSlide
  assign transitionStart = step1End | minus: transitionPercentageForEachSlide
  assign step2End = percentageForEachSlide | plus: percentageForEachSlide
  assign transition2Start = step2End | minus: transitionPercentageForEachSlide
-%}
0%                      { transform: translateX(100%);}
{{ transitionStart }}%  { transform: translateX(100%);}
{{ step1End }}%         { transform: translateX(0%); z-index: 1;}
{{ transition2Start }}% { transform: translateX(0%);}
{{ step2End }}%         { transform: translateX(-100%);}
100%                    { transform: translateX(-100%);}
}

{% for i in (1..numberOfAnnoucements) %}
  {% assign offset = forloop.index0 | minus: 1%}
  {% assign delay = offset | times: 5 %}
  .announcement-items__container > .announcement-item:nth-child({{ i }}) {
    animation-delay: {{ delay }}s
  }
{% endfor %}

  {% endstyle  %}

  <div class="announcement-bar ge-hide-display-none
    {{ section.settings.section_margin_top }}
    {{ section.settings.section_margin_bottom }}
    " role="region" aria-label="Announcement">
  <div class="announcement-items__container  slides-{{ numberOfAnnoucements }}">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'announcement' -%}
          {% assign text_desktop = block.settings.text %}
          {% assign text_mobile = block.settings.text_mobile %}
          {% if text_mobile == blank %}
            {% assign text_mobile = text_desktop %}
          {%  endif %}
          <div class="announcement-item" style="background-color: {{ block.settings.announcement_bg }};">
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
            {%- endif -%}
              <span class="announcement-bar__message" style="color: {{ block.settings.announcement_text }};">
                {{ text_desktop }}
              </span>
              <span class="announcement-bar__message_mobile" style="color: {{ block.settings.announcement_text }};">
                {{ text_mobile }}
              </span>
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
    </div>
  </div>
{% endunless %}

{% stylesheet %}
@media (min-width: 768px) {
  .announcement-bar-section {
    position: -webkit-sticky;
    position: sticky;
    top: 0;
    z-index: 999;
  }
}
.announcement-bar {
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  color: black;
  height: 3rem;
  display: flex;
  overflow: hidden;
  z-index: 115;
  position: relative;
}

.announcement-items__container {
  width: 100%;
  display: flex;
  overflow: hidden;
  position: relative;
}

.announcement-bar .announcement-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  flex: 1 0 100%;
}

.announcement-bar__link {
  display: block;
  text-decoration: none;
  text-align: center;
}

.announcement-bar__link .icon-arrow {
  display: inline-block;
  pointer-events: none;
  margin-left: 0.25rem;
  vertical-align: middle;
  margin-bottom: 1px;
}

.announcement-bar__message {
  display: none;
}

@media (min-width: 750px) {
  .announcement-bar__message {
    display: inline;
  }

  .announcement-bar__message_mobile {
    display: none;
  }
}
.announcement-bar__link .announcement-bar__message {
  padding: 0 0.125rem;
}

.announcement-bar .announcement-bar__message,
.announcement-bar .announcement-bar__message_mobile {
  margin: 0;
  padding: 0 1rem;
  font-size: 0.875rem;
  font-weight: 400;
  text-align: center;
}

.announcement-item span a,
.announcement-item span a:visited,
.announcement-item span a:hover,
.announcement-item span a:focus,
.announcement-item span a:active {
  color: inherit;
}

p.announcement-bar__message {
  text-align: center;
}

/* annoucment bar animation */
.announcement-items__container > .announcement-item {
  width: 100%;
  position: absolute;
  top: 0;
  display: flex;
  justify-content: center;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement Bar",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "index_only",
      "label": "Limit to homepage?",
      "info": "The announcement bar will only render on the homepage."
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "inline_richtext",
          "id": "text_mobile",
          "label": "Text (mobile)",
          "info": "Desktop text will be shown when blank"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
                {
          "type": "color",
          "id": "announcement_bg",
          "label": "Background Colour",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "announcement_text",
          "label": "Text Colour",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "Content"
    }
  ]
}
{% endschema %}