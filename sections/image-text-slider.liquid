        },
        {
          "value": "lg",
          "label": "Large"
        }
      ],
      "default": "lg"
    }
  ],
  "blocks": [
    {
      "type": "info_block",
      "name": "Information Block",
      "limit": 3,
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "small_heading",
          "label": "Subheading",
          "info": "To appear above title."
        },
        {
