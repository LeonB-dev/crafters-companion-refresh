{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "checkbox",
      "id": "hide_newsletter_section",
      "label": "Hide the newsletter section.",
      "default": false
    },
  ],
  "blocks": [
    {
      "type": "accordion-item",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "checkbox",
          "id": "use_description",
          "label": "Use Product Description?",
          "default": false
        }
      ]
    }
  ]
}
{% endschema %}
