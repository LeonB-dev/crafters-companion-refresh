  height: 3.5rem;
  border-radius: 1.75rem;
  padding: 0 2rem;
  font-size: 1rem;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  background-color: transparent;
  color: var(--colour-emperor) !important;
  transform: none;
  transition: all var(--transition-duration) var(--transition-timing) 0s;
  border: 1px solid var(--colour-whisper);
  text-transform: none;
  text-indent: none;
  line-height: normal;
}
