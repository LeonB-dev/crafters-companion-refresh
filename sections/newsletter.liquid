{%- liquid
  assign template_name = 'section-newsletter'

  if template contains 'page'
    assign brand_metaobject = page.metafields.custom.brand.value
    assign hide_section = page.metafields.custom.hide_newsletter_section
  elsif template contains 'collection'
    assign brand_metaobject = collection.metafields.custom.brand.value
    assign hide_section = collection.metafields.custom.hide_newsletter_section
  elsif template contains 'product'
    assign brand_metaobject = product.metafields.brand.parent_brand.value
  endif

  if brand_metaobject != blank
    assign newsletter_background_colour = brand_metaobject.newsletter_background_colour
    assign newsletter_text_colour = brand_metaobject.newsletter_text_colour
    assign newsletter_link_background_colour = brand_metaobject.newsletter_link_background_colour
    assign newsletter_text_link_colour = brand_metaobject.newsletter_text_link_colour
  endif

  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
%}

<style>
  #shopify-section-{{ section.id }} {
    margin-top: {{ margin_top }}px;
    margin-bottom: {{ margin_bottom }}px;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
</style>


  {% if hide_section != true %}
  {{- 'section-newsletter.css' | asset_url | stylesheet_tag -}}

  {% if brand_metaobject != blank %}
    <style>
      div[data-section-id="{{ section.id }}"]{
        background-color: {{ newsletter_background_colour }} !important;
        color: {{ newsletter_text_colour }} !important;
      }
      div[data-section-id="{{ section.id }}"] .c-btn{
        background: {{ newsletter_link_background_colour }} !important;
        color: {{ newsletter_text_link_colour }} !important;
      }

      .section-footer svg.top{
        fill: {{ newsletter_background_colour }}
      }
    </style>
  {% endif %}
  <div class="{{- template_name }}" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
    {%- render 'paper-edge', _section: section -%}
    <div class="container">
      <div class="u-text-lg subheading">{{ section.settings.subheading }}</div>
      <h2 class="u-heading-sm">{{ section.settings.title }}</h2>
      {{ section.settings.text }}
      <a href="{{ section.settings.link_url }}" class="c-btn main secondary">{{ section.settings.link_text }}</a>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "info": "To appear above heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Margin top",
      "default": 16
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Margin bottom",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 16
    },
    {
      "type": "header",
      "content": "Paper Edges"
    },
    {
      "type": "select",
      "id": "edge_version",
      "label": "Edge version",
      "options": [
        {
          "value": "edge-01",
          "label": "One"
        },
        {
          "value": "edge-02",
          "label": "Two"
        },
        {
          "value": "edge-03",
          "label": "Three"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "top_edge_colour",
      "label": "Top edge colour",
      "options": [
        {
          "value": "green",
          "label": "Green"
        },
        {
          "value": "pink",
          "label": "Pink"
        },
        {
          "value": "purple",
          "label": "Purple"
        },
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "is-hidden",
          "label": "None"
        }
      ],
      "default": "white"
    },
    {
      "type": "select",
      "id": "bottom_edge_colour",
      "label": "Bottom edge colour",
      "options": [
        {
          "value": "green",
          "label": "Green"
        },
        {
          "value": "pink",
          "label": "Pink"
        },
        {
          "value": "purple",
          "label": "Purple"
        },
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "is-hidden",
          "label": "None"
        }
      ],
      "default": "white"
    },
    {
      "type": "select",
      "id": "background_colour",
      "label": "Background colour",
      "info": "This can only be applied if a edge version is selected",
      "options": [
        {
          "value": "black-squeeze",
          "label": "Green"
        },
        {
          "value": "pippin",
          "label": "Pink"
        },
        {
          "value": "whisper",
          "label": "Purple"
        }
      ],
      "default": "pippin"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Newsletter",
      "category": "Content"
    }
  ]
}
{% endschema %}
