{% schema %}
  {
    "name": "CTV Meet the Experts",
    "tag": "section",
    "settings": [
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "inline_richtext",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text"
      }
    ],
    "blocks": [
      {
        "type": "carousel_image",
        "name": "Expert Carousel Image",
        "settings": [
          {
            "type": "text",
            "id": "name",
            "label": "Expert Name"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Expert Image",
            "info": "Minimum width: 500px and 5/4 aspect ratio."
          }
        ]
      }
    ]
  }
{% endschema %}