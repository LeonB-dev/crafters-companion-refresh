{%- liquid
  assign template_name = 'section-crafters-tv-meet-the-experts'
%}

{{- 'section-crafters-tv-meet-the-experts.css' | asset_url | stylesheet_tag -}}
<script defer src="{{- 'section-crafters-tv-meet-the-experts.js' | asset_url -}}"></script>

<div
  class="{{- template_name }} u-space-below-lg overflow-hidden"
  data-section-type="{{- template_name -}}"
  data-section-id="{{ section.id }}">
  <div class="wrapper">
    {%- render 'paper-edge', _edge_version: 'edge-03', _bottom_edge_colour: 'white' -%}
    <div class="container">
      {%-
        render 'crafters-tv-heading',
        _heading: section.settings.title,
        _title: section.settings.heading,
        _text: section.settings.text,
        _text_class: ''
      -%}
      {% if section.blocks.size > 0 %}
        <div class="swiper-outer-wrapper">
          <div class="swiper-container" data-ctmte-slider>
            <div class="swiper-wrapper">
              {%- for block in section.blocks -%}
                {% liquid
                  assign image = block.settings.image
                  assign name = block.settings.name
                  assign image_lazy = 'lazy'
                  if forloop.first == true
                    assign image_lazy = 'eager'
                  endif
                %}
                <div class="swiper-slide">
                  {%- if image != blank -%}
                    {{- image | image_url: width: 800 | image_tag: alt: image.alt, loading: image_lazy -}}
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag }}
                  {%- endif -%}
                  {%- if name != blank -%}
                    <span class="c-lozenge royal-purple">{{- name -}}</span>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
            <button
              class=" c-btn swiper-button prev"
              aria-label="Previous"
              data-ctmte-slider-prev>
              {%- render 'icon', _name: 'icon-arrow-left' -%}
            </button>
            <button
              class="c-btn swiper-button next"
              aria-label="Next"
              data-ctmte-slider-next>
              {%- render 'icon', _name: 'icon-arrow-right' -%}
            </button>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "CTV Meet the Experts",
    "tag": "section",
    "settings": [
      {
        "type": "header",
        "content": "Content"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "inline_richtext",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text"
      }
    ],
    "blocks": [
      {
        "type": "carousel_image",
        "name": "Expert Carousel Image",
        "settings": [
          {
            "type": "text",
            "id": "name",
            "label": "Expert Name"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Expert Image",
            "info": "Minimum width: 500px and 5/4 aspect ratio."
          }
        ]
      }
    ]
  }
{% endschema %}