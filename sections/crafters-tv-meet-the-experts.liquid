.section-crafters-tv-meet-the-experts .container {
  position: relative;
  z-index: 10;
}
.section-crafters-tv-meet-the-experts .swiper-outer-wrapper {
  display: flex;
  justify-content: center;
  position: relative;
}
.section-crafters-tv-meet-the-experts .swiper-container {
  padding: 0 1rem;
  width: 100%;
}
@media (min-width: 768px) {
  .section-crafters-tv-meet-the-experts .swiper-container {
    width: 44rem;
  }
}
.section-crafters-tv-meet-the-experts .swiper-wrapper {
  align-items: center;
}
.section-crafters-tv-meet-the-experts .swiper-slide {
  position: relative;
  height: auto;
}
@media (min-width: 768px) {
  .section-crafters-tv-meet-the-experts .swiper-slide {
    opacity: 0.4;
    height: 29.5rem;
    width: 32rem;
    transition: all var(--transition-duration) var(--transition-timing) 0s;
    display: flex;
    align-items: center;
  }
}
@media (min-width: 768px) {
  .section-crafters-tv-meet-the-experts .swiper-slide.swiper-slide-active {
    width: 44rem;
    opacity: 1;
  }
}
.section-crafters-tv-meet-the-experts .swiper-slide.swiper-slide-active span {
  opacity: 1;
  transition-delay: var(--transition-duration);
}
.section-crafters-tv-meet-the-experts .swiper-slide img {
  position: relative;
  z-index: 1;
  aspect-ratio: 3/2;
  object-fit: cover;
  display: block;
  width: 100%;
  height: auto;
  border-radius: var(--border-radius-xl);
}
.section-crafters-tv-meet-the-experts .swiper-slide span {
  --lozenge-position: 0.5rem;
  position: absolute;
  top: auto;
  left: auto;
  right: var(--lozenge-position);
  bottom: var(--lozenge-position);
  height: -webkit-fit-content;
  height: -moz-fit-content;
  height: fit-content;
  width: -webkit-fit-content;
  width: -moz-fit-content;
  width: fit-content;
  z-index: 5;
  opacity: 0;
  transition: opacity var(--transition-duration) var(--transition-timing) 0s;
}
@media (min-width: 768px) {
  .section-crafters-tv-meet-the-experts .swiper-slide span {
    --lozenge-position: 1rem;
  }
}
.section-crafters-tv-meet-the-experts .swiper-button {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}
.section-crafters-tv-meet-the-experts .swiper-button.prev {
  left: 1rem;
}
.section-crafters-tv-meet-the-experts .swiper-button.next {
  right: 1rem;
}
{% endstylesheet %}

