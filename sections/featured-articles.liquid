{%- liquid
  assign template_name = 'section-featured-articles'

  assign margin_bottom = section.settings.margin_bottom
%}

{{- 'snippet-article-item.css' | asset_url | stylesheet_tag -}}

<div class="{{- template_name }} u-space-below-{{- margin_bottom }} overflow-hidden" data-section-type="{{- template_name -}}" data-section-id="{{ section.id }}">
  {%-
    render 'paper-edge',
    _section: section
  -%}
  <div class="container">
    {%-
      render 'section-header',
      _image: section.settings.image,
      _heading: section.settings.heading
      _text: section.settings.text
      _offset: true,
      _heading_class: 'u-heading-xs',
      _link_url: section.settings.link_url
      _link_text: section.settings.link_text
      _loading: 'lazy'
    -%}
    <div class="swiper-container" data-fa-slider>
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide">
            {%-
              render 'article-item',
              _article: block.settings.article
            -%}
          </div>
        {%- endfor -%}
      </div>
      <div class="swiper-nav">
        <button class=" c-btn swiper-button prev" aria-label="Previous" data-fa-prev>
          {%- render 'icon', _name: 'icon-arrow-left' -%}
        </button>
        <button class="c-btn swiper-button next" aria-label="Next" data-fa-next>
          {%- render 'icon', _name: 'icon-arrow-right' -%}
        </button>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.section-featured-articles .swiper-container {
  position: relative;
}
@media (max-width: 1023.98px) {
  .section-featured-articles .swiper-container {
    padding-bottom: 4rem;
  }
}
@media (min-width: 1024px) {
  .section-featured-articles .swiper-wrapper {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
}
.section-featured-articles .swiper-slide {
  height: auto;
}
.section-featured-articles .swiper-nav {
  position: absolute;
  right: 0;
  bottom: 0;
}
@media (min-width: 1024px) {
  .section-featured-articles .swiper-nav {
    display: none;
  }
}
{% endstylesheet %}

{% javascript %}
(()=>{"use strict";var e,i;e="section-featured-articles",i={async onLoad(){window.matchMedia(`(min-width: ${window.theme.breakpoints.lg}px)`).matches||this.loadSlider()},loadSlider(){window.theme.Swiper?this.initSlider():document.addEventListener("theme:inititialised",(()=>{this.initSlider()}),{once:!0})},initSlider(){this.container.querySelectorAll("[data-fa-slider]").forEach((e=>{const i=e.querySelector("[data-fa-prev]"),t=e.querySelector("[data-fa-next]");new window.theme.Swiper(e,{slidesPerView:1,loop:!1,spaceBetween:16,simulateTouch:!1,navigation:{prevEl:i,nextEl:t},breakpoints:{[theme.breakpoints.sm]:{slidesPerView:1.4},[theme.breakpoints.md]:{slidesPerView:2}}})}))}},Shopify.theme.sections&&Shopify.theme.sections.register?(0===Shopify.theme.sections.getInstances(e).length&&Shopify.theme.sections.register(e,i),Shopify.theme.sections.load(e)):function(e,i){var t={name:e,events:i};theme.sections.push(t)}(e,i)})();
